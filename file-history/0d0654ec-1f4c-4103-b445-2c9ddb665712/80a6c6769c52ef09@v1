"""
Data pipeline helpers for the solver trigger flow.

Handles:
- Locked assignment filtering (lock_allocations + locked_date_ranges)
- Resource target filtering (team/group)
- Date range overlap logic
"""
import logging
from datetime import date
from typing import List, Optional, Set

logger = logging.getLogger(__name__)


def parse_date(date_str: str) -> Optional[date]:
    """Parse YYYY-MM-DD string to date, stripping any time component.

    Handles formats:
    - YYYY-MM-DD (plain date)
    - YYYY-MM-DDTHH:MM:SS... (ISO 8601 with T separator)
    - YYYY-MM-DD HH:MM:SS... (space-separated datetime from API)
    """
    if not date_str:
        return None
    # Strip time component - handle both T and space separators
    if 'T' in date_str:
        date_str = date_str.split('T')[0]
    elif ' ' in date_str:
        date_str = date_str.split(' ')[0]
    try:
        parts = date_str.split('-')
        return date(int(parts[0]), int(parts[1]), int(parts[2]))
    except (ValueError, IndexError):
        return None


def ranges_overlap(a_start: date, a_end: date, b_start: date, b_end: date) -> bool:
    """Check if two date ranges overlap (inclusive on both ends)."""
    return a_start <= b_end and b_start <= a_end


def block_in_locked_ranges(block: dict, locked_ranges: list) -> bool:
    """
    Check if a resource block overlaps with any of the locked date ranges.

    Args:
        block: Resource block dict with 'start_date' and 'end_date' keys
        locked_ranges: List of LockedDateRange-like dicts with 'start' and 'end' keys

    Returns:
        True if the block overlaps with at least one locked range
    """
    block_start = parse_date(block.get('start_date', ''))
    block_end = parse_date(block.get('end_date', ''))
    if not block_start or not block_end:
        return False

    for lr in locked_ranges:
        lr_start = parse_date(lr.get('start', '') if isinstance(lr, dict) else lr.start)
        lr_end = parse_date(lr.get('end', '') if isinstance(lr, dict) else lr.end)
        if not lr_start or not lr_end:
            continue
        # Skip inverted ranges (start > end) — treat as invalid, ignore
        if lr_start > lr_end:
            logger.warning(f"Ignoring inverted locked_date_range: start={lr_start} > end={lr_end}")
            continue
        if ranges_overlap(block_start, block_end, lr_start, lr_end):
            return True
    return False


def filter_resources_by_teams(resources: list, team_ids: Set[int]) -> list:
    """Filter resources to only those belonging to specified teams."""
    if not team_ids:
        return resources
    return [r for r in resources if r.get('team_id') in team_ids]


def filter_resources_by_groups(resources: list, group_ids: Set[int]) -> list:
    """Filter resources to only those belonging to specified groups."""
    if not group_ids:
        return resources
    return [r for r in resources if r.get('group_id') in group_ids]


def build_locked_assignments(
    service_blocks: list,
    lock_allocations: bool,
    locked_ranges: list,
    replannable_types: List[str]
) -> list:
    """
    Build the final set of locked service assignments.

    Pipeline:
    1. If locked_date_ranges provided -> keep only blocks overlapping with any locked range
    2. If no locked_date_ranges -> keep all blocks (all in plan_range are locked)
    3. Exclude replannable_demand_type from remaining
    4. Return final locked set

    Args:
        service_blocks: Raw service blocks from API (already date-filtered by plan_range)
        lock_allocations: Master switch (should be True when calling this)
        locked_ranges: List of LockedDateRange dicts/objects
        replannable_types: Calendar types to exclude (always active)

    Returns:
        Filtered list of service blocks that should lock resources
    """
    if not lock_allocations:
        return []

    # Step 1: Filter by locked date ranges (if provided)
    if locked_ranges:
        # Convert pydantic models to dicts if needed
        ranges_as_dicts = []
        for lr in locked_ranges:
            if hasattr(lr, 'start'):
                ranges_as_dicts.append({'start': lr.start, 'end': lr.end})
            else:
                ranges_as_dicts.append(lr)

        filtered = [b for b in service_blocks if block_in_locked_ranges(b, ranges_as_dicts)]
    else:
        # No locked ranges = all blocks in plan_range are locked
        filtered = list(service_blocks)

    # Step 2: Exclude replannable types
    if replannable_types:
        replannable_set = set(replannable_types)
        filtered = [
            b for b in filtered
            if b.get('block_type', '') not in replannable_set
        ]

    return filtered
