    # ==================== Resource Blocks (Absences with resource_id) ====================

    def get_resource_blocks(self, category: str = "all",
                            resource_ids: Optional[List[int]] = None,
                            start_date: Optional[str] = None,
                            end_date: Optional[str] = None,
                            exclude_calendar_types: Optional[List[str]] = None) -> Dict:
        """
        Fetch resource blocks (absences/service blocks) with resource_id resolved.
        Uses the new /resource-blocks/ endpoint that maps family_name to resource_id.

        Args:
            category: "blocking" for absences, "service" for job assignments, "all" for both
            resource_ids: Optional list of resource IDs to filter
            start_date: Filter blocks from this date (YYYY-MM-DD)
            end_date: Filter blocks to this date (YYYY-MM-DD)
            exclude_calendar_types: Calendar types to EXCLUDE (replannable types).
                                   Types NOT in this list will block resources.

        Returns:
            Dict with 'data' containing list of blocks with:
            - block_id: int
            - resource_id: int (resolved from family_name)
            - family_name: str
            - block_type: str (e.g., "Vacances", "RT Jour de repos")
            - start_date: str
            - end_date: str
            - status: str
            - notes: str
        """
        params = {
            'per_page': 1000,  # Larger page size to reduce HTTP round trips
            'category': category
        }
        if resource_ids:
            params['resource_ids'] = ','.join(str(rid) for rid in resource_ids)
        if start_date:
            params['start_date'] = start_date
        if end_date:
            params['end_date'] = end_date
        if exclude_calendar_types:
            params['exclude_calendar_types'] = ','.join(exclude_calendar_types)

        all_blocks = []
        page = 1
        total_pages = None

        while total_pages is None or page <= total_pages:
            params['page'] = page
            response = self.client.get(f"{self.base_url}/resource-blocks/", params=params)
            response.raise_for_status()
            data = response.json()

            if page == 1:
                total_pages = data.get('total_pages', 1)
                print(f"  Fetching {data.get('total', 0)} resource blocks ({category}) across {total_pages} pages...")

            all_blocks.extend(data.get('data', []))
            print(f"  Page {page}/{total_pages} fetched ({len(all_blocks)} blocks so far)")
            page += 1

        return {
            'data': all_blocks,
            'total': len(all_blocks),
            'page': 1,
            'per_page': len(all_blocks)
        }

