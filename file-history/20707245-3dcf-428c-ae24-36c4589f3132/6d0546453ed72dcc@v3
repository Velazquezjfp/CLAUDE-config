    # ==================== Operation Points ====================

    def get_operation_points(self, team_ids: List[int] = None) -> List[Dict]:
        """
        Fetch operation points, optionally filtered by team_ids.
        Returns list of dicts with station_code, station_name, team_id, etc.
        Paginates automatically.
        """
        params = {'per_page': 200}
        all_points = []
        # If single team_id, use server-side filter
        if team_ids and len(team_ids) == 1:
            params['team_id'] = team_ids[0]

        page = 1
        total_pages = None

        while total_pages is None or page <= total_pages:
            params['page'] = page
            response = self.client.get(f"{self.base_url}/operation-points/", params=params)
            response.raise_for_status()
            data = response.json()

            if page == 1:
                total_pages = data.get('total_pages', 1)

            all_points.extend(data.get('data', []))
            page += 1

        # Client-side filter for multiple team_ids
        if team_ids and len(team_ids) > 1:
            team_set = set(team_ids)
            all_points = [op for op in all_points if op.get('team_id') in team_set]

        return all_points

