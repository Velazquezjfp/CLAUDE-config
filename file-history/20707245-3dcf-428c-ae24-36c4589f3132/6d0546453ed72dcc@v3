    # ==================== Legal Constraints ====================

    def get_legal_constraint(self, constraint_name: str) -> Dict:
        """Fetch legal constraint by name"""
        params = {'constraint_name': constraint_name}
        response = self.client.get(f"{self.base_url}/legal-constraints/", params=params)
        response.raise_for_status()
        data = response.json()

        # Find the specific constraint
        for constraint in data:
            if constraint['constraint_name'] == constraint_name:
                return constraint

        raise ValueError(f"Constraint {constraint_name} not found")

    def get_all_legal_constraints(self) -> List[Dict]:
        """Fetch all legal constraints"""
        response = self.client.get(f"{self.base_url}/legal-constraints/")
        response.raise_for_status()
        return response.json()

    # ==================== Company Policy Constraints ====================

    def get_company_policy(self, policy_name: str,
                          planning_mode: Optional[str] = None,
                          user_id: Optional[str] = None) -> Dict:
        """Fetch company policy constraint by name (DYNAMIC)"""
        params = {}
        if planning_mode:
            params['planning_mode'] = planning_mode
        if user_id and user_id != 'global':
            params['user_id'] = user_id

        response = self.client.get(f"{self.base_url}/company-policy-constraints/",
                                  params=params)
        response.raise_for_status()
        data = response.json()

        # Find the specific policy
        for policy in data:
            if policy['policy_name'] == policy_name:
                return policy

        # Fallback: if user-specific returned nothing, retry with global
        if user_id and user_id != 'global':
            print(f"  [FALLBACK] No policies for user '{user_id}', falling back to global")
            return self.get_company_policy(policy_name, planning_mode, user_id=None)

        raise ValueError(f"Policy {policy_name} not found")

    def get_all_company_policies(self, user_id: Optional[str] = None) -> List[Dict]:
        """Fetch all company policies"""
        params = {}
        if user_id and user_id != 'global':
            params['user_id'] = user_id
        response = self.client.get(f"{self.base_url}/company-policy-constraints/", params=params)
        response.raise_for_status()
        data = response.json()

        # Fallback: if user-specific returned nothing, retry with global
        if not data and user_id and user_id != 'global':
            print(f"  [FALLBACK] No policies for user '{user_id}', falling back to global")
            return self.get_all_company_policies(user_id=None)

        return data

    # ==================== Objective Weights ====================

    def get_objective_weights(self, user_id: Optional[str] = None) -> List[Dict]:
        """
        Fetch all objective weights from backend.
        Falls back to global if user-specific returns empty.

        Args:
            user_id: User context ID (defaults to 'global' on server)

        Returns:
            List of objective weight dicts with:
            - objective_name: str
            - weight_coefficient: float
            - objective_category: str
            - description: str
            - active: bool
        """
        params = {}
        if user_id and user_id != 'global':
            params['user_id'] = user_id
        response = self.client.get(f"{self.base_url}/objective-weights/", params=params)
        response.raise_for_status()
        data = response.json()

        # Fallback: if user-specific returned nothing, retry with global
        if not data and user_id and user_id != 'global':
            print(f"  [FALLBACK] No objective weights for user '{user_id}', falling back to global")
            return self.get_objective_weights(user_id=None)

        return data

    def get_objective_weight(self, objective_name: str, user_id: Optional[str] = None) -> Dict:
        """
        Fetch specific objective weight by name.
        Falls back to global if user-specific returns nothing.

        Args:
            objective_name: Name of the objective (e.g., 'maximize_coverage')
            user_id: User context ID (defaults to 'global' on server)

        Returns:
            Objective weight dict
        """
        weights = self.get_objective_weights(user_id=user_id)
        for w in weights:
            if w['objective_name'] == objective_name:
                return w
        # get_objective_weights already falls back to global,
        # so if we still can't find it, it truly doesn't exist
        raise ValueError(f"Objective '{objective_name}' not found in backend")

    # ==================== Utility Methods ====================

    def fetch_constraint_values(self, legal_constraint_name: str,
                               company_policy_name: str,
                               planning_mode: Optional[str] = None,
                               user_id: Optional[str] = None) -> tuple:
        """
        Fetch both legal and company constraint values
        Returns: (legal_constraint, company_policy)
        """
        legal = self.get_legal_constraint(legal_constraint_name)
        company = self.get_company_policy(company_policy_name, planning_mode, user_id=user_id)
        return legal, company

    def fetch_test_dataset(self, num_requests: int = 2,
                          num_resources: int = 3) -> Dict:
        """
        Fetch a small test dataset for initial testing
        Returns: Dict with requests, resources, absences

        Note: API doesn't respect limit param, so we manually slice results
        """
        # Fetch all data and manually limit (API doesn't respect limit parameter)
        requests_data = self.get_requests()
        requests_data['data'] = requests_data['data'][:num_requests]
        requests_data['total'] = len(requests_data['data'])

        resources_data = self.get_resources()
        resources_data['data'] = resources_data['data'][:num_resources]
        resources_data['total'] = len(resources_data['data'])

        # Fetch absences for selected resources
        resource_ids = [r['resource_id'] for r in resources_data['data']]
        all_absences = []
        for resource_id in resource_ids:
            absences = self.get_absences(resource_id=resource_id)
            all_absences.extend(absences.get('data', []))

        return {
            'requests': requests_data,
            'resources': resources_data,
            'absences': {'data': all_absences, 'total': len(all_absences)}
        }


    # ==================== Planner Output ====================

    def post_planner_output(self, plan_id: str, status: str, assignments: List[Dict],
                           num_requests: int, num_resources: int, num_violations: int,
                           solve_time_seconds: float, metadata: Dict = None,
                           job_id: str = None,
                           fetch_rt: bool = True, fetch_ct: bool = True) -> Dict:
        """
        POST solver results to planner_output table.

        Args:
            plan_id: Unique plan identifier (e.g., "PLAN-20250123-DEV-U123")
            status: Solver status ("OPTIMAL", "FEASIBLE", "INFEASIBLE", "UNKNOWN")
            assignments: List of assignment dicts with resource_id, demand_id, start, end, duration_hours
            num_requests: Total number of requests in planning
            num_resources: Total number of resources in planning
            num_violations: Number of soft constraint violations
            solve_time_seconds: Time taken to solve
            metadata: Optional additional metadata
            fetch_rt: If True, FE must fetch RT blocks from external DB (solver did not replan RT).
                     If False, RT allocations are in planner_assignments with assignment_type=RT.
            fetch_ct: Same semantics as fetch_rt, but for CT blocks.

        Returns:
            API response dict
        """
        payload = {
            "plan_id": plan_id,
            "status": status,
            "assignments": assignments,
            "num_requests": num_requests,
            "num_resources": num_resources,
            "num_violations": num_violations,
            "solve_time_seconds": solve_time_seconds,
            "user_id": self.user_id,
            "env": self.env.value,
            "fetch_rt": bool(fetch_rt),
            "fetch_ct": bool(fetch_ct),
        }
        if job_id:
            payload["job_id"] = job_id
        if metadata:
            payload["metadata"] = metadata

        response = self.client.post(
            f"{self.base_url}/planner-output/",
            json=payload
        )
        response.raise_for_status()
        return response.json()

    def post_planner_assignments_bulk(self, plan_id: str, job_id: str, assignments: List[Dict]) -> Dict:
        """
        Bulk insert normalized assignments to planner_assignments table.

        Args:
            plan_id: The plan ID
            job_id: The solver job ID
            assignments: List of assignment dicts. Each dict may contain:
                - request_id: str or None (None for CT/RT rest-day allocations)
                - bsa_id, resource_id, resource_name, resource_category
                - team_id, team_name, group_id, group_name
                - calendar_start, calendar_end, duration_hours
                - is_night_shift: bool
                - assignment_type: "DEMAND" (default) | "CT" | "RT"

        Returns:
            API response dict with inserted count
        """
        payload = {
            "plan_id": plan_id,
            "job_id": job_id,
            "assignments": assignments,
        }
        response = self.client.post(
            f"{self.base_url}/planner-output/assignments/bulk",
            json=payload
        )
        response.raise_for_status()
        return response.json()

    def post_planner_uncovered_demands_bulk(self, plan_id: str, job_id: str, uncovered_demands: List[Dict]) -> Dict:
        """
        Bulk insert uncovered demands to planner_uncovered_demands table.

        Args:
            plan_id: The plan ID
            job_id: The solver job ID
            uncovered_demands: List of uncovered demand dicts

        Returns:
            API response dict with inserted count
        """
        payload = {
            "plan_id": plan_id,
            "job_id": job_id,
            "uncovered_demands": uncovered_demands,
        }
        response = self.client.post(
            f"{self.base_url}/planner-output/uncovered-demands/bulk",
            json=payload
        )
        response.raise_for_status()
        return response.json()

    def get_planner_output(self, plan_id: str) -> Dict:
        """
        GET planner output by plan_id.
        
        Args:
            plan_id: The plan ID to retrieve
        
        Returns:
            Planner output record
        """
        response = self.client.get(
            f"{self.base_url}/planner-output/",
            params={"plan_id": plan_id}
        )
        response.raise_for_status()
        return response.json()

# Singleton instance for convenience
# Singleton instance for convenience
_client_instance = None
_client_env = None
_client_user_id = None

def get_client(env: Environment = None, user_id: Optional[str] = None) -> CFFApiClient:
    """Get or create API client for specified environment"""
    global _client_instance, _client_env, _client_user_id
    
    # Create new client if env/user_id changed or no instance
    if (_client_instance is None or 
        _client_env != env or 
        _client_user_id != user_id):
        _client_instance = CFFApiClient(env=env, user_id=user_id)
        _client_env = env
        _client_user_id = user_id
    
    return _client_instance
