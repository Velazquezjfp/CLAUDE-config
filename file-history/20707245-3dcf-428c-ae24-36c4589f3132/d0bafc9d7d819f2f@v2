# CFF Workforce Planning Solver - QA Environment
# Usage: docker-compose -f docker-compose.qa.yml up

name: cff-solver-qa

version: '3.8'

services:
  solver-api:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: cff-solver-qa
    ports:
      - "8005:8004"
    environment:
      - SOLVER_ENV=qa
      # Connect to QA backend container by name (on same network)
      - BACKEND_HOST=cff_api_qa
      - BACKEND_PORT=8000  # Internal container port
      - BACKEND_PORT_QA=8000
      - PYTHONUNBUFFERED=1
      # Optional: Force WSS if nginx doesn't set X-Forwarded-Proto header
      # - FORCE_HTTPS_WEBSOCKET=true
    volumes:
      # Mount output directory for results
      - ./output:/app/output
    networks:
      - cff_network_qa  # Use the QA backend's existing network
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 12G
        reservations:
          memory: 6G
    healthcheck:
      test: ["CMD", "python", "-c", "import httpx; httpx.get('http://localhost:8004/health')"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s

networks:
  cff_network_qa:
    external: true  # Connect to existing QA network from database_application_v2
