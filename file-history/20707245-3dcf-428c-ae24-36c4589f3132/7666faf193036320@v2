-- Fix #16 companion (2026-04-23) — surface fetch_rt / fetch_ct on planner_output
-- for existing deployments. Mirrors the columns already seeded by
-- schema_planner_output.sql on fresh installs; this standalone ADD COLUMN
-- file exists so deploy.sh preserve-mode can apply it on existing postgres
-- volumes (docker-entrypoint-initdb.d only runs on empty volumes).
--
-- Idempotent via IF NOT EXISTS. Safe to re-run.

ALTER TABLE planner_output
    ADD COLUMN IF NOT EXISTS fetch_rt BOOLEAN NOT NULL DEFAULT TRUE,
    ADD COLUMN IF NOT EXISTS fetch_ct BOOLEAN NOT NULL DEFAULT TRUE;

COMMENT ON COLUMN planner_output.fetch_rt IS
    'If TRUE, FE must fetch RT blocks from external DB (solver did not replan RT). '
    'If FALSE, RT allocations are in planner_assignments with assignment_type=RT.';

COMMENT ON COLUMN planner_output.fetch_ct IS
    'If TRUE, FE must fetch CT blocks from external DB (solver did not replan CT). '
    'If FALSE, CT allocations are in planner_assignments with assignment_type=CT.';
