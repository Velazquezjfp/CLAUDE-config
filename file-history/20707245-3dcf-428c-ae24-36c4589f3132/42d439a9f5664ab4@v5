class WorkforcePlanningModel:
    """Main model for workforce planning optimization"""

    def __init__(self, preprocessed_data, constraint_values, objective_weights=None,
                 period_context=None, incoming_state=None):
        """
        Initialize the model with preprocessed data

        Args:
            preprocessed_data: PreprocessedData object
            constraint_values: ConstraintValues object
            objective_weights: ObjectiveWeights object (from preprocessing/objectives.py)
            period_context: Optional dict for OC-01 time-frame sensitive constraint
                          (from partitioner.create_period_context_for_partition)
            incoming_state: Optional PartitionState for constraint carryover
        """
        self.data = preprocessed_data
        self.constraints = constraint_values
        self.objective_weights = objective_weights
        self.period_context = period_context
        self.incoming_state = incoming_state
        self.model = cp_model.CpModel()

        # Decision variables
        self.x = {}  # Assignment variables: {(resource_id, request_id): BoolVar}

        # Violation variables (for soft constraints)
        self.violations = []              # ALL violations (backward compat with _extract_solution)
        self.legal_violations = []        # From LC_* and HC_* constraints
        self.policy_violations = []       # From CP_* and OC_* constraints
        self.violation_metadata = []      # Metadata for analysis

        # Objective variables (workload balancing, etc.)
        self.objective_vars = []

        # Solution
        self.solver = cp_model.CpSolver()
        self.status = None
        self.solution_assignments = []

        # LC-06 rest-day allocation state (populated only when activated)
        self.rt_vars = {}                     # {(resource_id, date): BoolVar}
        self.ct_vars = {}                     # {(resource_id, date): BoolVar}
        self.lc_06_anchor_map = {}            # {(resource_id, date): anchor_start datetime}
        self.lc_05_free_weekend_vars = {}     # populated by LC-05 (Phase F)

    def build_model(self):
        """Build the complete CP-SAT model"""
        print("\n" + "="*60)
        print("BUILDING CP-SAT MODEL")
        print("="*60)

        # Step 1: Create decision variables
        self._create_variables()

        # Step 2: Add coverage constraints (each request must be covered)
        self._add_coverage_constraints()

        # Step 3: Add enabled constraints
        self._add_constraint_modules()

        # Step 4: Add enabled objectives
        self._add_objectives()

        # Step 5: Create objective function
        self._create_objective()

        print("="*60)
        print("MODEL BUILD COMPLETE")
        print("="*60 + "\n")

    def _create_variables(self):
        """Create assignment decision variables"""
        print("\n[VARIABLES] Creating decision variables...")

        for resource_id in self.data.resource_ids:
            for request_id in self.data.request_ids:
                var_name = f'x_{resource_id}_{request_id}'
                self.x[(resource_id, request_id)] = self.model.NewBoolVar(var_name)

        print(f"  Created {len(self.x)} assignment variables")
        print(f"  ({len(self.data.resource_ids)} resources × {len(self.data.request_ids)} requests)")

    def _add_coverage_constraints(self):
        """Ensure each request is assigned to at most one resource"""
        print("\n[COVERAGE] Adding coverage constraints...")

        # Track which requests are covered (for maximize coverage objective)
        self.coverage_vars = {}

        for request_id in self.data.request_ids:
            # Each request can be assigned to AT MOST one resource (allows partial coverage)
            assignments = [
                self.x[(resource_id, request_id)]
                for resource_id in self.data.resource_ids
            ]
            self.model.Add(sum(assignments) <= 1)

            # Create coverage tracking variable for objective
            is_covered = self.model.NewBoolVar(f'covered_{request_id}')
            self.model.Add(sum(assignments) == is_covered)
            self.coverage_vars[request_id] = is_covered

        print(f"  Mode: AT MOST ONE resource per request (partial coverage allowed)")
        print(f"  Added {len(self.data.request_ids)} coverage constraints")
        print(f"  Created {len(self.coverage_vars)} coverage tracking variables")

    def _add_constraint_modules(self):
        """Add all enabled constraint modules"""
        print("\n[CONSTRAINTS] Adding constraint modules...")

        # === HARD CONSTRAINTS (HC_*) — pure hard, return empty violation lists ===

        # HC_01: Absence Blocking (Layer 0 - processed FIRST)
        if "HC_01_absence_blocking" in ENABLED_CONSTRAINTS:
            viols, metadata = add_absence_blocking_constraints(
                self.model, self.x, self.data, self.constraints
            )
            self.violations.extend(viols)
            self.violation_metadata.extend(metadata)

        # HC_01: Contract Type Matching (Layer 0 - processed alongside absence blocking)
        if "HC_01_contract_type" in ENABLED_CONSTRAINTS:
            viols, metadata = add_contract_type_constraints(
                self.model, self.x, self.data, self.constraints
            )
            self.violations.extend(viols)
            self.violation_metadata.extend(metadata)

        # HC_IR_ER: IR/ER Project Assignment (Layer 0 - processed alongside absence blocking)
        if "HC_IR_ER_matching" in ENABLED_CONSTRAINTS:
            viols, metadata = add_ir_er_constraints(
                self.model, self.x, self.data, self.constraints
            )
            self.violations.extend(viols)
            self.violation_metadata.extend(metadata)

        # HC_04: Locked Planning (Layer 0 - processed alongside absence blocking)
        if "HC_04_locked_planning" in ENABLED_CONSTRAINTS:
            viols, metadata = add_locked_planning_constraints(
                self.model, self.x, self.data, self.constraints
            )
            self.violations.extend(viols)
            self.violation_metadata.extend(metadata)

        # HC_05: Function Doubling (Layer 0 - multi-category demands)
        if "HC_05_function_doubling" in ENABLED_CONSTRAINTS:
            viols, metadata = add_function_doubling_constraints(
                self.model, self.x, self.data, self.constraints
            )
            self.violations.extend(viols)
            self.violation_metadata.extend(metadata)

        # === LEGAL CONSTRAINTS (LC_*) ===
        # NOTE: Legal limits are ALWAYS hard constraints (model.Add).
        # The violation variables from LC_01/02/03 track the COMPANY policy
        # limits (stricter than legal) — these are policy_violations, not legal.
        # LC_04 through LC_08 return empty violation lists (pure hard).

        # LC_01/02/03: Two-tier — hard legal + soft company policy
        if "LC_01_max_weekly_hours" in ENABLED_CONSTRAINTS:
            viols, metadata = add_weekly_hours_constraints(
                self.model, self.x, self.data, self.constraints
            )
            self.violations.extend(viols)
            self.policy_violations.extend(viols)  # Company limit, not legal
            self.violation_metadata.extend(metadata)

        if "LC_01_max_weekly_hours_v2" in ENABLED_CONSTRAINTS:
            viols, metadata = add_weekly_hours_constraints_v2(
                self.model, self.x, self.data, self.constraints,
                incoming_state=self.incoming_state
            )
            self.violations.extend(viols)
            self.policy_violations.extend(viols)  # Company limit, not legal
            self.violation_metadata.extend(metadata)

        if "LC_02_max_daily_hours_14h_span" in ENABLED_CONSTRAINTS:
            viols, metadata = add_14h_span_constraints(
                self.model, self.x, self.data, self.constraints
            )
            self.violations.extend(viols)
            self.policy_violations.extend(viols)  # Company limit, not legal
            self.violation_metadata.extend(metadata)

        if "LC_02_max_daily_hours_14h_span_v2" in ENABLED_CONSTRAINTS:
            viols, metadata = add_14h_span_constraints_v2(
                self.model, self.x, self.data, self.constraints
            )
            self.violations.extend(viols)
            self.policy_violations.extend(viols)  # Company limit, not legal
            self.violation_metadata.extend(metadata)

        if "LC_03_max_absolute_daily_hours" in ENABLED_CONSTRAINTS:
            viols, metadata = add_absolute_daily_constraints(
                self.model, self.x, self.data, self.constraints
            )
            self.violations.extend(viols)
            self.policy_violations.extend(viols)  # Company limit, not legal

        # LC_04 through LC_08: Pure hard constraints (return empty violation lists)
        if "LC_04_min_rest_between_shifts" in ENABLED_CONSTRAINTS:
            viols, metadata = add_min_rest_constraints(
                self.model, self.x, self.data, self.constraints,
                incoming_state=self.incoming_state
            )
            self.violations.extend(viols)
            self.violation_metadata.extend(metadata)

        if "LC_04_max_continuous_work" in ENABLED_CONSTRAINTS:
            viols, metadata = add_continuous_work_constraints(
                self.model, self.x, self.data, self.constraints
            )
            self.violations.extend(viols)
            self.violation_metadata.extend(metadata)

        if "LC_05_weekend_frequency" in ENABLED_CONSTRAINTS:
            viols, metadata, free_weekend_vars_dict = add_weekend_frequency_constraints(
                self.model, self.x, self.data, self.constraints
            )
            self.violations.extend(viols)
            self.violation_metadata.extend(metadata)
            # Stash for LC-06 coupling (Phase G wires this into add_rest_days_constraints)
            self.lc_05_free_weekend_vars = free_weekend_vars_dict

        if "LC_06_consecutive_nights" in ENABLED_CONSTRAINTS:
            viols, metadata = add_consecutive_nights_constraints(
                self.model, self.x, self.data, self.constraints
            )
            self.violations.extend(viols)
            self.violation_metadata.extend(metadata)

        # LC_06_v2: Optimized consecutive nights (counter-based O(R×D))
        if "LC_06_consecutive_nights_v2" in ENABLED_CONSTRAINTS:
            viols, metadata = add_consecutive_nights_v2(
                self.model, self.x, self.data, self.constraints,
                incoming_state=self.incoming_state
            )
            self.violations.extend(viols)
            self.violation_metadata.extend(metadata)

        if "LC_07_monthly_nights" in ENABLED_CONSTRAINTS:
            viols, metadata = add_monthly_night_limit_constraints(
                self.model, self.x, self.data, self.constraints
            )
            self.violations.extend(viols)
            self.violation_metadata.extend(metadata)

        # LC_07_v2: Optimized monthly nights (cumulative sum O(R×D))
        if "LC_07_monthly_nights_v2" in ENABLED_CONSTRAINTS:
            viols, metadata = add_monthly_night_limit_v2(
                self.model, self.x, self.data, self.constraints,
                incoming_state=self.incoming_state
            )
            self.violations.extend(viols)
            self.violation_metadata.extend(metadata)

        # LC_08: Minimum Rest Days per Month (Layer 1 - legal constraint)
        if "LC_08_monthly_rest" in ENABLED_CONSTRAINTS:
            viols, metadata = add_monthly_rest_constraints(
                self.model, self.x, self.data, self.constraints
            )
            self.violations.extend(viols)
            self.violation_metadata.extend(metadata)

        # LC_08_v2: Optimized monthly rest (pre-grouped O(R×M×D))
        # GATED BY LC-06 (Phase K): when rt_replannable or ct_replannable, LC-06
        # enforces a stricter, anchor-based rest-day rule that supersedes LC-08
        # v2's midnight-bound calendar-day approach. In that case LC-08 v2 is
        # skipped to avoid double-constraining the same set of days (LC-06's
        # "combined_required" target already satisfies LC-08 v2's ≥6-rest-days
        # bound). When neither flag is set, LC-08 v2 remains as the safety net.
        if "LC_08_monthly_rest_v2" in ENABLED_CONSTRAINTS:
            lc06_active = (
                "LC_06_rest_days_allocation" in ENABLED_CONSTRAINTS
                and (getattr(self.data, 'rt_replannable', False)
                     or getattr(self.data, 'ct_replannable', False))
            )
            if lc06_active:
                print("  [LC_08_monthly_rest_v2] SKIPPED — LC-06 rest-days allocation active (supersedes)")
            else:
                viols, metadata = add_monthly_rest_v2(
                    self.model, self.x, self.data, self.constraints
                )
                self.violations.extend(viols)
                self.violation_metadata.extend(metadata)

        # LC_06 — Rest Days Allocation (RT / CT hard constraint).
        # Gated by per-run rt/ct_replannable flags set in service.py from the
        # trigger payload's replannable_demand_type. When neither flag is True
        # the constraint is a no-op (preserves legacy behavior).
        if "LC_06_rest_days_allocation" in ENABLED_CONSTRAINTS:
            rt_replannable = getattr(self.data, 'rt_replannable', False)
            ct_replannable = getattr(self.data, 'ct_replannable', False)
            if rt_replannable or ct_replannable:
                ps = self.data.planning_start
                pe = self.data.planning_end
                planning_start_date = ps.date() if hasattr(ps, 'date') else ps
                planning_end_date = pe.date() if hasattr(pe, 'date') else pe

                rest_targets = compute_rest_targets(
                    planning_start_date, planning_end_date,
                    self.data.resource_ids, self.incoming_state,
                )

                prior_free_weekends = None
                if self.incoming_state is not None:
                    rstates = getattr(self.incoming_state, 'resource_states', {}) or {}
                    prior_free_weekends = {
                        rid: getattr(rs, 'free_weekend_by_month', {}) or {}
                        for rid, rs in rstates.items()
                        if getattr(rs, 'free_weekend_by_month', None)
                    }

                rt_vars, ct_vars, viols, metadata = add_rest_days_constraints(
                    self.model, self.x, self.data, self.constraints,
                    rest_targets,
                    lc_05_free_weekend_vars=self.lc_05_free_weekend_vars,
                    prior_free_weekends=prior_free_weekends,
                    rt_replannable=rt_replannable,
                    ct_replannable=ct_replannable,
                    incoming_state=self.incoming_state,
                )
                self.rt_vars = rt_vars
                self.ct_vars = ct_vars
                self.lc_06_anchor_map = getattr(self.model, 'lc_06_anchor_map', {}) or {}
                self.violations.extend(viols)
                self.violation_metadata.extend(metadata)
            else:
                print("  [LC_06_rest_days_allocation] Skipped "
                      "(rt_replannable=False and ct_replannable=False)")

        # === POLICY / OPERATIONAL CONSTRAINTS (CP_*, OC_*) → policy_violations ===

        if "CP_02_qualification_matching" in ENABLED_CONSTRAINTS:
            viols, metadata = add_qualification_matching_constraints(
                self.model, self.x, self.data, self.constraints
            )
            self.violations.extend(viols)
            self.policy_violations.extend(viols)
            self.violation_metadata.extend(metadata)

        # CP_02: External Resource Percentage (Company Policy - soft)
        if "CP_02_external_percentage" in ENABLED_CONSTRAINTS:
            viols, metadata = add_external_percentage_constraints(
                self.model, self.x, self.data, self.constraints
            )
            self.violations.extend(viols)
            self.policy_violations.extend(viols)
            self.violation_metadata.extend(metadata)

        # OC_01: Minimum Category Activity (TIME-FRAME SENSITIVE - Layer 2 operational)
        # Encourages resources to meet minimum activity in their categories
        # Uses period_context for partitioned solving (prorating + prior activity)
        if "OC_01_min_category_activity" in ENABLED_CONSTRAINTS:
            # Create PeriodContext from partitioner data if available
            oc01_period_context = None
            if self.period_context:
                from constraints.oc_01_min_category_activity import PeriodContext
                oc01_period_context = PeriodContext(
                    period_start=self.period_context['period_start'],
                    period_end=self.period_context['period_end'],
                    annual_fraction=self.period_context.get('annual_fraction'),
                    prior_activity=self.period_context.get('prior_activity', {})
                )
            viols, metadata = add_min_category_activity_constraints(
                self.model, self.x, self.data, self.constraints,
                period_context=oc01_period_context
            )
            self.violations.extend(viols)
            self.policy_violations.extend(viols)
            self.violation_metadata.extend(metadata)

        print(f"\n  Total soft violations tracked: {len(self.violations)}")
        print(f"    Legal violations: {len(self.legal_violations)}")
        print(f"    Policy violations: {len(self.policy_violations)}")

    def _add_objectives(self):
        """
        Add all objective functions.

        Objectives are ALWAYS ACTIVE - weights control their impact.
        Weights come from backend database via ObjectiveWeights.

        Active objectives (8):
        - maximize_coverage (quality)
        - balance_workload (balance)
        - minimize_legal_violations (compliance) — applied in _create_objective
        - minimize_policy_violations (compliance) — applied in _create_objective
        - minimize_idle_time (efficiency)
        - maximize_team_continuity (quality)
        - maintain_function_continuity (quality)
        - maintain_shift_continuity (quality)
        + group_continuity (quality, toggleable)

        DISABLED v3 (hardcoded values):
        - minimize_overtime_cost, minimize_total_cost, minimize_travel_cost,
          main_competencies_priority
        """
        print("\n[OBJECTIVES] Adding objective modules...")

        # Get weights (use defaults if not provided)
        weights = {}
        if self.objective_weights:
            weights = self.objective_weights.get_all_weights()
        else:
            # Fallback defaults for active objectives
            weights = {
                'maximize_coverage': 3.0,
                'balance_workload': 1.5,
                'minimize_policy_violations': 5.0,
                'minimize_idle_time': 1.0,
                'maximize_team_continuity': 2.0,
            }
            # Merge config-based fallbacks for objectives not yet in DB
            weights.update(OBJECTIVE_FALLBACK_DEFAULTS)
            print("  [WARNING] No objective weights provided, using defaults")

        # 1. maximize_coverage (quality objective)
        coverage_weight = weights.get('maximize_coverage', 3.0)
        if coverage_weight > 0:
            obj_vars = add_maximize_coverage_objective(
                self.model, self.coverage_vars, self.data, coverage_weight
            )
            self.objective_vars.extend(obj_vars)

        # 2. balance_workload (balance objective)
        workload_weight = weights.get('balance_workload', 1.5)
        if workload_weight > 0:
            obj_vars = add_workload_balance_objective(
                self.model, self.x, self.data, workload_weight
            )
            self.objective_vars.extend(obj_vars)

        # DISABLED v3: minimize_legal_violations — no effect in practice.
        # All legal limits (LC_*) use hard model.Add constraints that CANNOT be violated.
        # self.legal_violations is always empty. Keeping the DB entry for UI completeness
        # but the weight has zero impact on the solver.
        # See planner_dev/objectives_changelog_v3.md

        # 4. minimize_policy_violations (compliance objective)
        # Applied separately in _create_objective via self.policy_violations
        policy_weight = weights.get('minimize_policy_violations', 5.0)
        if policy_weight > 0:
            print(f"\n[MINIMIZE POLICY VIOLATIONS] Weight: {policy_weight} (applied in _create_objective)")

        # DISABLED v3: hardcoded values — see planner_dev/objectives_changelog_v3.md
        # 5. minimize_overtime_cost — DISABLED (hardcoded 41h/week target)
        # 6. minimize_total_cost — DISABLED (hardcoded internal/external multipliers)
        # 7. minimize_travel_cost — DISABLED (hardcoded travel cost matrix)

        # 8. minimize_idle_time (efficiency objective)
        idle_weight = weights.get('minimize_idle_time', 1.0)
        if idle_weight > 0:
            obj_vars = add_minimize_idle_time_objective(
                self.model, self.x, self.data, idle_weight
            )
            self.objective_vars.extend(obj_vars)

        # 9. maximize_team_continuity (quality objective)
        continuity_weight = weights.get('maximize_team_continuity', 2.0)
        if continuity_weight > 0:
            obj_vars = add_maximize_team_continuity_objective(
                self.model, self.x, self.data, continuity_weight
            )
            self.objective_vars.extend(obj_vars)

        # 10. maintain_function_continuity (quality objective - OBJ-02)
        # Not yet in DB — uses OBJECTIVE_FALLBACK_DEFAULTS from config.py
        function_continuity_weight = weights.get('maintain_function_continuity', OBJECTIVE_FALLBACK_DEFAULTS.get('maintain_function_continuity', 1.0))
        if function_continuity_weight > 0:
            obj_vars = add_function_continuity_objective(
                self.model, self.x, self.data, function_continuity_weight
            )
            self.objective_vars.extend(obj_vars)

        # 11. maintain_shift_continuity (quality objective - OBJ-03)
        # Not yet in DB — uses OBJECTIVE_FALLBACK_DEFAULTS from config.py
        shift_continuity_weight = weights.get('maintain_shift_continuity', OBJECTIVE_FALLBACK_DEFAULTS.get('maintain_shift_continuity', 1.5))
        if shift_continuity_weight > 0:
            obj_vars = add_shift_continuity_objective(
                self.model, self.x, self.data, shift_continuity_weight
            )
            self.objective_vars.extend(obj_vars)

        # DISABLED v3: hardcoded values — see planner_dev/objectives_changelog_v3.md
        # 12. main_competencies_priority — DISABLED (hardcoded category priority scores)

        # 13. group_continuity (quality objective - OBJ-07) - TOGGLEABLE
        # Not yet in DB — uses OBJECTIVE_FALLBACK_DEFAULTS from config.py
        group_continuity_weight = weights.get('group_continuity', OBJECTIVE_FALLBACK_DEFAULTS.get('group_continuity', 0.5))
        group_matching_enabled = is_group_matching_enabled(self.constraints)
        if group_continuity_weight > 0 and group_matching_enabled:
            obj_vars = add_group_continuity_objective(
                self.model, self.x, self.data, group_continuity_weight, enabled=True
            )
            self.objective_vars.extend(obj_vars)

        # 14. category_priority (quality objective - OBJ-08)
        # Prefer assigning resources to their primary (highest-priority) category
        category_priority_weight = weights.get('category_priority', OBJECTIVE_FALLBACK_DEFAULTS.get('category_priority', 1.5))
        if category_priority_weight > 0:
            obj_vars = add_category_priority_objective(
                self.model, self.x, self.data, category_priority_weight
            )
            self.objective_vars.extend(obj_vars)

        # 15. bsa_category_consistency (quality objective - OBJ-09)
        # Keep same resource in same category on same construction site (BSA-ID)
        bsa_consistency_weight = weights.get('bsa_category_consistency', OBJECTIVE_FALLBACK_DEFAULTS.get('bsa_category_consistency', 2.0))
        if bsa_consistency_weight > 0:
            obj_vars = add_bsa_category_consistency_objective(
                self.model, self.x, self.data, bsa_consistency_weight,
                incoming_state=self.incoming_state
            )
            self.objective_vars.extend(obj_vars)

        print(f"\n  Total objective variables tracked: {len(self.objective_vars)}")

    def _create_objective(self):
        """
        Create objective function.

        Note: Objective variables already include their weights from _add_objectives().
        Here we combine violations and objective terms.
        """
        print("\n[OBJECTIVE] Creating objective function...")

        objective_terms = []

        # 1. Minimize violations (if using soft constraints)
        # Legal limits are ALWAYS hard (model.Add) — can NEVER be violated.
        # self.legal_violations is always empty — minimize_legal_violations disabled.
        # Policy violations track company-level limits (stricter than legal).
        # Sources: LC_01/02/03 company limits, CP_02, OC_01
        if USE_SOFT_CONSTRAINTS:
            # Policy violations (company limits from LC_01/02/03, CP_02, OC_01)
            if self.policy_violations:
                policy_weight = 50
                if self.objective_weights:
                    policy_weight = int(self.objective_weights.get_weight('minimize_policy_violations') * 10)
                for violation in self.policy_violations:
                    objective_terms.append(violation * policy_weight)
                print(f"  Added {len(self.policy_violations)} policy violation terms (weight: {policy_weight})")

        # 2. Add objective terms (already weighted in _add_objectives)
        if self.objective_vars:
            for obj_var in self.objective_vars:
                objective_terms.append(obj_var)
            print(f"  Added {len(self.objective_vars)} objective terms (pre-weighted)")

        # If no objective terms, just minimize any variable (feasibility problem)
        if not objective_terms:
            print("  Feasibility problem (no objective terms)")
            objective_terms = [0]
        else:
            print(f"  Total objective terms: {len(objective_terms)}")

        self.model.Minimize(sum(objective_terms))

    def solve(self, time_limit: int = SOLVER_TIME_LIMIT_SECONDS):
        """
        Solve the model

        Args:
            time_limit: Time limit in seconds

        Returns:
            True if optimal or feasible solution found, False otherwise
        """
        print("\n" + "="*60)
        print("SOLVING MODEL")
        print("="*60)
        print(f"Time limit: {time_limit} seconds")

        # Stall detection
        stall_limit = SOLVER_STALL_LIMIT_SECONDS
        if stall_limit:
            print(f"Stall detection: ENABLED (stop after {stall_limit}s without improvement)")
        else:
            print(f"Stall detection: DISABLED (will run until time limit)")
        print("Searching for solution...\n")

        # Set solver parameters
        self.solver.parameters.max_time_in_seconds = time_limit
        self.solver.parameters.log_search_progress = True
        # Cap parallel workers. OR-Tools auto-detects CPU count and can spawn 32+
        # workers; each clones the presolved model, causing OOM on multi-core hosts.
        # 4 workers is a good balance of search diversity vs memory (each adds ~300MB).
        # Configurable via env var CFF_SOLVER_NUM_WORKERS (default 4).
        import os as _os
        self.solver.parameters.num_workers = int(_os.environ.get('CFF_SOLVER_NUM_WORKERS', '4'))
        print(f"CP-SAT workers: {self.solver.parameters.num_workers} (override via CFF_SOLVER_NUM_WORKERS env var)")

        # Solve with or without stall detection
        if stall_limit:
            callback = StallDetector(stall_limit_seconds=stall_limit)
            self.status = self.solver.Solve(self.model, callback)
            callback.cleanup()
            stats = callback.get_stats()
            first_sol = stats['first_solution_seconds']
            first_sol_str = f"{first_sol:.1f}s" if first_sol else "N/A"
            print(f"\n  Solver stats: {stats['solutions_found']} solutions, "
                  f"first at {first_sol_str}")
        else:
            self.status = self.solver.Solve(self.model)

        # Report results
        print("\n" + "="*60)
        print("SOLVER RESULTS")
        print("="*60)

        if self.status == cp_model.OPTIMAL:
            print("Status: OPTIMAL")
            self._extract_solution()
            return True
        elif self.status == cp_model.FEASIBLE:
            print("Status: FEASIBLE")
            self._extract_solution()
            return True
        elif self.status == cp_model.INFEASIBLE:
            print("Status: INFEASIBLE")
            print("No solution satisfies all constraints!")
            return False
        else:
            print("Status: UNKNOWN")
            return False

    def _extract_solution(self):
        """Extract solution from solver"""
        print("\nSOLUTION FOUND:")
        print("-" * 60)

        total_violations = 0
        if self.violations:
            total_violations = sum(self.solver.Value(v) for v in self.violations)

        print(f"Objective Value: {self.solver.ObjectiveValue()}")
        print(f"Total Violations: {total_violations}")
        print(f"Solve Time: {self.solver.WallTime():.2f} seconds")
        print(f"Branches: {self.solver.NumBranches()}")

        print("\nASSIGNMENTS:")
        print("-" * 60)

        # Build resource lookup for team_id/group_id enrichment
        resource_lookup = {r['resource_id']: r for r in self.data.resources}

        for request_id in self.data.request_ids:
            for resource_id in self.data.resource_ids:
                if self.solver.Value(self.x[(resource_id, request_id)]) == 1:
                    # Find the request details
                    req = next(r for r in self.data.requests if r['id'] == request_id)
                    duration = self.data.task_duration[request_id]
                    res_info = resource_lookup.get(resource_id, {})
                    last_name = res_info.get('last_name', '')
                    first_name = res_info.get('first_name', '')
                    resource_name = f"{last_name} {first_name}".strip()

                    assignment = {
                        'demand_id': request_id,
                        'bsa_id': req.get('bsa_id'),
                        'resource_id': resource_id,
                        'resource_name': resource_name or None,
                        'resource_category': req.get('resource_category'),
                        'team_id': res_info.get('team_id'),
                        'group_id': res_info.get('group_id'),
                        'start': req['shift_start_time'],
                        'end': req['shift_finish_time'],
                        'duration_hours': duration,
                        'is_night_shift': self.data.task_is_night.get(request_id, False),
                        'assignment_type': 'DEMAND',
                    }
                    self.solution_assignments.append(assignment)

                    print(f"  {request_id} → {resource_id}")
                    print(f"    {req['shift_start_time']} to {req['shift_finish_time']} ({duration:.2f}h)")

        # --- LC-06: emit RT / CT rest-day rows (only present when LC-06 ran) ---
        rt_count, ct_count = self._extract_rest_day_rows(resource_lookup)
        if rt_count or ct_count:
            print(f"  LC-06 rest-day rows emitted: RT={rt_count}, CT={ct_count}")

        print("="*60 + "\n")

        # Save solution if configured
        if SAVE_SOLUTION:
            self._save_solution()

    def _extract_rest_day_rows(self, resource_lookup: dict) -> tuple:
        """Append RT and CT rest-day rows to self.solution_assignments.

        For each (resource, day) whose rt[r,d] or ct[r,d] BoolVar was set to 1
        by the solver, emit a synthetic assignment row with:
          - assignment_type = 'RT' or 'CT'
          - request_id = None, bsa_id = None  (no underlying demand)
          - calendar window = [anchor_start, anchor_start + 24h] where
            anchor_start is looked up from self.lc_06_anchor_map (populated by
            LC-06 pre-solve). Falls back to midnight of d if missing.

        Returns (rt_count, ct_count) for logging.
        """
        rt_count = 0
        ct_count = 0
        anchors = self.lc_06_anchor_map or {}

        for label, vars_map, counter_is_rt in (
            ('RT', self.rt_vars, True),
            ('CT', self.ct_vars, False),
        ):
            for (resource_id, d), var in vars_map.items():
                try:
                    if self.solver.Value(var) != 1:
                        continue
                except Exception:
                    continue

                anchor_start = anchors.get((resource_id, d))
                if anchor_start is None:
                    anchor_start = datetime.combine(d, datetime.min.time(), tzinfo=timezone.utc)
                anchor_end = anchor_start + timedelta(hours=24)

                res_info = resource_lookup.get(resource_id, {})
                last_name = res_info.get('last_name', '')
                first_name = res_info.get('first_name', '')
                resource_name = f"{last_name} {first_name}".strip() or None

                self.solution_assignments.append({
                    'demand_id': None,
                    'bsa_id': None,
                    'resource_id': resource_id,
                    'resource_name': resource_name,
                    'resource_category': None,
                    'team_id': res_info.get('team_id'),
                    'group_id': res_info.get('group_id'),
                    'start': anchor_start.isoformat(),
                    'end': anchor_end.isoformat(),
                    'duration_hours': 24.0,
                    'is_night_shift': False,
                    'assignment_type': label,
                })

                if counter_is_rt:
                    rt_count += 1
                else:
                    ct_count += 1

        return rt_count, ct_count

    def _save_solution(self):
        """Save solution to file"""
        import os
        os.makedirs(os.path.dirname(SOLUTION_OUTPUT_PATH), exist_ok=True)

        solution_data = {
            'metadata': {
                'status': 'OPTIMAL' if self.status == cp_model.OPTIMAL else 'FEASIBLE',
                'objective_value': int(self.solver.ObjectiveValue()),
                'solve_time_seconds': self.solver.WallTime(),
                'timestamp': datetime.now().isoformat()
            },
            'assignments': self.solution_assignments,
            'statistics': {
                'num_requests': len(self.data.request_ids),
                'num_resources': len(self.data.resource_ids),
                'num_violations': sum(self.solver.Value(v) for v in self.violations) if self.violations else 0
            }
        }

        try:
            import os
            os.makedirs(os.path.dirname(SOLUTION_OUTPUT_PATH), exist_ok=True)
            with open(SOLUTION_OUTPUT_PATH, 'w') as f:
                json.dump(solution_data, f, indent=2)
            print(f"Solution saved to: {SOLUTION_OUTPUT_PATH}")
        except (PermissionError, OSError) as e:
            print(f"  [WARNING] Could not save solution file ({e}). Results are in the DB.")


def create_and_solve_model(preprocessed_data, constraint_values,
                          objective_weights=None,
                          time_limit: int = SOLVER_TIME_LIMIT_SECONDS,
                          period_context=None,
                          incoming_state=None):
    """
    Convenience function to create and solve the model

    Args:
        preprocessed_data: PreprocessedData object
        constraint_values: ConstraintValues object
        objective_weights: ObjectiveWeights object (optional, from preprocessing/objectives.py)
        time_limit: Solver time limit in seconds
        period_context: Optional dict for OC-01 partitioned solving (from partitioner)
        incoming_state: Optional PartitionState for constraint carryover

    Returns:
        WorkforcePlanningModel with solution (if found)
    """
    model = WorkforcePlanningModel(
        preprocessed_data, constraint_values, objective_weights,
        period_context=period_context, incoming_state=incoming_state
    )
    model.build_model()
    model.solve(time_limit)
    return model
