# SOLVER PERFORMANCE: Stall Detection Callback
# =============================================================================

class StallDetector(cp_model.CpSolverSolutionCallback):
    """
    Stops the solver when no improvement is found for a configurable period.

    Uses a timer thread to handle the case where CP-SAT is in bound-probing
    mode and no new solutions trigger the callback. Every time a new best
    solution is found, the timer resets. If the timer expires, StopSearch()
    is called from the timer thread (thread-safe in CP-SAT).

    Controlled by config.SOLVER_STALL_LIMIT_SECONDS:
      - > 0: Stop after N seconds without improvement
      - 0 or None: Disabled (solver runs until time_limit)
    """

    def __init__(self, stall_limit_seconds=120):
        import threading
        super().__init__()
        self._stall_limit = stall_limit_seconds
        self._start_time = _time.time()
        self._last_improvement_time = None
        self._best_objective = float('inf')
        self._solutions_found = 0
        self._first_solution_time = None
        self._timer = None
        self._threading = threading
        self._stopped = False

    def _reset_timer(self):
        """Reset the stall timer. Called on each improvement."""
        if self._timer:
            self._timer.cancel()
        self._timer = self._threading.Timer(self._stall_limit, self._on_stall_timeout)
        self._timer.daemon = True
        self._timer.start()

    def _on_stall_timeout(self):
        """Called by timer thread when stall limit expires."""
        if self._stopped:
            return
        self._stopped = True
        elapsed = _time.time() - self._start_time
        print(f"\n  [STALL DETECTOR] No improvement for {self._stall_limit}s")
        print(f"  [STALL DETECTOR] Stopping at {elapsed:.1f}s, obj={self._best_objective}, solutions={self._solutions_found}")
        self.StopSearch()

    def on_solution_callback(self):
        self._solutions_found += 1
        current_obj = self.ObjectiveValue()
        now = _time.time()

        if self._first_solution_time is None:
            self._first_solution_time = now - self._start_time
            print(f"\n  [SOLVER] First FEASIBLE at {self._first_solution_time:.1f}s (obj={current_obj})")

        if current_obj < self._best_objective:
            elapsed = now - self._start_time
            self._best_objective = current_obj
            self._last_improvement_time = now
            # Reset the stall timer on each improvement
            self._reset_timer()
            if self._solutions_found % 10 == 0:
                print(f"  [SOLVER] #{self._solutions_found} at {elapsed:.1f}s: obj={current_obj}")

    def cleanup(self):
        """Cancel timer after solve completes."""
        if self._timer:
            self._timer.cancel()

    def get_stats(self):
        return {
            'solutions_found': self._solutions_found,
            'first_solution_seconds': self._first_solution_time,
            'best_objective': self._best_objective if self._best_objective != float('inf') else None,
            'stall_limit_seconds': self._stall_limit,
        }
