-- ============================================================================
-- Planner Assignments & Uncovered Demands Tables
-- Internal DB (cff_planning) - Normalized solver output for FE queries
-- ============================================================================

-- planner_assignments: One row per assignment, queryable/filterable
-- Replaces FE's need to parse the full JSONB blob from planner_output.assignments
CREATE TABLE IF NOT EXISTS planner_assignments (
    id SERIAL PRIMARY KEY,
    plan_id VARCHAR(50) NOT NULL,
    job_id VARCHAR(50),
    request_id VARCHAR(50),  -- NULL allowed for CT/RT rest-day allocations (no underlying demand)
    bsa_id VARCHAR(20),
    resource_id VARCHAR(50) NOT NULL,
    resource_name VARCHAR(200),
    resource_category VARCHAR(100),
    team_id INTEGER,
    team_name VARCHAR(200),
    group_id INTEGER,
    group_name VARCHAR(200),
    calendar_start TIMESTAMP WITH TIME ZONE,
    calendar_end TIMESTAMP WITH TIME ZONE,
    duration_hours DECIMAL(6,2),
    is_night_shift BOOLEAN DEFAULT FALSE,
    assignment_type VARCHAR(20) NOT NULL DEFAULT 'DEMAND',  -- DEMAND | CT | RT
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Idempotent migration for existing deployments
ALTER TABLE planner_assignments
    ALTER COLUMN request_id DROP NOT NULL,
    ADD COLUMN IF NOT EXISTS assignment_type VARCHAR(20) NOT NULL DEFAULT 'DEMAND';

-- Indexes for planner_assignments
CREATE INDEX IF NOT EXISTS idx_pa_plan_id ON planner_assignments(plan_id);
CREATE INDEX IF NOT EXISTS idx_pa_job_id ON planner_assignments(job_id);
CREATE INDEX IF NOT EXISTS idx_pa_resource_id ON planner_assignments(resource_id);
CREATE INDEX IF NOT EXISTS idx_pa_request_id ON planner_assignments(request_id);
CREATE INDEX IF NOT EXISTS idx_pa_bsa_id ON planner_assignments(bsa_id);
CREATE INDEX IF NOT EXISTS idx_pa_team_id ON planner_assignments(team_id);
CREATE INDEX IF NOT EXISTS idx_pa_group_id ON planner_assignments(group_id);
CREATE INDEX IF NOT EXISTS idx_pa_calendar_start ON planner_assignments(calendar_start);
CREATE INDEX IF NOT EXISTS idx_pa_plan_team ON planner_assignments(plan_id, team_id);
CREATE INDEX IF NOT EXISTS idx_pa_assignment_type ON planner_assignments(assignment_type);


-- planner_uncovered_demands: Demands not covered by the solver
-- Correctly filtered by team/group targeting (same logic as coverage rate)
CREATE TABLE IF NOT EXISTS planner_uncovered_demands (
    id SERIAL PRIMARY KEY,
    plan_id VARCHAR(50) NOT NULL,
    job_id VARCHAR(50),
    request_id VARCHAR(50) NOT NULL,
    bsa_id VARCHAR(20),
    resource_category VARCHAR(100),
    start_location VARCHAR(100),
    start_location_code VARCHAR(50),
    end_location VARCHAR(100),
    end_location_code VARCHAR(50),
    calendar_start TIMESTAMP WITH TIME ZONE,
    calendar_end TIMESTAMP WITH TIME ZONE,
    required_qualifications JSONB,
    responsible_person VARCHAR(100),
    people_needed INTEGER DEFAULT 1,
    gap_type VARCHAR(30) NOT NULL,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Indexes for planner_uncovered_demands
CREATE INDEX IF NOT EXISTS idx_pud_plan_id ON planner_uncovered_demands(plan_id);
CREATE INDEX IF NOT EXISTS idx_pud_job_id ON planner_uncovered_demands(job_id);
CREATE INDEX IF NOT EXISTS idx_pud_request_id ON planner_uncovered_demands(request_id);
CREATE INDEX IF NOT EXISTS idx_pud_bsa_id ON planner_uncovered_demands(bsa_id);
CREATE INDEX IF NOT EXISTS idx_pud_gap_type ON planner_uncovered_demands(gap_type);
CREATE INDEX IF NOT EXISTS idx_pud_resource_category ON planner_uncovered_demands(resource_category);
CREATE INDEX IF NOT EXISTS idx_pud_start_location_code ON planner_uncovered_demands(start_location_code);
CREATE INDEX IF NOT EXISTS idx_pud_calendar_start ON planner_uncovered_demands(calendar_start);
