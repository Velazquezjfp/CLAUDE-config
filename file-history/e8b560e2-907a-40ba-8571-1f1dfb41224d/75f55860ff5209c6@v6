@api_router.websocket("/solver/progress/{job_id}")
async def websocket_progress(websocket: WebSocket, job_id: str):
    """
    WebSocket endpoint for real-time progress updates.

    Connect to this endpoint after triggering a job to receive live updates.

    **Message Types:**
    - `progress`: Regular progress update
    - `complete`: Job finished successfully
    - `error`: Job failed
    - `ping`: Keepalive heartbeat (every 30s)

    **Important:** If you disconnect, the solver continues running.
    You can reconnect at any time to resume receiving updates.
    """
    job = job_manager.get_job(job_id)
    if not job:
        await websocket.close(code=4004, reason=f"Job {job_id} not found")
        return

    await websocket.accept()
    job_manager.add_websocket(job_id, websocket)

    logger.info(f"WebSocket connected for job {job_id}")

    async def keepalive_ping():
        """Send periodic pings to keep the connection alive through proxies/firewalls."""
        while True:
            await asyncio.sleep(30)
            try:
                await websocket.send_json({
                    "type": "ping",
                    "timestamp": datetime.now().isoformat()
                })
            except Exception:
                break

    ping_task = asyncio.create_task(keepalive_ping())

    try:
        # Send current state first (for reconnections)
        if job.progress_history:
            for msg in job.progress_history:
                await websocket.send_json(msg.model_dump())

        # Keep connection alive and send updates
        while True:
            # Check if job is complete
            if job.status in [JobStatus.COMPLETE, JobStatus.FAILED, JobStatus.CANCELLED]:
                await asyncio.sleep(0.5)
                # Graceful close with proper code so client knows it's intentional
                close_reason = f"Job {job.status.value}"
                await websocket.close(code=1000, reason=close_reason)
                logger.info(f"WebSocket closed gracefully for job {job_id}: {close_reason}")
                return

            # Wait for updates (the background task will broadcast)
            await asyncio.sleep(0.5)

    except WebSocketDisconnect:
        # Client disconnected - this is OK, solver continues
        logger.info(f"WebSocket disconnected for job {job_id} - solver continues")

    except Exception as e:
        logger.error(f"WebSocket error for job {job_id}: {e}")

    finally:
        ping_task.cancel()
        try:
            await ping_task
        except asyncio.CancelledError:
            pass
        job_manager.remove_websocket(job_id, websocket)


