    )
    return result.to_dict()


@api_router.get("/plans/{plan_id}", tags=["Plans"])
async def get_plan(plan_id: str):
    """
    Get plan details by ID.

    Returns plan summary without full assignment lists.
    Use /api/v1/plans/{plan_id}/assignments for paginated assignments.
    """
    summary = plan_storage_service.get_plan_summary(plan_id)
    if not summary:
        raise HTTPException(status_code=404, detail=f"Plan {plan_id} not found")
    return summary


@api_router.get("/plans/{plan_id}/assignments", tags=["Plans"])
async def get_plan_assignments(
    plan_id: str,
    status: Optional[str] = None,
    page: int = 1,
    limit: int = 50
):
    """
    Get paginated assignments for a plan.

    **Query Parameters:**
    - status: Filter by status (PLANNED, BLOCKED, UNCOVERED, or omit for all)
    - page: Page number (default: 1)
    - limit: Items per page (default: 50, max: 200)

    **Returns:**
    - Paginated list of assignments sorted by start_datetime
    """
    limit = min(limit, 200)  # Cap at 200

    # Validate status filter
    if status and status not in ['PLANNED', 'BLOCKED', 'UNCOVERED']:
        raise HTTPException(
            status_code=400,
            detail=f"Invalid status filter. Use PLANNED, BLOCKED, or UNCOVERED"
        )

    result = plan_storage_service.get_assignments(
        plan_id=plan_id,
        status_filter=status,
        page=page,
        limit=limit
    )

    if result is None:
        raise HTTPException(status_code=404, detail=f"Plan {plan_id} not found")

    return result.to_dict()


@api_router.delete("/plans/{plan_id}", tags=["Plans"])
async def delete_plan(plan_id: str):
    """
    Delete a plan by ID.

    This permanently removes the plan and all its assignments.
    """
    success = plan_storage_service.delete_plan(plan_id)
    if not success:
        raise HTTPException(status_code=404, detail=f"Plan {plan_id} not found")

    return {"status": "deleted", "plan_id": plan_id}


