class TriggerRequest(BaseModel):
    """
    Request body for triggering a solver job.

    ## Example Request
    ```json
    {
      "user_id": "user_123",
      "test_mode": true,
      "test_requests": 100,
      "test_resources": 100,
      "plan_range": {"start_date": "2026-01-01", "end_date": "2026-01-31"},
      "target_team_ids": [1, 2],
      "target_group_ids": [10],
      "lock_allocations": true,
      "locked_date_ranges": [{"start": "2026-01-10", "end": "2026-01-15", "reason": "Sprint freeze"}],
      "replannable_demand_type": ["Service de nuit", "Service du matin"],
      "options": {"time_limit_seconds": 300}
    }
    ```

    ## Behavior Matrix
    ```
    lock_allocations=false                              → no blockers, solver is free to assign everywhere
    lock_allocations=true  + replannable=[]             → ALL assignments in plan_range block
    lock_allocations=true  + replannable=["X","Y"]      → all assignments block EXCEPT types X and Y
    ```
    plan_range (start_date/end_date) is ALWAYS the primary filter.
    FE's replannable_demand_type is the single source of truth — no hardcoded type categories.

    ## Target Filtering
    - `target_team_ids` and `target_group_ids` filter **resources only** (demands are NOT filtered)
    - Empty lists = no filtering (all resources included)

    ## Replannable Calendar Types
    The `replannable_demand_type` parameter controls which existing calendar assignments
    can be overwritten. Types in this list are EXCLUDED from blocking, making those
    resources AVAILABLE for new assignments. Types NOT in this list will BLOCK resources.
    Only active when `lock_allocations=true`.

    ## Active Constraints
    The solver applies the following validated constraints:
    - **CP_02**: Resource-category qualification matching (HARD)
    - **HC_IR_ER**: Apprentices blocked from IR projects (HARD)
    - **HC_05**: Multi-category demands require all categories (HARD)
    - **HC_01**: Block assignments during non-replannable calendar entries (HARD)
    - **LC_01**: Max 48h/week (legal), 45h (company) (SOFT)
    - **LC_02**: Max 9h in any 14h window (SOFT)
    - **LC_03**: Max 12h per calendar day (SOFT)
    - **LC_04**: Min 12h rest between shifts (HARD)
    """
    # Identity
    user_id: str = Field(default="user_000", description="User ID for audit trail and result ownership")

    # Mode
    test_mode: bool = Field(default=True, description="Enable test mode - slices dataset to test_requests/test_resources after plan_range filter")
    test_requests: int = Field(default=50, ge=1, le=1000, description="Number of demands when test_mode=true (smart strided sampling)")
    test_resources: int = Field(default=50, ge=1, le=500, description="Number of resources when test_mode=true (smart strided sampling)")
    use_mock_data: bool = Field(default=False, description="Use locally generated mock data (no backend calls) - for offline testing only")

    # Scope: what to plan
    plan_range: Optional[PlanRange] = Field(None, description="Date range filter - demands are filtered by shift_start_time before test_mode slicing")
    target_team_ids: List[int] = Field(default_factory=list, description="Filter resources by team IDs (resources only, demands not filtered)")
    target_group_ids: List[int] = Field(default_factory=list, description="Filter resources by group IDs (resources only, demands not filtered)")

    # Locking: what to preserve
    lock_allocations: bool = Field(default=True, description="Master switch: lock existing service assignments in plan_range")
    locked_date_ranges: List[LockedDateRange] = Field(default_factory=list, description="When lock_allocations=true, only lock assignments overlapping these ranges. Empty = lock all in plan_range.")
    replannable_demand_type: List[str] = Field(
        default_factory=list,
        description="Calendar types that CAN be re-planned (excluded from blocking). Only active when lock_allocations=true."
    )

    # DISABLED V1 (kept for schema compatibility, skipped in logic)
    blocked_teams: List[int] = Field(default_factory=list, description="[DISABLED V1] Use target_team_ids instead. Ignored in logic.")
    blocked_locations: List[int] = Field(default_factory=list, description="[DISABLED V1] Ignored in logic.")
    blocked_date_ranges: List[LockedDateRange] = Field(default_factory=list, description="[DEPRECATED] Use locked_date_ranges instead. Ignored in logic.")

    options: SolverOptions = Field(default_factory=SolverOptions, description="Solver execution options (time limits, etc.)")

    @validator('blocked_teams', 'blocked_locations', 'target_team_ids', 'target_group_ids', pre=True, each_item=True)
    def coerce_to_int(cls, v):
        """Coerce string integers to int (e.g., '1' -> 1)"""
        if v is None:
            return v
        return int(v)


