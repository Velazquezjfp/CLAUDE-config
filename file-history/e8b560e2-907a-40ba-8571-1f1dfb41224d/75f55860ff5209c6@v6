async def run_solver_job(job: SolverJob):
    """Semaphore wrapper: queues job until a solver slot is available."""
    try:
        logger.info(f"Job {job.job_id}: waiting for solver slot (queue position: {job_manager.get_queue_position(job.job_id)})...")
        async with job_manager._solver_semaphore:
            logger.info(f"Job {job.job_id}: acquired solver slot, starting execution")
            await _execute_solver_job(job)
    except Exception as e:
        if job.status not in (JobStatus.COMPLETE, JobStatus.FAILED, JobStatus.CANCELLED):
            logger.error(f"Job {job.job_id}: semaphore wrapper caught error: {e}")
            job.status = JobStatus.FAILED
            job.error = str(e)
            job.end_time = datetime.now()
            await send_webhook(job, "FAILED", 0.0, error_message=str(e))


def _fetch_and_preprocess_sync(job: SolverJob):
    """
    Synchronous helper: fetch all data, filter, fetch constraints/objectives, preprocess.
    Runs in thread pool via run_in_executor to keep the event loop free.
    Returns (client, requests_data, resources_data, absences_data,
             preprocessed_data, constraint_values, objective_weights).
    """
    import sys
    import os

    solver_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    if solver_dir not in sys.path:
        sys.path.insert(0, solver_dir)

    from api.client import get_client
    from api.data_pipeline import (
        filter_resources_by_teams, filter_resources_by_groups,
        build_locked_assignments
    )
    from preprocessing.constraints import fetch_constraint_values
    from preprocessing.objectives import fetch_objective_weights
    from preprocessing.data_processor import preprocess_data
    from config import CURRENT_ENV

    # Create client
    client = get_client(env=CURRENT_ENV, user_id=job.request.user_id)

    # Deprecation warnings for V1 disabled fields
    if job.request.blocked_teams or job.request.blocked_locations:
        logger.warning("blocked_teams/blocked_locations DISABLED V1 - use target_team_ids/target_group_ids instead. Values ignored.")
    if job.request.blocked_date_ranges:
        logger.warning("blocked_date_ranges DEPRECATED - use locked_date_ranges instead. Values ignored.")

    rt_replannable = False
    ct_replannable = False

    if job.request.use_mock_data:
        from agentic_integration.tests.mock_data import (
            generate_mock_resources, generate_mock_demands, generate_mock_absences
        )
        resources_data = generate_mock_resources(job.request.test_resources)
        requests_data = generate_mock_demands(job.request.test_requests)
        resource_ids = [r['resource_id'] for r in resources_data['data']]
        absences_data = generate_mock_absences(resource_ids, absence_rate=0.2)
    else:
        # --- 4A. Parse plan_range ---
        start_date = None
        end_date = None
        if job.request.plan_range and not job.request.plan_range.is_empty():
            start_date = job.request.plan_range.start_date
            end_date = job.request.plan_range.end_date
            if start_date and 'T' in start_date:
                start_date = start_date.split('T')[0]
            if end_date and 'T' in end_date:
                end_date = end_date.split('T')[0]
            logger.info(f"Plan range: {start_date} to {end_date}")
        else:
            logger.info("No plan_range specified - fetching all demands")

        # --- 4A. Fetch demands ---
        requests_data = client.get_demands(start_date=start_date, end_date=end_date)

        # --- 4B. Fetch resources (filtered by target teams/groups) ---
        target_teams = set(job.request.target_team_ids)
        target_groups = set(job.request.target_group_ids)

        resources_data = client.get_resources(
            team_id=list(target_teams)[0] if len(target_teams) == 1 else None,
            group_id=list(target_groups)[0] if len(target_groups) == 1 else None
        )
        if len(target_teams) > 1:
            resources_data['data'] = filter_resources_by_teams(resources_data['data'], target_teams)
            resources_data['total'] = len(resources_data['data'])
            logger.info(f"Client-side team filter: {len(resources_data['data'])} resources for teams {target_teams}")
        elif len(target_teams) == 1:
            logger.info(f"Server-side team filter: {len(resources_data['data'])} resources for team {target_teams}")
        if len(target_groups) > 1:
            resources_data['data'] = filter_resources_by_groups(resources_data['data'], target_groups)
            resources_data['total'] = len(resources_data['data'])
            logger.info(f"Client-side group filter: {len(resources_data['data'])} resources for groups {target_groups}")
        elif len(target_groups) == 1:
            logger.info(f"Server-side group filter: {len(resources_data['data'])} resources for group {target_groups}")

        # Log resource breakdown
        if resources_data['data']:
            res_by_cat = {}
            res_by_group = {}
            for r in resources_data['data']:
                for cat in (r.get('resource_categories') or []):
                    res_by_cat[cat] = res_by_cat.get(cat, 0) + 1
                gname = r.get('group_name', 'UNKNOWN')
                res_by_group[gname] = res_by_group.get(gname, 0) + 1
            logger.info(f"Resource categories: {dict(sorted(res_by_cat.items(), key=lambda x: -x[1]))}")
            logger.info(f"Resources by group: {dict(sorted(res_by_group.items(), key=lambda x: -x[1]))}")

        # --- 4B-bis. Category pre-filter ---
        resource_categories = {
            cat
            for r in resources_data['data']
            for cat in (r.get('resource_categories') or [])
        }
        if resource_categories:
            demands_before = len(requests_data['data'])
            requests_data['data'] = [
                d for d in requests_data['data']
                if d.get('resource_category', '') in resource_categories
            ]
            requests_data['total'] = len(requests_data['data'])
            filtered_out = demands_before - len(requests_data['data'])
            logger.info(f"Category pre-filter: {demands_before} → {len(requests_data['data'])} demands ({filtered_out} uncoverable removed, {len(resource_categories)} resource categories)")

        # Log demand category distribution after filtering
        if requests_data['data']:
            demand_cats = {}
            for d in requests_data['data']:
                cat = d.get('resource_category', 'UNKNOWN')
                demand_cats[cat] = demand_cats.get(cat, 0) + 1
            logger.info(f"Demand categories after filters: {dict(sorted(demand_cats.items(), key=lambda x: -x[1]))}")

        # --- 4B-ter. Operation point filter ---
        if target_teams:
            try:
                op_points = client.get_operation_points(team_ids=list(target_teams))
                team_station_codes = {op['station_code'] for op in op_points if op.get('station_code')}
                if team_station_codes:
                    demands_before_op = len(requests_data['data'])
                    location_dist = {}
                    for d in requests_data['data']:
                        slc = d.get('start_location_code', 'UNKNOWN')
                        location_dist[slc] = location_dist.get(slc, 0) + 1

                    requests_data['data'] = [
                        d for d in requests_data['data']
                        if d.get('start_location_code', '') in team_station_codes
                    ]
                    requests_data['total'] = len(requests_data['data'])
                    filtered_out_op = demands_before_op - len(requests_data['data'])

                    filtered_location_dist = {}
                    for d in requests_data['data']:
                        slc = d.get('start_location_code', 'UNKNOWN')
                        filtered_location_dist[slc] = filtered_location_dist.get(slc, 0) + 1

                    logger.info(
                        f"Operation point filter: {demands_before_op} → {len(requests_data['data'])} demands "
                        f"({filtered_out_op} outside team territory, "
                        f"{len(team_station_codes)} station codes for teams {target_teams})"
                    )
                    logger.info(f"Team station codes: {sorted(team_station_codes)}")
                    logger.info(f"Demand locations in scope: {dict(sorted(filtered_location_dist.items(), key=lambda x: -x[1]))}")

                    if len(requests_data['data']) == 0:
                        logger.warning(
                            f"No demands match team operation points! "
                            f"All {demands_before_op} demands were outside team territory. "
                            f"Top demand locations: {dict(sorted(location_dist.items(), key=lambda x: -x[1])[:10])}"
                        )
                else:
                    logger.warning(
                        f"No station codes found in operation points for teams {target_teams}. "
                        f"Proceeding with ALL {len(requests_data['data'])} demands (no territorial filter applied)."
                    )
            except Exception as e:
                logger.warning(
                    f"Failed to fetch operation points for teams {target_teams}: {e}. "
                    f"Proceeding with ALL {len(requests_data['data'])} demands (no territorial filter applied)."
                )

        # --- 4C. Test mode slicing ---
        sliced_resource_ids = None
        if job.request.test_mode:
            demands = requests_data['data']
            target_demands = job.request.test_requests
            if len(demands) > target_demands:
                stride = len(demands) // target_demands
                requests_data['data'] = demands[::stride][:target_demands]
            requests_data['total'] = len(requests_data['data'])

            resources = resources_data['data']
            target_resources = job.request.test_resources
            if len(resources) > target_resources:
                stride = len(resources) // target_resources
                resources_data['data'] = resources[::stride][:target_resources]
            resources_data['total'] = len(resources_data['data'])

            sliced_resource_ids = {r['resource_id'] for r in resources_data['data']}
            logger.info(f"Test mode: smart sliced to {len(requests_data['data'])} demands, {len(resources_data['data'])} resources (strided sampling)")

        # --- 4D. Fetch resource blocks ---
        replannable_types = job.request.replannable_demand_type
        lock_allocations = job.request.lock_allocations

        filter_resource_ids = list(sliced_resource_ids) if sliced_resource_ids else None
        if filter_resource_ids:
            logger.info(f"Fetching resource blocks for {len(filter_resource_ids)} sliced resources only (server-side filter)")

        from api.data_pipeline import sanitize_replannable_types, filter_to_always_blocking

        if not lock_allocations:
            # Even with lock_allocations=false, true absences must still block
            blocks_data = client.get_resource_blocks(
                category="all",
                start_date=start_date,
                end_date=end_date,
                resource_ids=filter_resource_ids
            )
            all_blocks = filter_to_always_blocking(blocks_data.get('data', []))
            logger.info(f"lock_allocations=false: kept {len(all_blocks)} always-blocking absence blocks "
                        f"(from {blocks_data.get('total', 0)} total)")
        else:
            safe_replannable = sanitize_replannable_types(replannable_types, logger)
            blocks_data = client.get_resource_blocks(
                category="all",
                start_date=start_date,
                end_date=end_date,
                exclude_calendar_types=safe_replannable if safe_replannable else None,
                resource_ids=filter_resource_ids
            )
            all_blocks = blocks_data.get('data', [])
            logger.info(f"lock_allocations=true: {len(all_blocks)} blocks "
                        f"(replannable excluded: {safe_replannable or 'none'})")

        absences_data = {'data': all_blocks, 'total': len(all_blocks)}
        logger.info(f"Total resource blocks for solver: {len(all_blocks)}")

        # LC-06: determine if RT/CT should be treated as replannable rest-day allocations.
        # Only meaningful when lock_allocations=true (otherwise absences are never replanned).
        from config import RT_CALENDAR_TYPE, CT_CALENDAR_TYPE
        raw_replannable = [t.strip() for t in (replannable_types or [])]
        rt_replannable = lock_allocations and (RT_CALENDAR_TYPE in raw_replannable)
        ct_replannable = lock_allocations and (CT_CALENDAR_TYPE in raw_replannable)
        logger.info(f"LC-06 rest replanning: rt_replannable={rt_replannable}, ct_replannable={ct_replannable}")

        # Set actual data counts on job
        job.num_demands = len(requests_data.get('data', []))
        job.num_resources = len(resources_data.get('data', []))
        logger.info(f"Actual counts: {job.num_demands} demands, {job.num_resources} resources")

    # Fetch constraints & objectives
    constraint_values = fetch_constraint_values(planning_mode="Balanced", user_id=job.request.user_id)
    objective_weights = fetch_objective_weights(user_id=job.request.user_id)

    # Preprocess
    preprocessed_data = preprocess_data(requests_data, resources_data, absences_data)
    preprocessed_data.targeted_request_ids = None
    preprocessed_data.rt_replannable = rt_replannable
    preprocessed_data.ct_replannable = ct_replannable

    return (client, requests_data, resources_data, absences_data,
            preprocessed_data, constraint_values, objective_weights)


def _save_results_sync(client, job, model, analysis_report, requests_data, resources_data,
                       rt_replannable: bool = False, ct_replannable: bool = False):
    """
    Synchronous helper: save solver results to backend.
    Runs in thread pool via run_in_executor to keep the event loop free.
    Returns plan_id.

    fetch_rt/fetch_ct in planner_output are the inverse of rt_replannable/ct_replannable:
    - rt_replannable=True  → solver produced RT allocations → fetch_rt=False (read from planner_assignments)
    - rt_replannable=False → solver did not replan RT      → fetch_rt=True  (FE reads from external DB)
    """
    import sys
    import os

    solver_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    if solver_dir not in sys.path:
        sys.path.insert(0, solver_dir)

    from ortools.sat.python import cp_model as cp

    plan_id = f"PLAN-{datetime.now().strftime('%Y%m%d%H%M%S')}"
    job.plan_id = plan_id

    solver_status = 'OPTIMAL' if model.status == cp.OPTIMAL else 'FEASIBLE' if model.status == cp.FEASIBLE else 'INFEASIBLE' if model.status == cp.INFEASIBLE else 'UNKNOWN'
    solve_time = model.solver.WallTime() if hasattr(model, 'solver') else 0.0
    assignments_list = model.solution_assignments if hasattr(model, 'solution_assignments') else []
    num_violations = analysis_report.get('summary', {}).get('violations', {}).get('total_count', 0) if analysis_report else 0

    # Capture the final CP-SAT objective cost so planner_output.objective_value
    # isn't null in the DB. Only valid when the solver reached a feasible/optimal
    # solution — skip on INFEASIBLE/UNKNOWN to avoid calling ObjectiveValue()
    # on an empty model.
    objective_value = None
    if model.status in (cp.OPTIMAL, cp.FEASIBLE) and hasattr(model, 'solver'):
        try:
            objective_value = float(model.solver.ObjectiveValue())
        except Exception as _exc:
            logger.warning(f"Could not read ObjectiveValue(): {_exc}")
            objective_value = None

    # Enrich assignments with team_name and group_name
    if assignments_list:
        try:
            teams = client.get_teams()
            groups = client.get_groups()
            team_lookup = {t['team_id']: t['team_name'] for t in teams}
            group_lookup = {g['group_id']: g['group_name'] for g in groups}
            for a in assignments_list:
                a['team_name'] = team_lookup.get(a.get('team_id'))
                a['group_name'] = group_lookup.get(a.get('group_id'))
            logger.info(f"Enriched {len(assignments_list)} assignments with team/group names")
        except Exception as e:
            logger.warning(f"Could not enrich assignments with team/group names: {e}")

    # Log assignment breakdown
    if assignments_list:
        asgn_by_team = {}
        asgn_by_group = {}
        asgn_by_cat = {}
        night_count = 0
        for a in assignments_list:
            tname = a.get('team_name') or f"team_{a.get('team_id', '?')}"
            asgn_by_team[tname] = asgn_by_team.get(tname, 0) + 1
            gname = a.get('group_name') or f"group_{a.get('group_id', '?')}"
            asgn_by_group[gname] = asgn_by_group.get(gname, 0) + 1
            cat = a.get('resource_category', 'UNKNOWN')
            asgn_by_cat[cat] = asgn_by_cat.get(cat, 0) + 1
            if a.get('is_night_shift'):
                night_count += 1

        distinct_resources = len({a.get('resource_id') for a in assignments_list})
        distinct_demands = len({a.get('demand_id') for a in assignments_list})

        logger.info(f"Assignments breakdown: {len(assignments_list)} total, "
                    f"{distinct_resources} distinct resources, {distinct_demands} distinct demands, "
                    f"{night_count} night shifts")
        logger.info(f"Assignments by team: {dict(sorted(asgn_by_team.items(), key=lambda x: -x[1]))}")
        logger.info(f"Assignments by group: {dict(sorted(asgn_by_group.items(), key=lambda x: -x[1]))}")
        logger.info(f"Assignments by category: {dict(sorted(asgn_by_cat.items(), key=lambda x: -x[1]))}")
    else:
        logger.info("No assignments produced by solver")

    # Calculate counts from actual data
    actual_num_requests = len(requests_data.get('data', []))
    actual_num_resources = len(resources_data.get('data', []))

    client.post_planner_output(
        plan_id=plan_id,
        status=solver_status,
        assignments=assignments_list,
        num_requests=actual_num_requests,
        num_resources=actual_num_resources,
        num_violations=num_violations,
        solve_time_seconds=solve_time,
        metadata={
            'job_id': job.job_id,
            'test_mode': job.request.test_mode,
            'analysis_summary': analysis_report.get('summary', {}) if analysis_report else {}
        },
        job_id=job.job_id,
        fetch_rt=not rt_replannable,
        fetch_ct=not ct_replannable,
        objective_value=objective_value,
    )
    logger.info(f"Plan {plan_id} saved to backend planner_output table")

    # Save normalized assignments
    # Rows of type 'CT' / 'RT' (emitted by LC-06) have no underlying demand —
    # request_id and bsa_id must be NULL. Rows of type 'DEMAND' keep their
    # demand_id as request_id. assignment_type is forwarded so the backend
    # bulk insert can populate the new column.
    try:
        normalized = []
        type_counts: dict = {}
        for a in assignments_list:
            assignment_type = a.get('assignment_type') or 'DEMAND'
            type_counts[assignment_type] = type_counts.get(assignment_type, 0) + 1
            demand_id = a.get('demand_id')
            normalized.append({
                'request_id': str(demand_id) if demand_id is not None else None,
                'bsa_id': a.get('bsa_id'),
                'resource_id': str(a.get('resource_id')),
                'resource_name': a.get('resource_name'),
                'resource_category': a.get('resource_category'),
                'team_id': a.get('team_id'),
                'team_name': a.get('team_name'),
                'group_id': a.get('group_id'),
                'group_name': a.get('group_name'),
                'calendar_start': a.get('start'),
                'calendar_end': a.get('end'),
                'duration_hours': a.get('duration_hours'),
                'is_night_shift': a.get('is_night_shift', False),
                'assignment_type': assignment_type,
            })
        if normalized:
            client.post_planner_assignments_bulk(plan_id, job.job_id, normalized)
            logger.info(
                f"Saved {len(normalized)} normalized assignments for plan {plan_id} "
                f"(by type: {type_counts})"
            )
    except Exception as e:
        logger.error(f"Failed to save normalized assignments: {e}")

    # Save uncovered demands
    try:
        if analysis_report:
            cov = analysis_report.get('objective_performance', {}).get('maximize_coverage', {})
            metrics = cov.get('metrics', {})
            uncov_ids = set(str(uid) for uid in metrics.get('uncovered_request_ids', []))
            qual_ids = set(str(qid) for qid in metrics.get('qualification_gap_ids', []))

            if uncov_ids:
                req_lookup = {str(d['id']): d for d in requests_data.get('data', [])}
                uncov_list = []
                for rid in uncov_ids:
                    req = req_lookup.get(rid, {})
                    gap = 'QUALIFICATION_GAP' if rid in qual_ids else 'CAPACITY_GAP'
                    uncov_list.append({
                        'request_id': str(rid),
                        'bsa_id': req.get('bsa_id'),
                        'resource_category': req.get('resource_category'),
                        'start_location': req.get('start_location'),
                        'start_location_code': req.get('start_location_code'),
                        'end_location': req.get('end_location'),
                        'end_location_code': req.get('end_location_code'),
                        'calendar_start': req.get('shift_start_time'),
                        'calendar_end': req.get('shift_finish_time'),
                        'required_qualifications': req.get('required_qualifications', []),
                        'responsible_person': req.get('responsible_person'),
                        'people_needed': req.get('people_needed', 1),
                        'gap_type': gap,
                    })
                client.post_planner_uncovered_demands_bulk(plan_id, job.job_id, uncov_list)
                logger.info(f"Saved {len(uncov_list)} uncovered demands for plan {plan_id}")
    except Exception as e:
        logger.error(f"Failed to save uncovered demands: {e}")

    return plan_id


async def _execute_solver_job(job: SolverJob):
    """
    Execute the solver job asynchronously.
    This runs as a background task, independent of WebSocket connections.
    """
    import sys
    import os

    # Add solver_v2 to path
    solver_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    if solver_dir not in sys.path:
        sys.path.insert(0, solver_dir)

    job.status = JobStatus.RUNNING
    job.start_time = datetime.now()

    try:
        # Webhook: QUEUED -> RUNNING
        await send_webhook(job, "QUEUED", 0.0, current_step="queued")

        # Step 1: Initialize
        job.update_progress(SolverStep.INITIALIZING)
        await job_manager.broadcast_progress(job.job_id, job.progress_history[-1])
        await asyncio.sleep(0.1)  # Allow WebSocket to catch up

        await send_webhook(job, "RUNNING", 5.0, current_step="initializing")

        # Import solver components (only what's needed post-fetch)
        from solver.model import create_and_solve_model
        from config import (
            Environment, ENABLE_PARTITIONING,
            PARTITION_ALIGN_TO_MONTHS, PARTITION_ALIGN_TO_WEEKS,
            PARTITION_MAX_DAYS, PARTITION_AUTO_THRESHOLD_DEMANDS,
            PARTITION_AUTO_THRESHOLD_DAYS, PARTITION_TIME_LIMIT,
            PARTITION_ENABLE_CHECKPOINTS, PARTITION_CHECKPOINT_DIR,
            PARTITION_MAX_DEMANDS
        )

        # Cancellation helper — cancel_job() already set status/webhook,
        # these checks just exit the execution flow cleanly.
        def _check_cancelled(step_name):
            if job.cancelled:
                logger.info(f"Job {job.job_id} cancelled during {step_name}")
                return True
            return False

        # Step 2: Fetch data & preprocess (in thread pool to keep event loop free)
        job.update_progress(SolverStep.FETCHING_DATA)
        await job_manager.broadcast_progress(job.job_id, job.progress_history[-1])

        if _check_cancelled("fetching_data"): return

        loop = asyncio.get_event_loop()
        (client, requests_data, resources_data, absences_data,
         preprocessed_data, constraint_values, objective_weights
        ) = await loop.run_in_executor(None, _fetch_and_preprocess_sync, job)

        if _check_cancelled("after_fetching_data"): return

        await send_webhook(job, "RUNNING", 15.0, current_step="preprocessing")

        job.update_progress(SolverStep.PREPROCESSING, {
            'requests_count': job.num_demands,
            'resources_count': job.num_resources
        })
        await job_manager.broadcast_progress(job.job_id, job.progress_history[-1])

        if _check_cancelled("before_solving"): return

        # Step 6-8: Build and solve model
        job.update_progress(SolverStep.BUILDING_MODEL, {
            'num_requests': len(preprocessed_data.request_ids),
            'num_resources': len(preprocessed_data.resource_ids)
        })
        await job_manager.broadcast_progress(job.job_id, job.progress_history[-1])

        # Workflow A: Let solver run until complete (high limit, user can cancel)
        # The time_limit is a safety net, not a hard cutoff - user is warned via progress
        time_limit = job.request.options.time_limit_seconds  # Default 7200s (2 hours)

        # Check if partitioning should be used
        use_partitioning = False
        if ENABLE_PARTITIONING:
            num_demands = len(preprocessed_data.request_ids)
            date_range_days = (preprocessed_data.planning_end - preprocessed_data.planning_start).days
            if num_demands > PARTITION_AUTO_THRESHOLD_DEMANDS or date_range_days > PARTITION_AUTO_THRESHOLD_DAYS:
                use_partitioning = True
                logger.info(f"Partitioning ENABLED: {num_demands} demands, {date_range_days} days")

        def solve_sync():
            if use_partitioning:
                # Use partitioned solving
                from solver.partitioner import SolverPartitioner, PartitionConfig
                from solver.checkpoint_manager import CheckpointManager, solve_with_checkpointing
                from solver.proration_engine import ProrationEngine

                config = PartitionConfig(
                    align_to_calendar_months=PARTITION_ALIGN_TO_MONTHS,
                    align_to_calendar_weeks=PARTITION_ALIGN_TO_WEEKS,
                    max_days_per_partition=PARTITION_MAX_DAYS,
                    time_limit_per_partition=PARTITION_TIME_LIMIT,
                    max_demands_per_partition=PARTITION_MAX_DEMANDS  # Use explicit max, not auto threshold
                )

                partitioner = SolverPartitioner(config)
                partitions = partitioner.create_partitions(
                    requests_data.get('data', []),
                    resources_data.get('data', []),
                    absences_data.get('data', [])
                )

                logger.info(f"Created {len(partitions)} partitions for solving")

                # Setup checkpointing if enabled
                checkpoint_manager = None
                if PARTITION_ENABLE_CHECKPOINTS:
                    checkpoint_manager = CheckpointManager(checkpoint_dir=PARTITION_CHECKPOINT_DIR)

                # Setup proration engine for OC-01
                planning_year = preprocessed_data.planning_start.year
                proration_engine = ProrationEngine(planning_year=planning_year)

                # Partition progress callback for webhook tracking
                def partition_progress_cb(partition_index, total, status):
                    if status != "solving":  # Only on completion
                        job.partition_completed = partition_index + 1
                        job.partition_total = total
                        label = partitions[partition_index].start_date.strftime('%B %Y')
                        job.partition_last_label = label

                # Solve with checkpointing
                result = solve_with_checkpointing(
                    partitioner, partitions,
                    constraint_values, objective_weights,
                    job_id=job.job_id,
                    checkpoint_manager=checkpoint_manager,
                    proration_engine=proration_engine,
                    resume=True,
                    progress_callback=partition_progress_cb,
                    cancellation_check=lambda: job.cancelled,
                    rt_replannable=getattr(preprocessed_data, 'rt_replannable', False),
                    ct_replannable=getattr(preprocessed_data, 'ct_replannable', False),
                )

                # Clean up checkpoints after successful completion
                if checkpoint_manager and result['summary']['overall_status'] in ['OPTIMAL', 'FEASIBLE']:
                    checkpoint_manager.clean_old_checkpoints(job.job_id, keep_last=0)
                    logger.info(f"Cleaned up checkpoints for job {job.job_id}")

                # Wrap result in a model-like object for compatibility
                class PartitionedResult:
                    def __init__(self, result_dict):
                        self.solution_assignments = result_dict['assignments']
                        self.status = self._map_status(result_dict['summary']['overall_status'])
                        solve_time = result_dict['summary']['total_solve_time_seconds']
                        self.solver = type('Solver', (), {'WallTime': lambda self: solve_time})()
                        self._result = result_dict

                    def _map_status(self, status_str):
                        from ortools.sat.python import cp_model as cp
                        return {
                            'OPTIMAL': cp.OPTIMAL,
                            'FEASIBLE': cp.FEASIBLE,
                            'INFEASIBLE': cp.INFEASIBLE,
                            'ERROR': cp.MODEL_INVALID,
                            'PARTIAL': cp.FEASIBLE,
                        }.get(status_str, cp.UNKNOWN)

                return PartitionedResult(result)
            else:
                # Standard non-partitioned solving
                return create_and_solve_model(preprocessed_data, constraint_values, objective_weights, time_limit=time_limit)

        solving_mode = 'PARTITIONED' if use_partitioning else 'STANDARD'
        job.update_progress(SolverStep.SOLVING, {
            'estimated_seconds': job.estimated_seconds,
            'workflow': 'A',
            'mode': solving_mode,
            'note': f'Solver running ({solving_mode}). You will be warned if exceeding estimated time.'
        })
        await job_manager.broadcast_progress(job.job_id, job.progress_history[-1])

        # Run solver with periodic time monitoring
        async def monitor_solve_time():
            """Send periodic updates during solving with time warnings and partition webhooks."""
            update_interval = 10  # Check every 10 seconds
            last_webhook_partition = 0
            while True:
                await asyncio.sleep(update_interval)

                # Check for partition completion and send webhook
                if job.partition_total > 0 and job.partition_completed > last_webhook_partition:
                    last_webhook_partition = job.partition_completed
                    progress = (job.partition_completed / job.partition_total) * 90.0 + 5.0
                    await send_webhook(
                        job, "RUNNING", progress,
                        current_step="solving",
                        partition_info={
                            "current_partition": job.partition_completed,
                            "total_partitions": job.partition_total,
                            "partition_label": job.partition_last_label,
                        },
                    )

                time_status, warning = job.get_time_status()
                if time_status != "normal":
                    elapsed = int((datetime.now() - job.start_time).total_seconds())
                    job.update_progress(SolverStep.SOLVING, {
                        'elapsed_seconds': elapsed,
                        'estimated_seconds': job.estimated_seconds,
                        'time_status': time_status,
                        'warning': warning
                    })
                    await job_manager.broadcast_progress(job.job_id, job.progress_history[-1])

        # Start monitoring task
        monitor_task = asyncio.create_task(monitor_solve_time())
        try:
            model = await loop.run_in_executor(None, solve_sync)
        finally:
            monitor_task.cancel()
            try:
                await monitor_task
            except asyncio.CancelledError:
                pass

        if _check_cancelled("after_solving"): return

        # Webhook: solving done
        await send_webhook(job, "RUNNING", 95.0, current_step="analyzing")

        # Step 9: Analyze results
        job.update_progress(SolverStep.ANALYZING)
        await job_manager.broadcast_progress(job.job_id, job.progress_history[-1])

        from ortools.sat.python import cp_model as cp
        from analysis.solution_analyzer import SolutionAnalyzer

        analysis_report = None
        if model.status in [cp.OPTIMAL, cp.FEASIBLE]:
            analyzer = SolutionAnalyzer(
                solution=model,
                data=preprocessed_data,
                constraints=constraint_values
            )
            analysis_report = analyzer.analyze()

        if analysis_report:
            summary = analysis_report.get('summary', {})
            cov = summary.get('coverage', {})
            logger.info(
                f"Analysis summary: coverage={cov.get('rate', 0)}% "
                f"({cov.get('requests_covered', 0)}/{cov.get('requests_total', 0)} demands), "
                f"violations={summary.get('violations', {}).get('total_count', 0)}, "
                f"status={summary.get('overall_status', '?')}"
            )

            # Log uncovered demand details
            cov_perf = analysis_report.get('objective_performance', {}).get('maximize_coverage', {})
            if cov_perf:
                metrics = cov_perf.get('metrics', {})
                uncov_count = metrics.get('uncovered_requests', 0)
                if uncov_count > 0:
                    qual_gaps = len(metrics.get('qualification_gap_ids', []))
                    cap_gaps = len(metrics.get('capacity_gap_ids', []))
                    logger.info(f"Uncovered demands: {uncov_count} total ({qual_gaps} qualification gaps, {cap_gaps} capacity gaps)")

        if _check_cancelled("before_saving"): return

        # Step 10: Save results (in thread pool to keep event loop free)
        job.update_progress(SolverStep.SAVING_RESULTS)
        await job_manager.broadcast_progress(job.job_id, job.progress_history[-1])

        try:
            rt_replannable_flag = getattr(preprocessed_data, 'rt_replannable', False)
            ct_replannable_flag = getattr(preprocessed_data, 'ct_replannable', False)
            plan_id = await loop.run_in_executor(
                None, _save_results_sync, client, job, model, analysis_report, requests_data, resources_data,
                rt_replannable_flag, ct_replannable_flag
            )
        except Exception as e:
            plan_id = job.plan_id or "UNKNOWN"
            logger.error(f"CRITICAL: Failed to save plan {plan_id} to backend: {e}")
            import traceback
            traceback.print_exc()
            job.error = f"Plan completed but save failed: {e}"

        # Complete
        job.update_progress(SolverStep.COMPLETE, {
            'plan_id': plan_id,
            'assignments_count': len(model.solution_assignments) if hasattr(model, 'solution_assignments') else 0
        })
        await job_manager.broadcast_progress(job.job_id, job.progress_history[-1])

        status_map = {
            cp.OPTIMAL: "OPTIMAL",
            cp.FEASIBLE: "FEASIBLE",
            cp.INFEASIBLE: "INFEASIBLE",
            cp.MODEL_INVALID: "MODEL_INVALID",
            cp.UNKNOWN: "UNKNOWN"
        }

        job.result = {
            'solver_status': status_map.get(model.status, 'UNKNOWN'),
            'assignments_count': len(model.solution_assignments) if hasattr(model, 'solution_assignments') else 0,
            'solve_time_seconds': model.solver.WallTime() if hasattr(model, 'solver') else None,
            'analysis_summary': analysis_report.get('summary', {}) if analysis_report else {}
        }

        job.status = JobStatus.COMPLETE
        job.end_time = datetime.now()

        # Webhook: COMPLETED
        await send_webhook(job, "COMPLETED", 100.0, current_step="complete", plan_id=plan_id)

        logger.info(f"Job {job.job_id} completed successfully")

    except Exception as e:
        logger.error(f"Job {job.job_id} failed: {e}")
        import traceback
        traceback.print_exc()

        job.status = JobStatus.FAILED
        job.error = str(e)
        job.end_time = datetime.now()

        # Webhook: FAILED
        await send_webhook(job, "FAILED", job.progress * 100, current_step="error", error_message=str(e))

        # Broadcast error
        error_msg = ProgressMessage(
            type="error",
            step="error",
            progress=job.progress,
            message=f"Job failed: {str(e)}",
            timestamp=datetime.now().isoformat(),
            details={'error': str(e)}
        )
        job.progress_history.append(error_msg)
        await job_manager.broadcast_progress(job.job_id, error_msg)


