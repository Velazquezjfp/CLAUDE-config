@api_router.post("/solver/trigger", response_model=TriggerResponse, tags=["Solver"])
async def trigger_solver(
    trigger_request: TriggerRequest,
    background_tasks: BackgroundTasks,
    http_request: Request
):
    """
    Trigger a new solver job (Workflow A).

    The solver runs asynchronously in the background. Use the returned `job_id`
    to monitor progress via WebSocket or polling.

    **Time Tracking:** The response includes an estimated time. Progress updates
    will include warnings if the solver takes longer than expected.

    **Important:** The solver continues running even if you disconnect.
    You can cancel anytime if it takes too long.
    """
    # Validate plan_range if provided with dates
    if trigger_request.plan_range and not trigger_request.plan_range.is_empty():
        try:
            start_str = trigger_request.plan_range.start_date
            end_str = trigger_request.plan_range.end_date

            # Both must be provided if one is provided
            if start_str and not end_str:
                raise HTTPException(status_code=400, detail="plan_range.end_date required when start_date is provided")
            if end_str and not start_str:
                raise HTTPException(status_code=400, detail="plan_range.start_date required when end_date is provided")

            # Strip time component if full ISO 8601 provided
            if start_str and 'T' in start_str:
                start_str = start_str.split('T')[0]
            if end_str and 'T' in end_str:
                end_str = end_str.split('T')[0]

            start_date = datetime.strptime(start_str, '%Y-%m-%d').date()
            end_date = datetime.strptime(end_str, '%Y-%m-%d').date()

            if start_date > end_date:
                logger.error(f"plan_range start ({start_date}) > end ({end_date})")
                raise HTTPException(
                    status_code=400,
                    detail=f"plan_range start_date ({start_str}) must be <= end_date ({end_str})"
                )
        except ValueError as e:
            logger.error(f"Invalid plan_range date format: {e}")
            raise HTTPException(
                status_code=400,
                detail=f"Invalid date format in plan_range: {e}. Use YYYY-MM-DD format."
            )

    # Check queue capacity
    from config import MAX_QUEUE_SIZE
    pending = job_manager.get_pending_count()
    running = job_manager.get_running_count()
    if pending + running >= MAX_QUEUE_SIZE:
        raise HTTPException(
            status_code=429,
            detail=f"Solver queue full ({pending} pending, {running} running). Try again later."
        )

    # Create job
    job = job_manager.create_job(trigger_request)

    # Calculate time estimate for UX
    time_estimate = get_time_estimate_for_trigger(
        trigger_request.test_requests if trigger_request.test_mode else 1000,  # Default estimate
        trigger_request.test_resources if trigger_request.test_mode else 100
    )

    # Set estimate on job for progress tracking
    job.set_time_estimate(
        time_estimate.estimated_seconds,
        time_estimate.estimated_display,
        time_estimate.confidence
    )

    # Webhook: QUEUED (from trigger endpoint, before background task starts)
    await send_webhook(job, "QUEUED", 0.0, current_step="queued")

    # Store websocket_url on the job so webhooks can include it
    job.websocket_url = get_websocket_url(http_request, job.job_id)

    # Start solver in background
    background_tasks.add_task(run_solver_job, job)

    # Return immediately with time estimate for UX
    queue_position = job_manager.get_queue_position(job.job_id)
    return TriggerResponse(
        status="accepted",
        job_id=job.job_id,
        websocket_url=job.websocket_url,
        status_url=f"{ROOT_PATH}/api/v1/solver/status/{job.job_id}",
        message=f"Solver job queued (position {queue_position}). Estimated time: {time_estimate.estimated_display}",
        time_estimate=time_estimate,
        queue_position=queue_position
    )


@api_router.get("/solver/status/{job_id}", response_model=JobStatusResponse, tags=["Solver"])
async def get_job_status(job_id: str):
    """
    Get the status of a solver job.

    Use this endpoint to poll for job status if you cannot use WebSocket.
    """
    job = job_manager.get_job(job_id)
    if not job:
