class SolverJob:
    """Represents a solver job with time tracking for UX"""
    def __init__(self, job_id: str, request: TriggerRequest):
        self.job_id = job_id
        self.request = request
        self.status = JobStatus.PENDING
        self.current_step = SolverStep.INITIALIZING
        self.progress = 0.0
        self.message = "Job queued"
        self.start_time: Optional[datetime] = None
        self.end_time: Optional[datetime] = None
        self.plan_id: Optional[str] = None
        self.result: Optional[Dict[str, Any]] = None
        self.error: Optional[str] = None
        self.progress_history: List[ProgressMessage] = []
        # Time tracking for UX
        self.estimated_seconds: Optional[int] = None
        self.time_estimate_display: Optional[str] = None
        self.time_estimate_confidence: Optional[str] = None
        # Actual data counts (set after data fetching)
        self.num_demands: Optional[int] = None
        self.num_resources: Optional[int] = None
        # Partition tracking for webhook progress
        self.partition_completed: int = 0
        self.partition_total: int = 0
        self.partition_last_label: Optional[str] = None
        # WebSocket URL (set by trigger endpoint)
        self.websocket_url: Optional[str] = None
        # Cancellation flag (set by cancel endpoint)
        self.cancelled = False

    def set_time_estimate(self, estimated_seconds: int, display: str, confidence: str):
        """Set time estimate for this job"""
        self.estimated_seconds = estimated_seconds
        self.time_estimate_display = display
        self.time_estimate_confidence = confidence

    def get_time_status(self) -> tuple:
        """
        Get time status and warning message for UX.
        Returns (time_status, warning_message)
        """
        if not self.start_time or not self.estimated_seconds:
            return ("normal", None)

        elapsed = self.get_elapsed_seconds() or 0

        # Calculate how much we've exceeded the estimate
        if elapsed <= self.estimated_seconds:
            return ("normal", None)
        elif elapsed <= self.estimated_seconds * 1.5:
            return ("exceeding_estimate",
                    f"Taking longer than expected ({int(elapsed)}s / ~{self.estimated_seconds}s estimated). "
                    "The solver is still working. You can wait or cancel if needed.")
        elif elapsed <= self.estimated_seconds * 2.5:
            return ("significantly_delayed",
                    f"Significantly delayed ({int(elapsed)}s / ~{self.estimated_seconds}s estimated). "
                    "Consider cancelling and reducing dataset size by blocking more teams, locations, or dates.")
        else:
            return ("significantly_delayed",
                    f"Very delayed ({int(elapsed)}s / ~{self.estimated_seconds}s estimated). "
                    "Strongly recommend cancelling and using a smaller dataset or date range.")

    def update_progress(self, step: SolverStep, details: Optional[Dict] = None):
        """Update job progress with time context"""
        self.current_step = step
        self.progress = STEP_PROGRESS.get(step, self.progress)
        self.message = STEP_MESSAGES.get(step, f"Step: {step}")

        # Get time context for UX
        elapsed = self.get_elapsed_seconds()
        time_status, warning = self.get_time_status()

        progress_msg = ProgressMessage(
            type="warning" if warning and step != SolverStep.COMPLETE else ("progress" if step != SolverStep.COMPLETE else "complete"),
            step=step.value,
            progress=self.progress,
            message=self.message,
            timestamp=datetime.now().isoformat(),
            details=details,
            elapsed_seconds=elapsed,
            estimated_seconds=self.estimated_seconds,
            time_status=time_status,
            warning=warning
        )
        self.progress_history.append(progress_msg)

        if warning:
            logger.warning(f"Job {self.job_id}: {warning}")
        logger.info(f"Job {self.job_id}: {step.value} ({self.progress*100:.0f}%) - elapsed: {elapsed:.1f}s")

    def get_elapsed_seconds(self) -> Optional[float]:
        """Get elapsed time in seconds"""
        if self.start_time:
            end = self.end_time or datetime.now()
            return (end - self.start_time).total_seconds()
        return None


class JobManager:
    """Manages solver jobs"""
    def __init__(self):
        self.jobs: Dict[str, SolverJob] = {}
        self.active_websockets: Dict[str, List[WebSocket]] = {}
        from config import MAX_CONCURRENT_JOBS
        self._solver_semaphore = asyncio.Semaphore(MAX_CONCURRENT_JOBS)
        logger.info(f"JobManager initialized: max_concurrent_jobs={MAX_CONCURRENT_JOBS}")

    def create_job(self, request: TriggerRequest) -> SolverJob:
        """Create a new solver job"""
        job_id = f"JOB-{datetime.now().strftime('%Y%m%d%H%M%S')}-{uuid.uuid4().hex[:6].upper()}"
        job = SolverJob(job_id, request)
        self.jobs[job_id] = job
        logger.info(f"Created job {job_id}")
        return job

    def get_job(self, job_id: str) -> Optional[SolverJob]:
        """Get a job by ID"""
        return self.jobs.get(job_id)

    async def broadcast_progress(self, job_id: str, message: ProgressMessage):
        """Broadcast progress to all connected WebSocket clients"""
        if job_id in self.active_websockets:
            disconnected = []
            for ws in self.active_websockets[job_id]:
                try:
                    await ws.send_json(message.model_dump())
                except Exception as e:
                    logger.warning(f"Failed to send to WebSocket: {e}")
                    disconnected.append(ws)

            # Remove disconnected clients
            for ws in disconnected:
                self.active_websockets[job_id].remove(ws)

    def add_websocket(self, job_id: str, websocket: WebSocket):
        """Add a WebSocket connection for a job"""
        if job_id not in self.active_websockets:
            self.active_websockets[job_id] = []
        self.active_websockets[job_id].append(websocket)

    def remove_websocket(self, job_id: str, websocket: WebSocket):
        """Remove a WebSocket connection"""
        if job_id in self.active_websockets and websocket in self.active_websockets[job_id]:
            self.active_websockets[job_id].remove(websocket)

    def get_pending_count(self) -> int:
        """Count jobs waiting to run (PENDING status)."""
        return sum(1 for j in self.jobs.values() if j.status == JobStatus.PENDING)

    def get_running_count(self) -> int:
        """Count jobs currently running."""
        return sum(1 for j in self.jobs.values() if j.status == JobStatus.RUNNING)

    async def cancel_job(self, job_id: str) -> bool:
        """Cancel a job. Returns True if cancellation was accepted."""
        job = self.jobs.get(job_id)
        if not job:
            return False
        if job.status in (JobStatus.COMPLETE, JobStatus.FAILED, JobStatus.CANCELLED):
            return False

        job.cancelled = True
        previous_status = job.status
        job.status = JobStatus.CANCELLED
        job.error = "Cancelled by user"
        job.end_time = datetime.now()

        # Broadcast cancellation via WebSocket
        cancel_msg = ProgressMessage(
            type="cancelled",
            step="cancelled",
            progress=job.progress,
            message="Job cancelled by user",
            timestamp=datetime.now().isoformat(),
            details={
                "cancelled_at_step": job.current_step.value if job.current_step else None,
                "elapsed_seconds": job.get_elapsed_seconds(),
            }
        )
        job.progress_history.append(cancel_msg)
        await self.broadcast_progress(job_id, cancel_msg)

        # Send webhook to backend DB
        await send_webhook(job, "CANCELLED", job.progress, current_step="cancelled")

        # Clean up checkpoint files
        try:
            from config import PARTITION_ENABLE_CHECKPOINTS, PARTITION_CHECKPOINT_DIR
            if PARTITION_ENABLE_CHECKPOINTS:
                from solver.checkpoint_manager import CheckpointManager
                cm = CheckpointManager(PARTITION_CHECKPOINT_DIR)
                cm.clean_old_checkpoints(job_id, keep_last=0)
                logger.info(f"Cleaned up checkpoints for cancelled job {job_id}")
        except Exception as e:
            logger.warning(f"Checkpoint cleanup failed for {job_id}: {e}")

        logger.info(f"Job {job_id} cancelled (was {previous_status.value})")
        return True

    def get_queue_position(self, job_id: str) -> int:
        """Get queue position for a job. 0 = running/next, 1+ = waiting."""
        job = self.jobs.get(job_id)
        if not job or job.status != JobStatus.PENDING:
            return 0
        # Count PENDING jobs created before this one + running jobs
        position = sum(1 for j in self.jobs.values() if j.status == JobStatus.RUNNING)
        for jid, j in self.jobs.items():
            if jid == job_id:
                break
            if j.status == JobStatus.PENDING:
                position += 1
        return position


