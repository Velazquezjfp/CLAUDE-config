def get_websocket_url(http_request: Request, job_id: str) -> str:
    """
    Construct WebSocket URL dynamically from the HTTP request.
    Works for both localhost and remote servers behind reverse proxies.
    """
    host = http_request.headers.get("host", "localhost:8004")

    # Check for X-Forwarded-Proto from reverse proxy (nginx, traefik, etc.)
    forwarded_proto = http_request.headers.get("x-forwarded-proto")

    # Environment variable override (optional)
    force_https = os.environ.get("FORCE_HTTPS_WEBSOCKET", "").lower() in ("true", "1", "yes")

    # Determine scheme
    if force_https:
        scheme = "https"
    elif forwarded_proto:
        scheme = forwarded_proto
    else:
        scheme = http_request.url.scheme

    ws_scheme = "wss" if scheme == "https" else "ws"
    ws_url = f"{ws_scheme}://{host}{ROOT_PATH}/api/v1/solver/progress/{job_id}"

    logger.info(f"WebSocket URL: {ws_url}")
    return ws_url


