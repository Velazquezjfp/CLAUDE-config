    request: ExecuteRequest,
    background_tasks: BackgroundTasks,
    http_request: Request
):
    """
    Execute planning from a pre-plan.

    This is Stage 2 of the two-stage planning workflow.
    Uses the dataset created in Stage 1 (pre-plan) to run the solver.

    The solver runs as a background task. Monitor progress via:
    - WebSocket: /api/v1/solver/progress/{job_id}
    - Polling: GET /api/v1/solver/status/{job_id}
    """
    # Check queue capacity
    from config import MAX_QUEUE_SIZE
    pending = job_manager.get_pending_count()
    running = job_manager.get_running_count()
    if pending + running >= MAX_QUEUE_SIZE:
        raise HTTPException(
            status_code=429,
            detail=f"Solver queue full ({pending} pending, {running} running). Try again later."
        )

    # Get pre-plan data
    pre_plan_data = pre_planning_service.get_pre_plan_for_execution(request.pre_plan_id)
    if not pre_plan_data:
        raise HTTPException(
            status_code=404,
            detail=f"Pre-plan {request.pre_plan_id} not found or not ready for execution"
        )

    # Create a solver job using the pre-plan data
    trigger_request = TriggerRequest(
        user_id=pre_plan_data['user_id'],
        test_mode=pre_plan_data['request'].get('test', False),
        test_requests=len(pre_plan_data['dataset']['demands']),
        test_resources=len(pre_plan_data['dataset']['resources']),
        use_mock_data=False  # Use actual pre-plan data
    )

    # Store pre-plan data for solver to use
    # (In production, this would be more robust)
    trigger_request._pre_plan_data = pre_plan_data

    job = job_manager.create_job(trigger_request)
    job.pre_plan_id = request.pre_plan_id

    # Get time estimate from pre-plan for UX tracking
    pre_plan_response = pre_plan_data.get('response', {})
    time_estimate_data = pre_plan_response.get('time_estimate', {})
    estimated_seconds = time_estimate_data.get('estimated_seconds', 60)
    estimated_display = time_estimate_data.get('estimated_display', '~1 minute')
    confidence = time_estimate_data.get('confidence', 'medium')

    # Set estimate on job for progress warnings
    job.set_time_estimate(estimated_seconds, estimated_display, confidence)

    time_estimate = TimeEstimateInfo(
        estimated_seconds=estimated_seconds,
        estimated_display=estimated_display,
        confidence=confidence
    )

    # Store websocket_url on the job so webhooks can include it
    job.websocket_url = get_websocket_url(http_request, job.job_id)

    # Webhook: QUEUED (from execute endpoint, before background task starts)
    await send_webhook(job, "QUEUED", 0.0, current_step="queued")

    # Start solver in background
    background_tasks.add_task(run_solver_job_from_preplan, job, pre_plan_data)

    queue_position = job_manager.get_queue_position(job.job_id)
    return TriggerResponse(
        job_id=job.job_id,
        websocket_url=job.websocket_url,
        status_url=f"{ROOT_PATH}/api/v1/solver/status/{job.job_id}",
        message=f"Solver job queued (position {queue_position}). Estimated time: {estimated_display}",
        time_estimate=time_estimate,
        queue_position=queue_position
    )


async def run_solver_job_from_preplan(job: SolverJob, pre_plan_data: dict):
    """Semaphore wrapper: queues pre-plan job until a solver slot is available."""
    try:
        logger.info(f"Job {job.job_id}: waiting for solver slot (pre-plan, queue position: {job_manager.get_queue_position(job.job_id)})...")
        async with job_manager._solver_semaphore:
            logger.info(f"Job {job.job_id}: acquired solver slot, starting pre-plan execution")
            await _execute_solver_job_from_preplan(job, pre_plan_data)
    except Exception as e:
        if job.status not in (JobStatus.COMPLETE, JobStatus.FAILED, JobStatus.CANCELLED):
            logger.error(f"Job {job.job_id}: semaphore wrapper caught error: {e}")
            job.status = JobStatus.FAILED
            job.error = str(e)
            job.end_time = datetime.now()
            await send_webhook(job, "FAILED", 0.0, error_message=str(e))


async def _execute_solver_job_from_preplan(job: SolverJob, pre_plan_data: dict):
    """
    Execute solver using pre-plan data.
    Similar to _execute_solver_job but uses cached dataset.
    """
    import sys
    import os

    solver_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    if solver_dir not in sys.path:
        sys.path.insert(0, solver_dir)

    job.status = JobStatus.RUNNING
    job.start_time = datetime.now()

    try:
        # Webhook: QUEUED -> RUNNING
        await send_webhook(job, "QUEUED", 0.0, current_step="queued")

        job.update_progress(SolverStep.INITIALIZING)
        await job_manager.broadcast_progress(job.job_id, job.progress_history[-1])

        await send_webhook(job, "RUNNING", 5.0, current_step="initializing")

        from solver.model import create_and_solve_model
        from ortools.sat.python import cp_model as cp

        # Use pre-plan dataset (no fetching needed)
        job.update_progress(SolverStep.FETCHING_DATA, {
            'source': 'pre-plan',
            'pre_plan_id': pre_plan_data['pre_plan_id']
        })
        await job_manager.broadcast_progress(job.job_id, job.progress_history[-1])

        # Data already available from pre-plan
        requests_data = {'data': pre_plan_data['dataset']['demands']}
        resources_data = {'data': pre_plan_data['dataset']['resources']}
        absences_data = {'data': pre_plan_data['dataset']['absences']}

        # Fetch constraints, objectives, preprocess (in thread pool to keep event loop free)
        job.update_progress(SolverStep.PREPROCESSING, {
            'demands_count': len(requests_data['data']),
            'resources_count': len(resources_data['data'])
        })
        await job_manager.broadcast_progress(job.job_id, job.progress_history[-1])

        loop = asyncio.get_event_loop()

        def _preplan_preprocess_sync():
            from preprocessing.constraints import fetch_constraint_values
            from preprocessing.objectives import fetch_objective_weights
            from preprocessing.data_processor import preprocess_data
            cv = fetch_constraint_values(planning_mode="Balanced", user_id=job.request.user_id)
            ow = fetch_objective_weights(user_id=job.request.user_id)
            pd = preprocess_data(requests_data, resources_data, absences_data)
            pd.targeted_request_ids = None
            return (pd, cv, ow)

        (preprocessed_data, constraint_values, objective_weights) = await loop.run_in_executor(
            None, _preplan_preprocess_sync
        )

        # Build and solve
        job.update_progress(SolverStep.BUILDING_MODEL, {
            'num_requests': len(preprocessed_data.request_ids),
            'num_resources': len(preprocessed_data.resource_ids)
        })
        await job_manager.broadcast_progress(job.job_id, job.progress_history[-1])

        # Workflow B: Run until complete (no hard limit - user decides when to cancel)
        # Use 2 hours as safety net, but progress warnings will alert user
        time_limit = 7200  # 2 hours max safety net

        def solve_sync():
            return create_and_solve_model(preprocessed_data, constraint_values, objective_weights, time_limit=time_limit)

        job.update_progress(SolverStep.SOLVING, {
            'estimated_seconds': job.estimated_seconds,
            'workflow': 'B',
            'note': 'Solver running. You will be warned if exceeding estimated time.'
        })
        await job_manager.broadcast_progress(job.job_id, job.progress_history[-1])

        # Run solver with periodic time monitoring (loop already defined above)
        async def monitor_solve_time():
            """Send periodic updates during solving with time warnings."""
            update_interval = 10  # Check every 10 seconds
            while True:
                await asyncio.sleep(update_interval)
                time_status, warning = job.get_time_status()
                if time_status != "normal":
                    elapsed = int((datetime.now() - job.start_time).total_seconds())
                    job.update_progress(SolverStep.SOLVING, {
                        'elapsed_seconds': elapsed,
                        'estimated_seconds': job.estimated_seconds,
                        'time_status': time_status,
                        'warning': warning
                    })
                    await job_manager.broadcast_progress(job.job_id, job.progress_history[-1])

        # Start monitoring task
        monitor_task = asyncio.create_task(monitor_solve_time())
        try:
            model = await loop.run_in_executor(None, solve_sync)
        finally:
            monitor_task.cancel()
            try:
                await monitor_task
            except asyncio.CancelledError:
                pass

        # Webhook: solving done
        await send_webhook(job, "RUNNING", 95.0, current_step="analyzing")

        # Analyze
        job.update_progress(SolverStep.ANALYZING)
        await job_manager.broadcast_progress(job.job_id, job.progress_history[-1])

        from analysis.solution_analyzer import analyze_solution
        analysis_report = analyze_solution(model, preprocessed_data, constraint_values)

        # Complete
        job.update_progress(SolverStep.COMPLETE, {
            'pre_plan_id': pre_plan_data['pre_plan_id'],
            'assignments_count': len(model.solution_assignments) if hasattr(model, 'solution_assignments') else 0
        })
        await job_manager.broadcast_progress(job.job_id, job.progress_history[-1])

        status_map = {
            cp.OPTIMAL: "OPTIMAL",
            cp.FEASIBLE: "FEASIBLE",
            cp.INFEASIBLE: "INFEASIBLE",
            cp.MODEL_INVALID: "MODEL_INVALID",
            cp.UNKNOWN: "UNKNOWN"
        }

        job.result = {
            'solver_status': status_map.get(model.status, 'UNKNOWN'),
            'assignments_count': len(model.solution_assignments) if hasattr(model, 'solution_assignments') else 0,
            'blocked_count': len(pre_plan_data['dataset']['blocked_demands']),
            'pre_plan_id': pre_plan_data['pre_plan_id']
        }

        job.status = JobStatus.COMPLETE
        job.end_time = datetime.now()

        # Webhook: COMPLETED
        await send_webhook(job, "COMPLETED", 100.0, current_step="complete")

        # Mark pre-plan as executed
        pre_planning_service.mark_execution_complete(
            pre_plan_data['pre_plan_id'],
            job.job_id
        )

        logger.info(f"Job {job.job_id} completed from pre-plan {pre_plan_data['pre_plan_id']}")

    except Exception as e:
        logger.error(f"Job {job.job_id} failed: {e}")
        import traceback
        traceback.print_exc()

        job.status = JobStatus.FAILED
        job.error = str(e)
        job.end_time = datetime.now()

        # Webhook: FAILED
        await send_webhook(job, "FAILED", job.progress * 100, current_step="error", error_message=str(e))

        error_msg = ProgressMessage(
            type="error",
            step="error",
            progress=job.progress,
            message=f"Job failed: {str(e)}",
            timestamp=datetime.now().isoformat(),
            details={'error': str(e)}
        )
        job.progress_history.append(error_msg)
        await job_manager.broadcast_progress(job.job_id, error_msg)


