async def send_webhook(
    job: SolverJob,
    status: str,
    progress: float,
    current_step: str = None,
    plan_id: str = None,
    error_message: str = None,
    partition_info: dict = None,
):
    """
    Send a best-effort webhook notification to the backend.
    Catches all exceptions to avoid disrupting solver flow.
    """
    from config import SOLVER_WEBHOOK_ENABLED, SOLVER_WEBHOOK_URL

    if not SOLVER_WEBHOOK_ENABLED:
        return

    payload = {
        "job_id": job.job_id,
        "user_id": job.request.user_id,
        "status": status,
        "progress": round(progress, 1),
        "current_step": current_step,
        "plan_id": plan_id or job.plan_id,
        "error_message": error_message,
        "metadata": {
            "test_mode": job.request.test_mode,
            "num_demands": job.num_demands,
            "num_resources": job.num_resources,
            "estimated_seconds": job.estimated_seconds,
            "partition_info": partition_info,
            "websocket_url": job.websocket_url,
            "plan_range": {
                "start_date": job.request.plan_range.start_date,
                "end_date": job.request.plan_range.end_date,
            } if job.request.plan_range and not job.request.plan_range.is_empty() else None,
        },
    }

    try:
        async with httpx.AsyncClient(timeout=5.0) as client:
            resp = await client.post(SOLVER_WEBHOOK_URL, json=payload)
            logger.info(f"Webhook sent: status={status} progress={progress:.1f} -> HTTP {resp.status_code}")
    except Exception as e:
        logger.warning(f"Webhook failed (best-effort): {e}")


