"""
Total Cost Objective Analyzer
Analyzes cost performance by resource type (internal vs external)
"""
from .base_analyzer import ObjectiveAnalyzer
import sys
sys.path.append('../..')


class TotalCostAnalyzer(ObjectiveAnalyzer):
    """Analyzer for minimize_total_cost objective"""

    def __init__(self):
        super().__init__(
            objective_id='minimize_total_cost',
            objective_name='Minimize Total Cost'
        )

    def analyze_performance(self, solution, data, constraints):
        """
        Analyze cost performance based on internal vs external resource usage.

        Cost only accrues on DEMAND work — RT/CT rest days are not billable.
        Including them inflates the cost-weighted ratios. Filter to DEMAND.
        """
        # Get assignments - handle both attribute names for compatibility
        assignments = getattr(solution, 'solution_assignments', getattr(solution, 'assignments', []))
        demand_assignments = [a for a in assignments if a.get('assignment_type', 'DEMAND') == 'DEMAND']

        # Classify resources
        internal_resources = set()
        external_resources = set()

        for resource in data.resources:
            res_id = resource['resource_id']
            res_type = resource.get('type', 'internal').lower()

            if res_type in ['external', 'externe', 'ext']:
                external_resources.add(res_id)
            else:
                # Default to internal (includes 'internal', 'interne', 'int', and unknown)
                internal_resources.add(res_id)

        # Count DEMAND assignments by resource type
        internal_assignments = 0
        external_assignments = 0

        for assignment in demand_assignments:
            res_id = assignment['resource_id']
            if res_id in external_resources:
                external_assignments += 1
            else:
                internal_assignments += 1

        total_assignments = len(demand_assignments)
        
        # Calculate cost score (weighted)
        # Internal = 1.0 cost unit, External = 1.5 cost unit
        cost_score = (internal_assignments * 1.0) + (external_assignments * 1.5)
        
        # Calculate ratios
        internal_ratio = (internal_assignments / total_assignments * 100) if total_assignments > 0 else 0
        external_ratio = (external_assignments / total_assignments * 100) if total_assignments > 0 else 0
        
        # Achievement rate: 100% = all internal, scales down with more external
        # Best case: 100% internal (achievement = 100%)
        # Worst case: 100% external (achievement = 66.67% since external is 1.5x)
        if total_assignments > 0:
            best_cost = total_assignments * 1.0  # All internal
            current_cost = cost_score
            achievement_rate = (best_cost / current_cost) * 100
        else:
            achievement_rate = 100.0

        # Analyze gaps
        gaps = self.get_gap_details(solution, data, external_assignments, total_assignments)

        return {
            "objective_id": "minimize_total_cost",
            "objective_name": "Minimize Total Cost",
            "target_description": "Prefer internal resources over external resources",
            "achieved_value": cost_score,
            "max_possible_value": total_assignments * 1.0,  # Best case: all internal
            "achievement_rate": round(achievement_rate, 2),
            "performance_category": self.classify_performance(achievement_rate),
            "gaps": gaps,
            "metrics": {
                "total_assignments": total_assignments,
                "internal_assignments": internal_assignments,
                "external_assignments": external_assignments,
                "cost_score": round(cost_score, 2),
                "internal_ratio": round(internal_ratio, 2),
                "external_ratio": round(external_ratio, 2),
                "cost_multiplier": 1.5
            }
        }

    def get_gap_details(self, solution, data, external_assignments, total_assignments):
        """
        Analyze why external resources were used
        """
        gaps = []

        if external_assignments == 0:
            # Perfect - no external resources used
            return gaps

        external_percentage = (external_assignments / total_assignments * 100) if total_assignments > 0 else 0

        # Build gap report for external resource usage
        gaps.append({
            "gap_type": "EXTERNAL_RESOURCE_USAGE",
            "description": f"{external_assignments} assignments to external resources ({external_percentage:.1f}% of total)",
            "impact": f"Cost increase of {external_assignments * 0.5:.1f} units (50% premium on external resources)",
            "recommendations": self._generate_cost_recommendations(solution, data, external_percentage)
        })

        return gaps

    def _generate_cost_recommendations(self, solution, data, external_percentage):
        """Generate recommendations to reduce external resource usage"""
        recommendations = []

        if external_percentage > 50:
            recommendations.append(
                "CRITICAL: Over 50% of assignments use external resources - consider hiring more internal staff"
            )
        elif external_percentage > 25:
            recommendations.append(
                "HIGH PRIORITY: Significant external resource usage - evaluate internal capacity expansion"
            )
        elif external_percentage > 10:
            recommendations.append(
                "MODERATE: Some external resources used - review if internal resources can be better utilized"
            )
        else:
            recommendations.append(
                "LOW IMPACT: Minimal external resource usage - acceptable for peak demand coverage"
            )

        # Additional strategic recommendations
        recommendations.append(
            "Review qualification requirements - training internal staff may reduce external dependency"
        )
        
        recommendations.append(
            "Analyze external resource usage patterns - identify if concentrated on specific shifts/periods"
        )

        return recommendations
