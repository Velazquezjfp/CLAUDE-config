#!/bin/bash

echo "chmod -x deploy.sh"

# --- 1. Git Pull and Validation ---
echo "--- Checking for updates from Bitbucket ---"
GIT_OUTPUT=$(git pull 2>&1)
GIT_EXIT_CODE=$?

echo "$GIT_OUTPUT"

GIT_LOG_1=$(git log -1)
echo "###########################################"
echo "Last commit: $GIT_LOG_1"
echo "###########################################"

echo "chmod +x deploy.sh"

if [ $GIT_EXIT_CODE -ne 0 ]; then
    echo "------------------------------------------------"
    echo "❌ ERROR: Git pull failed. Deployment aborted."
    echo "Please check your SSH connection or local changes."
    echo "------------------------------------------------"
    exit 1
fi

# ============================================================================
# --- 1.5 Preserve-mode branch (additive, 2026-04-22) ---
# ============================================================================
# DEFAULT: PRESERVE postgres volume + data dir, rebuild images, apply
# idempotent migrations (./database/schema_*_add_*.sql + self-healing seeds).
#
# Opt-in destructive mode: pass --wipe (or -wipe) to fall through to the
# EXISTING destructive logic below (down -v + sudo rm -rf). Nothing in the
# existing deploy functions is modified by this patch.
#
# Migration files applied on every preserve run — all use IF NOT EXISTS /
# ON CONFLICT DO NOTHING so they are safe to re-run:
#   - schema_replannable_demand_types.sql         (Fix #7, self-healing RT+CT catalog)
#   - schema_solver_jobs_add_fetch_flags.sql      (Fix #16, fetch_rt/fetch_ct)
#   - schema_planner_assignments_add_category_priority.sql  (Fix #16, category_priority)
#
# Add new migration files to the MIGRATIONS array below. See
# /home/javiervel/clients/CFF/.claude/development_practices.md for the full
# schema-change checklist.
# ============================================================================

DEPLOY_MODE=preserve
ARGS_FILTERED=()
for _a in "$@"; do
    case "$_a" in
        --wipe|-wipe) DEPLOY_MODE=wipe ;;
        *)            ARGS_FILTERED+=("$_a") ;;
    esac
done

if [ "$DEPLOY_MODE" = "preserve" ]; then
    set -- "${ARGS_FILTERED[@]}"

    if [ $# -eq 0 ]; then
        echo "❌ Error: No environment specified."
        echo "Usage: ./deploy.sh -dev | -qa | -uat           (preserve mode — keeps data, applies migrations)"
        echo "       ./deploy.sh -qa --wipe                  (destructive mode — drops volumes + data dirs)"
        exit 1
    fi

    echo "------------------------------------------------"
    echo "PRESERVE MODE: keeps postgres volumes + data dirs."
    echo "Will rebuild images and apply idempotent migrations."
    echo "Target(s): $@"
    echo "------------------------------------------------"
    read -p "Proceed? (y/n): " CONFIRM
    if [[ ! $CONFIRM =~ ^[Yy]$ ]]; then
        echo "🚫 Deployment cancelled by user."
        exit 0
    fi

    # Preserve-mode deploy functions: down (NO -v), build (with cache), up.
    # Leaves volumes and data dirs untouched.
    preserve_dev() {
        echo "🚀 DEV (preserve): rebuild without wiping data..."
        docker compose -f docker-compose.yml down
        docker compose -f docker-compose.yml build
        docker compose -f docker-compose.yml --env-file .env up -d
    }
    preserve_qa() {
        echo "🚀 QA (preserve): rebuild without wiping data..."
        docker compose -f docker-compose.qa.yml down
        docker compose -f docker-compose.qa.yml build
        docker compose -f docker-compose.qa.yml --env-file .env.qa up -d
    }
    preserve_uat() {
        echo "🚀 UAT (preserve): rebuild without wiping data..."
        docker compose -f docker-compose.uat.yml down
        docker compose -f docker-compose.uat.yml build
        docker compose -f docker-compose.uat.yml --env-file .env.uat up -d
    }

    # Wait for postgres to accept SQL, then apply idempotent migrations.
    apply_migrations() {
        local pg_container=$1
        local label=$2
        local waited=0
        echo "  Waiting for $pg_container to accept SQL..."
        while [ $waited -lt 90 ]; do
            if docker exec "$pg_container" sh -c 'pg_isready -U "$POSTGRES_USER"' >/dev/null 2>&1; then
                break
            fi
            sleep 5
            waited=$((waited + 5))
        done
        if [ $waited -ge 90 ]; then
            echo "  ❌ $pg_container did not become ready; skipping $label migrations."
            return 1
        fi

        # Idempotent migration list. Append new files here as schema evolves.
        local MIGRATIONS=(
            "./database/schema_replannable_demand_types.sql"
            "./database/schema_solver_jobs_add_fetch_flags.sql"
            "./database/schema_planner_assignments_add_category_priority.sql"
        )
        local applied=0 failed=0
        for sql in "${MIGRATIONS[@]}"; do
            if [ ! -f "$sql" ]; then
                echo "    SKIP (missing file): $sql"
                continue
            fi
            local _out
            if _out=$(docker exec -i "$pg_container" \
                      sh -c 'psql -v ON_ERROR_STOP=1 -U "$POSTGRES_USER" -d "$POSTGRES_DB"' \
                      < "$sql" 2>&1); then
                echo "    ✓ $(basename "$sql")"
                applied=$((applied + 1))
            else
                echo "    ✗ $(basename "$sql") FAILED:"
                echo "$_out" | sed 's/^/        /'
                failed=$((failed + 1))
            fi
        done
        echo "  $label migrations: $applied applied, $failed failed."
    }

    ENVS_DONE=()
    for arg in "$@"; do
        case $arg in
            -dev) preserve_dev ; ENVS_DONE+=("dev") ;;
            -qa)  preserve_qa  ; ENVS_DONE+=("qa")  ;;
            -uat) preserve_uat ; ENVS_DONE+=("uat") ;;
            *)    echo "❓ Unknown argument: $arg" ; exit 1 ;;
        esac
    done

    echo ""
    echo "--- Applying idempotent migrations ---"
    for env in "${ENVS_DONE[@]}"; do
        case $env in
            dev) apply_migrations cff_postgres     "DEV" ;;
            qa)  apply_migrations cff_postgres_qa  "QA"  ;;
            uat) apply_migrations cff_postgres_uat "UAT" ;;
        esac
    done

    echo "🎉 All requested deployments are complete (preserve mode)."
    exit 0
fi

# --wipe fallthrough: restore original $@ (filtered) so existing arg parser
# below sees only -dev / -qa / -uat (no --wipe token).
set -- "${ARGS_FILTERED[@]}"

# --- 2. Argument and Confirmation Logic ---
if [ $# -eq 0 ]; then
    echo "❌ Error: No environment specified."
    echo "Usage: ./deploy.sh -dev | -qa | -uat | -dev -qa -uat"
    exit 1
fi

echo "------------------------------------------------"
echo "ATTENTION: You are about to deploy to: $@"
echo "This will DELETE database folders and REBUILD images."
echo "------------------------------------------------"
read -p "Are you sure you want to proceed? (y/n): " CONFIRM

if [[ ! $CONFIRM =~ ^[Yy]$ ]]; then
    echo "🚫 Deployment cancelled by user."
    exit 0
fi

# --- 3. Deployment Functions ---

deploy_dev() {
    echo "🚀 Starting DEV Deployment..."
    docker compose -f docker-compose.yml down -v
    sudo rm -rf ./data/postgres
    docker compose -f docker-compose.yml build --no-cache
    docker compose -f docker-compose.yml --env-file .env up -d
    echo "✅ DEV Deployment Finished."
}

deploy_qa() {
    echo "🚀 Starting QA Deployment..."
    docker compose -f docker-compose.qa.yml down -v
    sudo rm -rf ./data/postgres_qa
    docker compose -f docker-compose.qa.yml build --no-cache
    docker compose -f docker-compose.qa.yml --env-file .env.qa up -d
    echo "✅ QA Deployment Finished."
}

deploy_uat() {
    echo "🚀 Starting UAT Deployment..."
    docker compose -f docker-compose.uat.yml down -v
    sudo rm -rf ./data/postgres_uat
    docker compose -f docker-compose.uat.yml build --no-cache
    docker compose -f docker-compose.uat.yml --env-file .env.uat up -d
    echo "✅ UAT Deployment Finished."
}

# --- 4. Execution Loop ---
for arg in "$@"
do
    case $arg in
        -dev)
            deploy_dev
            ;;
        -qa)
            deploy_qa
            ;;
        -uat)
            deploy_uat
            ;;
        *)
            echo "❓ Unknown argument: $arg"
            exit 1
            ;;
    esac
done

echo "🎉 All requested deployments are complete."