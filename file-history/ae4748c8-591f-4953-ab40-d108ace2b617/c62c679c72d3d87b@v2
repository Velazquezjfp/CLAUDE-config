-- Fix #16 (2026-04-22) — Surface the resource's PRIMARY category on each
-- assignment row. This is the FIRST category in the resource's
-- resource_categories array — the category the resource is "supposed to"
-- be assigned to. Comparison with `resource_category` (the category
-- actually used for the assignment) lets callers tell at a glance whether
-- a resource was on their primary role.
--
--   resource_category:   the category fulfilled by THIS assignment
--                        (may be primary or secondary for the resource).
--                        NULL for RT/CT rest-day rows.
--   category_priority:   the resource's first/primary category.
--                        NON-NULL for every resource with a defined
--                        resource_categories array (including RT/CT rows).
--
-- Populated by the solver's save path (api/client.py::post_planner_assignments_bulk).
-- Idempotent via IF NOT EXISTS.

ALTER TABLE planner_assignments
    ADD COLUMN IF NOT EXISTS category_priority VARCHAR(100);

COMMENT ON COLUMN planner_assignments.category_priority IS
    'The resource primary category — resource_categories[0]. Comparison with '
    'resource_category shows whether the assignment used the resource primary '
    'role or a secondary one.';

CREATE INDEX IF NOT EXISTS idx_pa_category_priority
    ON planner_assignments(category_priority);
