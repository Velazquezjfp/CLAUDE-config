@dataclass
class ResourceState:
    """State for a single resource at partition boundary."""

    # LC-01: Weekly hours - hours worked in last 6 days
    hours_last_6_days: Dict[date, float] = field(default_factory=dict)

    # LC-04: Min rest - last shift end time
    last_shift_end: Optional[datetime] = None

    # LC-05: Weekend frequency - tracking
    last_free_weekend: Optional[date] = None
    weekends_worked_last_5_weeks: List[date] = field(default_factory=list)

    # LC-06: Consecutive nights - counter
    consecutive_night_count: int = 0
    last_night_shift_date: Optional[date] = None

    # LC-07: Monthly nights - night shifts in last 27 days
    night_shifts_last_27_days: Dict[date, int] = field(default_factory=dict)

    # OC-01: Annual category activity (YTD tracking)
    category_activity: CategoryActivityState = field(default_factory=CategoryActivityState)

    # BSA-ID category consistency - which category was used on each BSA-ID
    bsa_category_map: Dict[str, str] = field(default_factory=dict)  # {bsa_id: category}

    # LC-06: CT/RT rest-day counts per calendar month (for cross-partition target subtraction)
    # month_key = "YYYY-MM"
    rt_count_by_month: Dict[str, int] = field(default_factory=dict)
    ct_count_by_month: Dict[str, int] = field(default_factory=dict)

    # LC-06 × LC-05: Free weekends observed per month (for cross-partition coupling)
    # month_key = "YYYY-MM" (month of the Saturday)
    # value = list of (saturday_date, sunday_date) tuples
    free_weekend_by_month: Dict[str, List[tuple]] = field(default_factory=dict)

    # Fix #17 (2026-04-23): cross-partition overlap prevention.
    # Previously the within-partition LC-06 overlap constraint was the only
    # guard against RT/CT ↔ demand clashes; partition B could emit a demand
    # overlapping an RT anchored in partition A's tail because the RT var
    # doesn't exist in B's model. Both windows below carry UTC datetimes
    # keyed by the month of the WINDOW START (so a 12:00 → +24h window
    # spanning a month boundary lives in the earlier-month bucket).
    #
    # rest_day_windows_by_month: 24h rest intervals that this partition
    # allocated, so the NEXT partition can block demands overlapping them.
    # Value = list of (anchor_start_utc, anchor_end_utc) tuples.
    rest_day_windows_by_month: Dict[str, List[tuple]] = field(default_factory=dict)

    # assigned_demand_windows_by_month: demand assignments this partition
    # made, so the NEXT partition can forbid anchors whose 24h rest window
    # would overlap any of them. Value = list of (shift_start_utc,
    # shift_end_utc) tuples.
    assigned_demand_windows_by_month: Dict[str, List[tuple]] = field(default_factory=dict)

    def to_dict(self) -> Dict[str, Any]:
        """Serialize to dict for JSON storage."""
        return {
            'hours_last_6_days': {str(k): v for k, v in self.hours_last_6_days.items()},
            'last_shift_end': self.last_shift_end.isoformat() if self.last_shift_end else None,
            'last_free_weekend': str(self.last_free_weekend) if self.last_free_weekend else None,
            'weekends_worked_last_5_weeks': [str(d) for d in self.weekends_worked_last_5_weeks],
            'consecutive_night_count': self.consecutive_night_count,
            'last_night_shift_date': str(self.last_night_shift_date) if self.last_night_shift_date else None,
            'night_shifts_last_27_days': {str(k): v for k, v in self.night_shifts_last_27_days.items()},
            'category_activity': self.category_activity.to_dict(),
            'bsa_category_map': dict(self.bsa_category_map),
            'rt_count_by_month': dict(self.rt_count_by_month),
            'ct_count_by_month': dict(self.ct_count_by_month),
            'free_weekend_by_month': {
                mk: [[str(pair[0]), str(pair[1])] for pair in pairs]
                for mk, pairs in self.free_weekend_by_month.items()
            },
            # Fix #17: cross-partition overlap prevention windows (datetimes).
            'rest_day_windows_by_month': {
                mk: [[w[0].isoformat(), w[1].isoformat()] for w in windows]
                for mk, windows in self.rest_day_windows_by_month.items()
            },
            'assigned_demand_windows_by_month': {
                mk: [[w[0].isoformat(), w[1].isoformat()] for w in windows]
                for mk, windows in self.assigned_demand_windows_by_month.items()
            },
        }

    @classmethod
    def from_dict(cls, data: Dict[str, Any]) -> 'ResourceState':
        """Deserialize from dict."""
        state = cls()

        if data.get('hours_last_6_days'):
            state.hours_last_6_days = {
                date.fromisoformat(k): v
                for k, v in data['hours_last_6_days'].items()
            }

        if data.get('last_shift_end'):
            state.last_shift_end = _ensure_aware(datetime.fromisoformat(data['last_shift_end']))

        if data.get('last_free_weekend'):
            state.last_free_weekend = date.fromisoformat(data['last_free_weekend'])

        if data.get('weekends_worked_last_5_weeks'):
            state.weekends_worked_last_5_weeks = [
                date.fromisoformat(d) for d in data['weekends_worked_last_5_weeks']
            ]

        state.consecutive_night_count = data.get('consecutive_night_count', 0)

        if data.get('last_night_shift_date'):
            state.last_night_shift_date = date.fromisoformat(data['last_night_shift_date'])

        if data.get('night_shifts_last_27_days'):
            state.night_shifts_last_27_days = {
                date.fromisoformat(k): v
                for k, v in data['night_shifts_last_27_days'].items()
            }

        if data.get('category_activity'):
            state.category_activity = CategoryActivityState.from_dict(data['category_activity'])

        if data.get('bsa_category_map'):
            state.bsa_category_map = dict(data['bsa_category_map'])

        # LC-06 carryover fields. Missing keys are expected for state blobs
        # serialized before LC-06 landed — default to empty dicts.
        if data.get('rt_count_by_month'):
            state.rt_count_by_month = {k: int(v) for k, v in data['rt_count_by_month'].items()}
        if data.get('ct_count_by_month'):
            state.ct_count_by_month = {k: int(v) for k, v in data['ct_count_by_month'].items()}
        if data.get('free_weekend_by_month'):
            state.free_weekend_by_month = {}
            for mk, pairs in data['free_weekend_by_month'].items():
                parsed_pairs = []
                for pair in pairs:
                    try:
                        parsed_pairs.append(
                            (date.fromisoformat(pair[0]), date.fromisoformat(pair[1]))
                        )
                    except (ValueError, IndexError, TypeError):
                        continue
                if parsed_pairs:
                    state.free_weekend_by_month[mk] = parsed_pairs

        # Fix #17: rest_day + assigned_demand window carryover (UTC datetimes).
        for field_name in ('rest_day_windows_by_month', 'assigned_demand_windows_by_month'):
            if data.get(field_name):
                parsed: Dict[str, List[tuple]] = {}
                for mk, windows in data[field_name].items():
                    parsed_windows: List[tuple] = []
                    for w in windows:
                        try:
                            s = _ensure_aware(datetime.fromisoformat(w[0]))
                            e = _ensure_aware(datetime.fromisoformat(w[1]))
                            parsed_windows.append((s, e))
                        except (ValueError, IndexError, TypeError):
                            continue
                    if parsed_windows:
                        parsed[mk] = parsed_windows
                setattr(state, field_name, parsed)

        return state


@dataclass
class PartitionState:
    """
    State to carry forward between partitions.

    Tracks all rolling constraint state needed to ensure compliance
    across partition boundaries.
    """

    # Partition metadata
    partition_index: int = 0
    partition_start: Optional[date] = None
    partition_end: Optional[date] = None

    # Per-resource state
    resource_states: Dict[str, ResourceState] = field(default_factory=dict)

    # CP-02: External percentage tracking (global)
    total_assignments_so_far: int = 0
    external_assignments_so_far: int = 0

    # OC-01: Annual context for YTD tracking
    annual_context: AnnualContext = field(default_factory=AnnualContext)

    # Solution tracking
    previous_assignments: List[Dict[str, Any]] = field(default_factory=list)

    def get_resource_state(self, resource_id) -> ResourceState:
        """Get or create resource state. Normalizes ID to int for consistency with x_vars keys."""
        try:
            key = int(resource_id)
        except (ValueError, TypeError):
            key = resource_id
        if key not in self.resource_states:
            self.resource_states[key] = ResourceState()
        return self.resource_states[key]

    def get_hours_in_window(self, resource_id, window_start: date, window_days: int = 7) -> float:
        """
        Get total hours worked by resource in a date window.
        Used for LC-01 weekly hours constraint carryover.
        """
        state = self.get_resource_state(resource_id)
        total = 0.0
        for day_offset in range(window_days):
            check_date = window_start + timedelta(days=day_offset)
            total += state.hours_last_6_days.get(check_date, 0.0)
        return total

    def get_night_shifts_in_window(self, resource_id: str, window_start: date, window_days: int = 28) -> int:
        """
        Get total night shifts by resource in a date window.
        Used for LC-07 monthly nights constraint carryover.
        """
        state = self.get_resource_state(resource_id)
        total = 0
        for day_offset in range(window_days):
            check_date = window_start + timedelta(days=day_offset)
            total += state.night_shifts_last_27_days.get(check_date, 0)
        return total

    def get_external_percentage(self) -> float:
        """Get current external resource percentage."""
        if self.total_assignments_so_far == 0:
            return 0.0
        return (self.external_assignments_so_far / self.total_assignments_so_far) * 100

    def get_category_activity(self, resource_id: str, category: str,
                               activity_type: str = 'shifts') -> float:
        """
        Get accumulated category activity for a resource (OC-01).

        Args:
            resource_id: Resource ID
            category: Category name (e.g., 'protecteur', 'cvm')
            activity_type: 'shifts' or 'hours'

        Returns:
            Accumulated activity value (shifts count or hours)
        """
        res_state = self.resource_states.get(resource_id)
        if not res_state:
            return 0.0
        return res_state.category_activity.get_activity(category, activity_type)

    def get_bsa_category_map(self, resource_id) -> Dict[str, str]:
        """Get BSA-ID to category mapping from prior partition for a resource."""
        res_state = self.resource_states.get(resource_id)
        if not res_state:
            return {}
        return res_state.bsa_category_map

    def get_prior_activity_dict(self) -> Dict[str, Dict[str, float]]:
        """
        Get prior activity dict for OC-01 PeriodContext.

        Returns:
            Dict of {resource_id: {category: accumulated_value}}
        """
        result = {}
        for res_id, res_state in self.resource_states.items():
            cat_activity = res_state.category_activity
            activity = {}

            # Add shift-based categories
            if cat_activity.shifts_protecteur > 0:
                activity['protecteur'] = cat_activity.shifts_protecteur
            if cat_activity.shifts_chef_securite > 0:
                activity['chef sécurité'] = cat_activity.shifts_chef_securite

            # Add hour-based categories
            if cat_activity.hours_cvm > 0:
                activity['cvm'] = cat_activity.hours_cvm

            # Add any other tracked categories
            for cat, shifts in cat_activity.shifts_by_category.items():
                if cat not in activity and shifts > 0:
                    activity[cat] = shifts
            for cat, hours in cat_activity.hours_by_category.items():
                if cat not in activity and hours > 0:
                    activity[cat] = hours

            if activity:
                result[res_id] = activity

        return result

    def to_dict(self) -> Dict[str, Any]:
        """Serialize to dict for JSON storage."""
        return {
            'partition_index': self.partition_index,
            'partition_start': str(self.partition_start) if self.partition_start else None,
            'partition_end': str(self.partition_end) if self.partition_end else None,
            'resource_states': {
                rid: state.to_dict()
                for rid, state in self.resource_states.items()
            },
            'total_assignments_so_far': self.total_assignments_so_far,
            'external_assignments_so_far': self.external_assignments_so_far,
            'annual_context': self.annual_context.to_dict(),
            'previous_assignments_count': len(self.previous_assignments),
        }

    @classmethod
    def from_dict(cls, data: Dict[str, Any]) -> 'PartitionState':
        """Deserialize from dict."""
        state = cls()
        state.partition_index = data.get('partition_index', 0)

        if data.get('partition_start'):
            state.partition_start = date.fromisoformat(data['partition_start'])
        if data.get('partition_end'):
            state.partition_end = date.fromisoformat(data['partition_end'])

        if data.get('resource_states'):
            state.resource_states = {}
            for rid, rs_data in data['resource_states'].items():
                try:
                    key = int(rid)
                except (ValueError, TypeError):
                    key = rid
                state.resource_states[key] = ResourceState.from_dict(rs_data)

        state.total_assignments_so_far = data.get('total_assignments_so_far', 0)
        state.external_assignments_so_far = data.get('external_assignments_so_far', 0)

        if data.get('annual_context'):
            state.annual_context = AnnualContext.from_dict(data['annual_context'])

        return state

    def save(self, filepath: str):
        """Save state to JSON file."""
        with open(filepath, 'w') as f:
            json.dump(self.to_dict(), f, indent=2)

    @classmethod
    def load(cls, filepath: str) -> 'PartitionState':
        """Load state from JSON file."""
        with open(filepath, 'r') as f:
            data = json.load(f)
        return cls.from_dict(data)


def extract_state_from_solution(
    solution_assignments: List[Dict[str, Any]],
    resources_data: List[Dict[str, Any]],
    partition_end: date,
    previous_state: Optional[PartitionState] = None,
    partition_start: Optional[date] = None
) -> PartitionState:
    """
    Extract partition state from a solved partition's assignments.

    This extracts the constraint state needed for the next partition:
    - Last 6 days of hours per resource (LC-01)
    - Last shift end time per resource (LC-04)
    - Weekend work status (LC-05)
    - Consecutive night count (LC-06)
    - Night shifts in last 27 days (LC-07)
    - External percentage tracking (CP-02)
    - Category activity YTD (OC-01)

    Args:
        solution_assignments: List of assignments from solved partition
        resources_data: List of resource dicts with is_external flag
        partition_end: End date of the current partition
        previous_state: State from previous partition (if any)
        partition_start: Optional start date of partition (for annual context)

    Returns:
        PartitionState ready for next partition
    """
    from datetime import datetime, timedelta

    # Create new state, carrying forward previous state if exists
    state = PartitionState()
    if previous_state:
        state.partition_index = previous_state.partition_index + 1
        state.total_assignments_so_far = previous_state.total_assignments_so_far
        state.external_assignments_so_far = previous_state.external_assignments_so_far
        state.previous_assignments = previous_state.previous_assignments.copy()

        # Carry forward annual context
        state.annual_context = AnnualContext.from_dict(previous_state.annual_context.to_dict())

        # Carry forward ALL resource state from previous partition
        for res_id, prev_res_state in previous_state.resource_states.items():
            new_res_state = state.get_resource_state(res_id)
            # Copy all rolling state fields (will be updated/overwritten by current assignments)
            new_res_state.last_shift_end = prev_res_state.last_shift_end
            new_res_state.hours_last_6_days = dict(prev_res_state.hours_last_6_days)
            new_res_state.consecutive_night_count = prev_res_state.consecutive_night_count
            new_res_state.last_night_shift_date = prev_res_state.last_night_shift_date
            new_res_state.night_shifts_last_27_days = dict(prev_res_state.night_shifts_last_27_days)
            new_res_state.weekends_worked_last_5_weeks = list(prev_res_state.weekends_worked_last_5_weeks)
            new_res_state.last_free_weekend = prev_res_state.last_free_weekend
            new_res_state.category_activity = CategoryActivityState.from_dict(
                prev_res_state.category_activity.to_dict()
            )
            new_res_state.bsa_category_map = dict(prev_res_state.bsa_category_map)
            # LC-06 carryover (graceful if missing on older state blobs)
            new_res_state.rt_count_by_month = dict(getattr(prev_res_state, 'rt_count_by_month', {}) or {})
            new_res_state.ct_count_by_month = dict(getattr(prev_res_state, 'ct_count_by_month', {}) or {})
            new_res_state.free_weekend_by_month = {
                mk: list(pairs)
                for mk, pairs in (getattr(prev_res_state, 'free_weekend_by_month', {}) or {}).items()
            }
            # Fix #17: cross-partition overlap-prevention windows
            new_res_state.rest_day_windows_by_month = {
                mk: list(windows)
                for mk, windows in (getattr(prev_res_state, 'rest_day_windows_by_month', {}) or {}).items()
            }
            new_res_state.assigned_demand_windows_by_month = {
                mk: list(windows)
                for mk, windows in (getattr(prev_res_state, 'assigned_demand_windows_by_month', {}) or {}).items()
            }

    state.partition_end = partition_end
    if partition_start:
        state.partition_start = partition_start

    # Build resource lookup for is_external
    resource_is_external = {}
    for res in resources_data:
        res_id = str(res.get('resource_id', res.get('id', '')))
        resource_is_external[res_id] = res.get('is_external', False)

    # Process assignments
    boundary_start = partition_end - timedelta(days=27)  # Cover all rolling windows

    # For LC-06 free-weekend derivation: track which calendar dates have DEMAND
    # work per resource. RT/CT rows do NOT make a day "occupied" for LC-05
    # purposes (a weekend with only RT/CT is semantically a free weekend).
    demand_dates_by_resource: Dict[Any, set] = {}

    for assignment in solution_assignments:
        raw_id = assignment.get('resource_id', '')
        if not raw_id:
            continue
        # Store as int to match data.resource_ids type used in x_vars keys
        try:
            res_id = int(raw_id)
        except (ValueError, TypeError):
            res_id = raw_id

        res_state = state.get_resource_state(res_id)

        # Parse assignment times (solver uses 'start'/'end', API uses 'shift_start_time'/'shift_finish_time')
        start_str = assignment.get('start') or assignment.get('shift_start_time') or assignment.get('start_datetime')
        end_str = assignment.get('end') or assignment.get('shift_finish_time') or assignment.get('end_datetime')

        if not start_str or not end_str:
            continue

        try:
            if isinstance(start_str, str):
                start_dt = datetime.fromisoformat(start_str.replace('Z', '+00:00'))
            else:
                start_dt = start_str
            if isinstance(end_str, str):
                end_dt = datetime.fromisoformat(end_str.replace('Z', '+00:00'))
            else:
                end_dt = end_str
            # Ensure timezone-aware (DB returns naive timestamps)
            start_dt = _ensure_aware(start_dt)
            end_dt = _ensure_aware(end_dt)
        except (ValueError, TypeError):
            continue

        assignment_date = start_dt.date()
        duration_hours = (end_dt - start_dt).total_seconds() / 3600
        is_night = assignment.get('is_night_shift', False)
        assignment_type = (assignment.get('assignment_type') or 'DEMAND').upper()

        # LC-06: tally RT/CT rest-day rows by month. Do this BEFORE the
        # 27-day boundary gate because monthly carryover needs full-month
        # visibility regardless of where the rest day lies in the partition.
        if assignment_type in ('RT', 'CT'):
            month_key = f"{start_dt.year:04d}-{start_dt.month:02d}"
            if assignment_type == 'RT':
                res_state.rt_count_by_month[month_key] = (
                    res_state.rt_count_by_month.get(month_key, 0) + 1
                )
            else:
                res_state.ct_count_by_month[month_key] = (
                    res_state.ct_count_by_month.get(month_key, 0) + 1
                )
            # Fix #17: record the 24h rest window so the next partition
            # can block any demand that would overlap it.
            res_state.rest_day_windows_by_month.setdefault(month_key, []).append(
                (start_dt, end_dt)
            )
            # Rest rows don't contribute to any of the rolling-demand state below.
            state.previous_assignments.append(assignment)
            continue

        # Fix #17: record the demand window so the next partition can forbid
        # anchors whose 24h rest would overlap it.
        dem_month_key = f"{start_dt.year:04d}-{start_dt.month:02d}"
        res_state.assigned_demand_windows_by_month.setdefault(dem_month_key, []).append(
            (start_dt, end_dt)
        )

        # DEMAND row — record every calendar date the shift touches so we can
        # derive free-weekend status after the loop.
        demand_dates = demand_dates_by_resource.setdefault(res_id, set())
        cur_date = assignment_date
        end_date = end_dt.date()
        while cur_date <= end_date:
            demand_dates.add(cur_date)
            cur_date = cur_date + timedelta(days=1)

        # Only track state in the boundary window (last 27 days)
        if assignment_date >= boundary_start:
            # LC-01: Track hours (last 6 days)
            if assignment_date >= partition_end - timedelta(days=6):
                current = res_state.hours_last_6_days.get(assignment_date, 0.0)
                res_state.hours_last_6_days[assignment_date] = current + duration_hours

            # LC-04: Track last shift end
            if res_state.last_shift_end is None or end_dt > res_state.last_shift_end:
                res_state.last_shift_end = end_dt

            # LC-05: Track weekend work
            if assignment_date.weekday() >= 5:  # Saturday or Sunday
                if assignment_date not in res_state.weekends_worked_last_5_weeks:
                    res_state.weekends_worked_last_5_weeks.append(assignment_date)

            # LC-06: Track consecutive nights
            if is_night:
                if (res_state.last_night_shift_date is None or
                    assignment_date == res_state.last_night_shift_date + timedelta(days=1)):
                    res_state.consecutive_night_count += 1
                else:
                    res_state.consecutive_night_count = 1
                res_state.last_night_shift_date = assignment_date

            # LC-07: Track night shifts (last 27 days)
            if is_night:
                current = res_state.night_shifts_last_27_days.get(assignment_date, 0)
                res_state.night_shifts_last_27_days[assignment_date] = current + 1

        # CP-02: Track external assignments (all assignments)
        state.total_assignments_so_far += 1
        if resource_is_external.get(res_id, False):
            state.external_assignments_so_far += 1

        # OC-01: Track category activity (always, for YTD totals)
        resource_category = assignment.get('resource_category', '')
        if resource_category:
            # Track shift for shift-based categories
            res_state.category_activity.add_shift(resource_category)
            # Track hours for hour-based categories
            if duration_hours > 0:
                res_state.category_activity.add_hours(resource_category, duration_hours)

        # BSA category consistency: Track which category each resource used per BSA-ID
        bsa_id = assignment.get('bsa_id')
        if bsa_id and resource_category:
            res_state.bsa_category_map[str(bsa_id)] = resource_category

        # Store assignment for reference
        state.previous_assignments.append(assignment)

    # LC-06: derive free_weekend_by_month per resource from demand_dates.
    # A weekend (Sat+Sun) is "free" for a resource iff neither Sat nor Sun has
    # a DEMAND assignment. Weekends spanning outside the partition range are
    # skipped (not enough data to decide both days). Grouped by the Saturday's
    # calendar month.
    if partition_start is not None:
        scan_start = partition_start
        scan_end = partition_end
        # Walk every Saturday in [scan_start, scan_end]
        days_until_sat = (5 - scan_start.weekday()) % 7
        sat = scan_start + timedelta(days=days_until_sat)
        while sat <= scan_end:
            sun = sat + timedelta(days=1)
            if sun > scan_end:
                break  # incomplete weekend at range end
            month_key = f"{sat.year:04d}-{sat.month:02d}"
            # Determine set of all resources we might credit a free weekend to:
            # everyone who has ANY activity recorded OR exists in previous_state.
            # For correctness, we iterate every resource we've seen.
            for res_id, res_state in state.resource_states.items():
                demand_dates = demand_dates_by_resource.get(res_id, set())
                if sat in demand_dates or sun in demand_dates:
                    continue
                res_state.free_weekend_by_month.setdefault(month_key, [])
                pair = (sat, sun)
                if pair not in res_state.free_weekend_by_month[month_key]:
                    res_state.free_weekend_by_month[month_key].append(pair)
            sat = sat + timedelta(days=7)

    # Clean up old data outside relevant windows
    # Retain only the last ~2 full months of LC-06 month-keyed state. This
    # covers the worst case where the next partition spans a month whose
    # earlier portion was handled here.
    month_cutoff = partition_end - timedelta(days=62)
    month_cutoff_key = f"{month_cutoff.year:04d}-{month_cutoff.month:02d}"

    for res_id, res_state in state.resource_states.items():
        # Keep only last 6 days for hours
        cutoff_6d = partition_end - timedelta(days=6)
        res_state.hours_last_6_days = {
            d: h for d, h in res_state.hours_last_6_days.items()
            if d >= cutoff_6d
        }

        # Keep only last 5 weeks for weekend tracking
        cutoff_5w = partition_end - timedelta(weeks=5)
        res_state.weekends_worked_last_5_weeks = [
            d for d in res_state.weekends_worked_last_5_weeks
            if d >= cutoff_5w
        ]

        # Keep only last 27 days for night shifts
        cutoff_27d = partition_end - timedelta(days=27)
        res_state.night_shifts_last_27_days = {
            d: n for d, n in res_state.night_shifts_last_27_days.items()
            if d >= cutoff_27d
        }

        # Keep only the last ~2 months of LC-06 carryover
        res_state.rt_count_by_month = {
            mk: v for mk, v in res_state.rt_count_by_month.items() if mk >= month_cutoff_key
        }
        res_state.ct_count_by_month = {
            mk: v for mk, v in res_state.ct_count_by_month.items() if mk >= month_cutoff_key
        }
        res_state.free_weekend_by_month = {
            mk: v for mk, v in res_state.free_weekend_by_month.items() if mk >= month_cutoff_key
        }
        # Fix #17: window lists use the same 2-month retention. Only windows
        # starting near the partition boundary can affect the next partition
        # (anchors/demands further in the past have already closed out).
        res_state.rest_day_windows_by_month = {
            mk: v for mk, v in res_state.rest_day_windows_by_month.items() if mk >= month_cutoff_key
        }
        res_state.assigned_demand_windows_by_month = {
            mk: v for mk, v in res_state.assigned_demand_windows_by_month.items() if mk >= month_cutoff_key
        }

    # Update annual context
    if partition_start and partition_end:
        days_in_partition = (partition_end - partition_start).days + 1
        state.annual_context.days_processed += days_in_partition
        state.annual_context.planning_year = partition_end.year

        if state.annual_context.year_start is None:
            state.annual_context.year_start = partition_start
        state.annual_context.year_end = partition_end

    return state


def create_period_context_from_state(
    partition_state: PartitionState,
    partition_start: date,
    partition_end: date
) -> dict:
    """
    Create OC-01 PeriodContext data from partition state.

    This function creates the dictionary needed to initialize
    constraints.oc_01_min_category_activity.PeriodContext with
    prior activity from previous partitions.

    Args:
        partition_state: State from previous partition(s)
        partition_start: Start date of current partition
        partition_end: End date of current partition

    Returns:
        Dict with period_start, period_end, annual_fraction, prior_activity
    """
    from datetime import datetime

    # Calculate annual fraction for this partition
    days_in_partition = (partition_end - partition_start).days + 1
    annual_fraction = days_in_partition / 365.0

    # Get prior activity from partition state
    prior_activity = partition_state.get_prior_activity_dict()

    return {
        'period_start': datetime.combine(partition_start, datetime.min.time()),
        'period_end': datetime.combine(partition_end, datetime.min.time()),
        'annual_fraction': annual_fraction,
        'prior_activity': prior_activity
    }
