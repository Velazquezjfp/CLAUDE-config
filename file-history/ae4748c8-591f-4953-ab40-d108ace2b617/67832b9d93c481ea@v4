"""
LC-06 rest-day allocation: compute per-resource, per-month rest targets.

Used by the LC-06 hard constraint (Phase E) to enforce:
  - Min 4 RT (Jour de repos) per calendar month
  - Min 2 CT (Jour de compensation) per calendar month
  - Min 6 combined rest days per calendar month

When the planning range does not cover a full calendar month, targets are
prorated by ceil(N * fraction) so partial segments never require more rest
than is physically possible, but also never round down to zero unless the
segment is empty.

Carryover from prior partitions is subtracted (graceful degradation: if
partition_state is missing or empty for a resource/month, we log a warning
and use the full prorated target — never crash).

Source: BAR CCT via solver_v2/planner_dev/ct_rt_hard_constraint-2026-04-13.md
"""
from __future__ import annotations

import calendar
import logging
import math
from dataclasses import dataclass
from datetime import date, timedelta
from typing import Any, Dict, List, Optional

from config import (
    MIN_RT_PER_MONTH,
    MIN_CT_PER_MONTH,
    MIN_REST_DAYS_PER_MONTH,
)

logger = logging.getLogger(__name__)


@dataclass
class RestTarget:
    """Rest-day target for one resource × one calendar-month segment."""
    rt_required: int            # remaining RT days after carryover
    ct_required: int            # remaining CT days after carryover
    combined_required: int      # remaining RT+CT combined (safety net)
    segment_start: date         # first day of the segment (inclusive)
    segment_end: date           # last day of the segment (inclusive)
    is_full_month: bool         # True iff segment covers the full calendar month
    # Gross (pre-carryover) values — kept for logging/analyzer visibility
    rt_gross: int = 0
    ct_gross: int = 0
    combined_gross: int = 0
    prior_rt: int = 0
    prior_ct: int = 0


def _month_segments(planning_start: date, planning_end: date) -> List[tuple]:
    """Decompose [planning_start, planning_end] into per-calendar-month segments.

    Returns a list of (segment_start, segment_end, month_key) tuples where
    month_key is "YYYY-MM". Both dates are inclusive.
    """
    if planning_end < planning_start:
        return []

    segments = []
    cur = planning_start
    while cur <= planning_end:
        last_day_of_month = calendar.monthrange(cur.year, cur.month)[1]
        month_end = date(cur.year, cur.month, last_day_of_month)
        seg_end = min(month_end, planning_end)
        month_key = f"{cur.year:04d}-{cur.month:02d}"
        segments.append((cur, seg_end, month_key))
        # Advance to first day of next month
        cur = month_end + timedelta(days=1)
    return segments


def _prorate(target: int, fraction: float) -> int:
    """Prorate a full-month target by fraction, rounding up (ceil).

    ceil ensures a partial month with even a single day keeps a minimum of 1
    required rest day for each target (not rounded down to 0). Callers are
    responsible for calling with 0 <= fraction <= 1.
    """
    if fraction <= 0:
        return 0
    if fraction >= 1:
        return target
    return int(math.ceil(target * fraction))


def compute_rest_targets(
    planning_start: date,
    planning_end: date,
    resource_ids: List[str],
    partition_state=None,
    full_plan_start: Optional[date] = None,
    full_plan_end: Optional[date] = None,
    locked_free_weekends: Optional[Dict[Any, List[Any]]] = None,
) -> Dict[str, Dict[str, RestTarget]]:
    """Compute rest targets per (resource_id, month_key).

    Args:
        planning_start: first day of THIS partition's planning range (inclusive)
        planning_end:   last day of THIS partition's planning range (inclusive)
        resource_ids:   list of resource IDs in scope
        partition_state: optional PartitionState (from solver.partition_state).
                         When present, the per-resource ResourceState.rt_count_by_month
                         and ct_count_by_month attributes are consulted to subtract
                         carryover from prior partitions of the same month.
        full_plan_start: (Fix #15, 2026-04-22) the FULL plan range's first day,
                         across ALL partitions. Used to compute cumulative
                         proration (see below). If None, defaults to planning_start
                         (i.e., pre-Fix-#15 behavior).
        full_plan_end:   same idea for the end. Defaults to planning_end.

    Proration semantics (Fix #15):
        Target for a (resource, month) segment is computed as the CUMULATIVE
        target from the start of plan coverage of the month through seg_end,
        not the per-partition fraction. This ensures the final partition
        covering a month sees the full-month target minus prior allocations,
        avoiding undercount across partition boundaries.

        Before Fix #15 (still behavior when full_plan_* are None):
            fraction = days_in_segment / days_in_full_month

        After Fix #15:
            fraction = (seg_end - earliest_plan_day_in_month) / days_in_full_month
            where earliest_plan_day_in_month is:
              - full_plan_start.day if plan starts in this month, else 1

        Example: for plan [Apr 27 - May 30] split across 3 partitions covering
        May [1-3], [1-19], [20-30]:
            Partition 3's May seg_end=May 30 → cumulative_days=30 → gross=4.
            After carryover subtracts 3 (from P1+P2), required=1. Correct.
        Pre-Fix-#15 gave P3 a prorated gross of only 2 (11 days), which after
        subtracting 3 clamped to 0, producing a silent shortfall.

    Returns:
        {resource_id: {month_key: RestTarget}} where month_key is "YYYY-MM".
    """
    if isinstance(planning_start, str) or isinstance(planning_end, str):
        raise TypeError("compute_rest_targets expects date objects, not strings")

    # Fix #15: fall back to per-partition bounds when full-plan bounds aren't
    # supplied. This preserves behavior for non-partitioned callers and
    # analyzers that already pass the full plan range as planning_start/end.
    if full_plan_start is None:
        full_plan_start = planning_start
    if full_plan_end is None:
        full_plan_end = planning_end

    segments = _month_segments(planning_start, planning_end)
    if not segments:
        logger.warning(
            f"[LC-06] Empty planning range ({planning_start}..{planning_end}) — "
            f"no rest targets generated"
        )
        return {resource_id: {} for resource_id in resource_ids}

    # Per-resource ResourceState lookup (graceful: may be None or empty)
    resource_states = {}
    if partition_state is not None:
        resource_states = getattr(partition_state, 'resource_states', {}) or {}

    results: Dict[str, Dict[str, RestTarget]] = {}

    for resource_id in resource_ids:
        rs = resource_states.get(resource_id)
        if partition_state is not None and rs is None:
            # Partition state exists but this resource is missing (e.g., first
            # partition this resource appears in, or new hire). Not an error —
            # carryover is simply zero.
            logger.debug(f"[LC-06] resource {resource_id}: no prior partition state")

        results[resource_id] = {}

        for seg_start, seg_end, month_key in segments:
            days_in_full_month = calendar.monthrange(seg_start.year, seg_start.month)[1]

            # Fix #15: cumulative proration.
            # Determine the earliest plan-covered day-of-month for this month.
            # If the FULL plan starts in this month, cumulative starts from
            # full_plan_start.day. Otherwise (plan extends before this month),
            # cumulative starts from day 1.
            if (full_plan_start.year == seg_start.year
                    and full_plan_start.month == seg_start.month):
                month_cum_start_day = full_plan_start.day
            else:
                month_cum_start_day = 1
            cumulative_days = seg_end.day - month_cum_start_day + 1
            # Safety: cumulative should not exceed plan_end coverage of the month
            if (full_plan_end.year == seg_start.year
                    and full_plan_end.month == seg_start.month):
                cumulative_cap_end = full_plan_end.day
            else:
                cumulative_cap_end = days_in_full_month
            # Clamp cumulative_days to the plan's actual coverage of this month.
            plan_month_span = cumulative_cap_end - month_cum_start_day + 1
            cumulative_days = min(cumulative_days, plan_month_span)
            fraction = cumulative_days / days_in_full_month

            # is_full_month now means "plan covers the entire calendar month"
            # (so full-month gross target applies). With cumulative semantics,
            # the last partition covering such a month will naturally have
            # cumulative_days == days_in_full_month and reach the full target.
            month_first = date(seg_start.year, seg_start.month, 1)
            month_last = date(seg_start.year, seg_start.month, days_in_full_month)
            is_full_month = (full_plan_start <= month_first and month_last <= full_plan_end)

            if fraction >= 1.0:
                rt_gross = MIN_RT_PER_MONTH
                ct_gross = MIN_CT_PER_MONTH
                combined_gross = MIN_REST_DAYS_PER_MONTH
            else:
                rt_gross = _prorate(MIN_RT_PER_MONTH, fraction)
                ct_gross = _prorate(MIN_CT_PER_MONTH, fraction)
                combined_gross = _prorate(MIN_REST_DAYS_PER_MONTH, fraction)

            # Carryover subtraction — graceful degradation
            prior_rt = 0
            prior_ct = 0
            if rs is not None:
                rt_map = getattr(rs, 'rt_count_by_month', None)
                ct_map = getattr(rs, 'ct_count_by_month', None)
                if rt_map is None and ct_map is None:
                    # Partition state predates LC-06 wiring. Use full targets.
                    logger.warning(
                        f"[LC-06] resource {resource_id} month {month_key}: "
                        f"partition state has no rt/ct carryover fields — "
                        f"using full prorated targets"
                    )
                else:
                    prior_rt = int((rt_map or {}).get(month_key, 0))
                    prior_ct = int((ct_map or {}).get(month_key, 0))

            # Fix #17-J (2026-04-23): pre-credit LC-05 locked weekend days as
            # RT rest days toward this month's target. The pre-allocator
            # decided globally that these Sat+Sun are "free weekends"; those
            # 2 days DO count as monthly rest per BAR CCT. We convention-
            # assign them as RT (not CT). Without this pre-credit, LC-06
            # would emit a shortfall penalty for the same days twice (once
            # per partition seeing them).
            locked_credit = 0
            if locked_free_weekends:
                # Resource-id lookup is type-tolerant (key can be int or str)
                r_key_variants = (resource_id, int(resource_id)) if not isinstance(resource_id, int) else (resource_id, str(resource_id))
                r_locks = None
                for _k in r_key_variants:
                    r_locks = locked_free_weekends.get(_k)
                    if r_locks:
                        break
                if r_locks:
                    for w in r_locks:
                        sat = getattr(w, 'sat', None) if not isinstance(w, dict) else w.get('sat')
                        sun = getattr(w, 'sun', None) if not isinstance(w, dict) else w.get('sun')
                        if isinstance(sat, str):
                            try: sat = date.fromisoformat(sat)
                            except (ValueError, TypeError): sat = None
                        if isinstance(sun, str):
                            try: sun = date.fromisoformat(sun)
                            except (ValueError, TypeError): sun = None
                        # Count Sat and Sun that fall in THIS month segment
                        for d in (sat, sun):
                            if d is not None and seg_start <= d <= seg_end:
                                locked_credit += 1

            rt_required = max(0, rt_gross - prior_rt - locked_credit)
            ct_required = max(0, ct_gross - prior_ct)
            combined_required = max(0, combined_gross - prior_rt - prior_ct - locked_credit)

            results[resource_id][month_key] = RestTarget(
                rt_required=rt_required,
                ct_required=ct_required,
                combined_required=combined_required,
                segment_start=seg_start,
                segment_end=seg_end,
                is_full_month=is_full_month,
                rt_gross=rt_gross,
                ct_gross=ct_gross,
                combined_gross=combined_gross,
                prior_rt=prior_rt,
                prior_ct=prior_ct,
            )

    # Summary log (aggregate, not per-resource to avoid log spam)
    if results and segments:
        first_resource = next(iter(results))
        sample = results[first_resource]
        logger.info(
            f"[LC-06] Rest targets computed: {len(resource_ids)} resources × "
            f"{len(segments)} month segment(s). "
            f"Sample (resource={first_resource}): "
            + ", ".join(
                f"{mk}=[rt={rt.rt_required}/{rt.rt_gross}, "
                f"ct={rt.ct_required}/{rt.ct_gross}, "
                f"comb={rt.combined_required}/{rt.combined_gross}, "
                f"full_month={rt.is_full_month}]"
                for mk, rt in sample.items()
            )
        )

    return results
