-- Planner Output Table
-- Stores the results from the solver/planner, including assignments and metadata
-- This table is in the INTERNAL database (parameters DB)

CREATE TABLE IF NOT EXISTS planner_output (
    output_id SERIAL PRIMARY KEY,
    plan_id VARCHAR(50) NOT NULL,
    status VARCHAR(20) NOT NULL DEFAULT 'PENDING',
    objective_value BIGINT,
    solve_time_seconds DECIMAL(12,6),
    solver_timestamp TIMESTAMP WITH TIME ZONE,
    num_requests INTEGER DEFAULT 0,
    num_resources INTEGER DEFAULT 0,
    num_violations INTEGER DEFAULT 0,
    assignments JSONB NOT NULL DEFAULT '[]'::jsonb,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT valid_status CHECK (status IN ('PENDING', 'FEASIBLE', 'OPTIMAL', 'INFEASIBLE', 'ERROR'))
);

-- Indexes for performance
CREATE INDEX IF NOT EXISTS idx_planner_output_plan_id ON planner_output(plan_id);
CREATE INDEX IF NOT EXISTS idx_planner_output_status ON planner_output(status);
CREATE INDEX IF NOT EXISTS idx_planner_output_created ON planner_output(created_at DESC);

-- Comments
COMMENT ON TABLE planner_output IS 'Stores solver/planner output results including assignments and metadata';
COMMENT ON COLUMN planner_output.plan_id IS 'Unique identifier for the planning run';
COMMENT ON COLUMN planner_output.status IS 'Solver status: PENDING, FEASIBLE, OPTIMAL, INFEASIBLE, ERROR';
COMMENT ON COLUMN planner_output.objective_value IS 'Objective function value from solver';
COMMENT ON COLUMN planner_output.solve_time_seconds IS 'Time taken to solve in seconds';
COMMENT ON COLUMN planner_output.assignments IS 'JSONB array of resource assignments with request_id, resource_id, start, end, duration_hours';
COMMENT ON COLUMN planner_output.num_requests IS 'Total number of requests/demands processed';
COMMENT ON COLUMN planner_output.num_resources IS 'Total number of resources available';
COMMENT ON COLUMN planner_output.num_violations IS 'Number of constraint violations in solution';
