"""
Planner Output router - CRUD operations for solver/planner results
Connects to INTERNAL database (parameters DB)

Note: The list endpoint excludes assignments for performance.
Use /{output_id} or /plan/{plan_id} to get full details with assignments.
"""
from fastapi import APIRouter, Depends, HTTPException, Query, status
from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import text
from typing import Optional
import math
import json

from database import get_internal_db
from models import PaginatedResponse


router = APIRouter(prefix="/planner-output", tags=["Planner Output"])


@router.get("/", response_model=PaginatedResponse)
async def list_planner_outputs(
    page: int = Query(1, ge=1, description="Page number"),
    per_page: int = Query(50, ge=1, le=200, description="Items per page"),
    status_filter: Optional[str] = Query(None, description="Filter by status (PENDING, FEASIBLE, OPTIMAL, INFEASIBLE, ERROR)"),
    plan_id: Optional[str] = Query(None, description="Filter by plan ID"),
    user_id: Optional[str] = Query(None, description="Filter by user ID (via solver_jobs link)"),
    db: AsyncSession = Depends(get_internal_db),
):
    """
    List all planner outputs with pagination and optional filters.

    **Performance note:** This endpoint returns summary data without assignments.
    Use `GET /{output_id}` or `GET /plan/{plan_id}` to retrieve full details including assignments.

    **Filters:**
    - `status_filter`: Filter by solver status
    - `plan_id`: Filter by exact plan ID
    - `user_id`: Filter by user (via JOIN to solver_jobs on job_id)
    """
    try:
        offset = (page - 1) * per_page

        # Build WHERE clause dynamically
        where_clauses = []
        params = {"limit": per_page, "offset": offset}

        if status_filter:
            where_clauses.append("po.status = :status_filter")
            params["status_filter"] = status_filter

        if plan_id:
            where_clauses.append("po.plan_id = :plan_id")
            params["plan_id"] = plan_id

        if user_id:
            where_clauses.append("sj.user_id = :user_id")
            params["user_id"] = user_id

        where_sql = f"WHERE {' AND '.join(where_clauses)}" if where_clauses else ""

        from_sql = "FROM planner_output po LEFT JOIN solver_jobs sj ON po.job_id = sj.job_id"

        # Count total
        count_query = text(f"SELECT COUNT(*) as total {from_sql} {where_sql}")
        count_result = await db.execute(count_query, params)
        total = count_result.scalar()

        # Fetch planner outputs - EXCLUDES assignments JSONB for performance
        # but includes num_assignments (total), num_demand_assignments (coverage),
        # and coverage_percentage.
        #
        # coverage_percentage measures DEMAND coverage only — RT/CT rest-day
        # rows are NOT counted in the numerator (they're not demand coverage).
        # Rows with a missing `assignment_type` are treated as DEMAND for
        # backward-compat with pre-Phase-H runs.
        query = text(f"""
            SELECT
                po.output_id, po.job_id, po.plan_id, po.status, po.objective_value, po.solve_time_seconds,
                po.solver_timestamp, po.num_requests, po.num_resources, po.num_violations,
                po.fetch_rt, po.fetch_ct,
                jsonb_array_length(po.assignments) AS num_assignments,
                (SELECT COUNT(*) FROM jsonb_array_elements(po.assignments) elem
                    WHERE COALESCE(elem->>'assignment_type', 'DEMAND') = 'DEMAND') AS num_demand_assignments,
                CASE WHEN po.num_requests > 0
                    THEN ROUND(
                        (SELECT COUNT(*)::numeric FROM jsonb_array_elements(po.assignments) elem
                            WHERE COALESCE(elem->>'assignment_type', 'DEMAND') = 'DEMAND')
                        / po.num_requests * 100, 2)
                    ELSE 0
                END AS coverage_percentage,
                sj.user_id,
                sj.plan_start_date, sj.plan_end_date,
                po.created_at
            {from_sql}
            {where_sql}
            ORDER BY po.created_at DESC
            LIMIT :limit OFFSET :offset
        """)

        result = await db.execute(query, params)
        rows = result.fetchall()

        outputs = [dict(row._mapping) for row in rows]

        total_pages = math.ceil(total / per_page) if total > 0 else 0

        return PaginatedResponse(
            total=total,
            page=page,
            per_page=per_page,
            total_pages=total_pages,
            data=outputs,
        )

    except Exception as e:
        raise HTTPException(
            status_code=500,
            detail=f"Error fetching planner outputs: {str(e)}",
        )


@router.get("/{output_id}")
async def get_planner_output(
    output_id: int,
    db: AsyncSession = Depends(get_internal_db),
):
    """
    Get a single planner output by ID.

    Returns full details including assignments.
    """
    try:
        query = text("""
            SELECT
                po.output_id, po.job_id, po.plan_id, po.status, po.objective_value, po.solve_time_seconds,
                po.solver_timestamp, po.num_requests, po.num_resources, po.num_violations,
                po.fetch_rt, po.fetch_ct,
                po.assignments, sj.user_id,
                sj.plan_start_date, sj.plan_end_date,
                po.created_at
            FROM planner_output po
            LEFT JOIN solver_jobs sj ON po.job_id = sj.job_id
            WHERE po.output_id = :output_id
        """)

        result = await db.execute(query, {"output_id": output_id})
        row = result.fetchone()

        if not row:
            raise HTTPException(
                status_code=404,
                detail=f"Planner output with ID {output_id} not found",
            )

        return dict(row._mapping)

    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(
            status_code=500,
            detail=f"Error fetching planner output: {str(e)}",
        )


@router.get("/plan/{plan_id}")
async def get_planner_outputs_by_plan_id(
    plan_id: str,
    db: AsyncSession = Depends(get_internal_db),
):
    """
    Get all planner outputs for a specific plan ID.

    Returns full details including assignments.
    This is the recommended endpoint for viewing plan results.
    """
    try:
        # /plan/{plan_id}: full record (assignments JSONB included) plus the
        # same computed num_assignments / num_demand_assignments /
        # coverage_percentage columns the LIST endpoint exposes. Prior version
        # omitted them, so /plan/{plan_id} always returned these as null.
        query = text("""
            SELECT
                po.output_id, po.job_id, po.plan_id, po.status, po.objective_value, po.solve_time_seconds,
                po.solver_timestamp, po.num_requests, po.num_resources, po.num_violations,
                po.fetch_rt, po.fetch_ct,
                po.assignments,
                jsonb_array_length(po.assignments) AS num_assignments,
                (SELECT COUNT(*) FROM jsonb_array_elements(po.assignments) elem
                    WHERE COALESCE(elem->>'assignment_type', 'DEMAND') = 'DEMAND') AS num_demand_assignments,
                CASE WHEN po.num_requests > 0
                    THEN ROUND(
                        (SELECT COUNT(*)::numeric FROM jsonb_array_elements(po.assignments) elem
                            WHERE COALESCE(elem->>'assignment_type', 'DEMAND') = 'DEMAND')
                        / po.num_requests * 100, 2)
                    ELSE 0
                END AS coverage_percentage,
                sj.user_id,
                sj.plan_start_date, sj.plan_end_date,
                po.created_at
            FROM planner_output po
            LEFT JOIN solver_jobs sj ON po.job_id = sj.job_id
            WHERE po.plan_id = :plan_id
            ORDER BY po.created_at DESC
        """)

        result = await db.execute(query, {"plan_id": plan_id})
        rows = result.fetchall()

        return [dict(row._mapping) for row in rows]

    except Exception as e:
        raise HTTPException(
            status_code=500,
            detail=f"Error fetching planner outputs by plan ID: {str(e)}",
        )


@router.post("/", status_code=201)
async def create_planner_output(
    output: dict,
    db: AsyncSession = Depends(get_internal_db),
):
    """
    Create a new planner output in internal database.

    **Required fields:** plan_id, status, assignments
    **Optional fields:** job_id (links to solver_jobs table)
    """
    try:
        # Validate required fields
        if "plan_id" not in output or not output["plan_id"]:
            raise HTTPException(
                status_code=400,
                detail="Missing required field: plan_id",
            )
        if "status" not in output or not output["status"]:
            raise HTTPException(
                status_code=400,
                detail="Missing required field: status",
            )
        if "assignments" not in output:
            raise HTTPException(
                status_code=400,
                detail="Missing required field: assignments",
            )

        # Validate status value
        valid_statuses = ["PENDING", "FEASIBLE", "OPTIMAL", "INFEASIBLE", "ERROR"]
        if output["status"] not in valid_statuses:
            raise HTTPException(
                status_code=400,
                detail=f"Invalid status. Must be one of: {', '.join(valid_statuses)}",
            )

        # Convert assignments to JSON string
        assignments_json = json.dumps(output.get("assignments"))

        insert_query = text("""
            INSERT INTO planner_output (
                job_id, plan_id, status, objective_value, solve_time_seconds, solver_timestamp,
                num_requests, num_resources, num_violations, assignments,
                fetch_rt, fetch_ct
            ) VALUES (
                :job_id, :plan_id, :status, :objective_value, :solve_time_seconds, :solver_timestamp,
                :num_requests, :num_resources, :num_violations, CAST(:assignments AS jsonb),
                :fetch_rt, :fetch_ct
            )
            RETURNING *
        """)

        result = await db.execute(
            insert_query,
            {
                "job_id": output.get("job_id"),  # Optional - links to solver_jobs
                "plan_id": output.get("plan_id"),
                "status": output.get("status"),
                "objective_value": output.get("objective_value"),
                "solve_time_seconds": output.get("solve_time_seconds"),
                "solver_timestamp": output.get("solver_timestamp"),
                "num_requests": output.get("num_requests", 0),
                "num_resources": output.get("num_resources", 0),
                "num_violations": output.get("num_violations", 0),
                "assignments": assignments_json,
                # Default TRUE → FE fetches RT/CT from external DB. Solver sets FALSE when it replans.
                "fetch_rt": bool(output.get("fetch_rt", True)),
                "fetch_ct": bool(output.get("fetch_ct", True)),
            },
        )

        await db.commit()
        row = result.fetchone()
        return dict(row._mapping)

    except HTTPException:
        raise
    except Exception as e:
        await db.rollback()
        raise HTTPException(
            status_code=500,
            detail=f"Error creating planner output: {str(e)}",
        )


@router.delete("/{output_id}", status_code=204)
async def delete_planner_output(
    output_id: int,
    db: AsyncSession = Depends(get_internal_db),
):
    """
    Delete a planner output from internal database.
    """
    try:
        # Check if output exists
        check_query = text("SELECT output_id FROM planner_output WHERE output_id = :output_id")
        check_result = await db.execute(check_query, {"output_id": output_id})
        if not check_result.fetchone():
            raise HTTPException(
                status_code=404,
                detail=f"Planner output with ID {output_id} not found",
            )

        delete_query = text("DELETE FROM planner_output WHERE output_id = :output_id")
        await db.execute(delete_query, {"output_id": output_id})
        await db.commit()

        return None

    except HTTPException:
        raise
    except Exception as e:
        await db.rollback()
        raise HTTPException(
            status_code=500,
            detail=f"Error deleting planner output: {str(e)}",
        )
