    def analyze(self):
        """
        Generate comprehensive analysis report

        Returns:
            Dict with complete analysis including:
            - metadata (status, solve time, etc.)
            - constraint_violations (detailed per constraint)
            - objective_performance (achievement rates, gaps)
            - recommendations (actionable insights)
            - summary (executive overview)
        """
        report = {
            'metadata': self._generate_metadata(),
            'constraint_violations': self._analyze_constraints(),
            'objective_performance': self._analyze_objectives(),
            'summary': {}  # Will be generated after other sections
        }

        # Generate summary based on analysis results
        report['summary'] = self._generate_summary(report)

        return report

    def _generate_metadata(self):
        """Generate report metadata"""
        from ortools.sat.python import cp_model

        status_names = {
            4: "OPTIMAL",
            2: "FEASIBLE",
            3: "INFEASIBLE",
            0: "UNKNOWN"
        }

        # Get assignments - handle both attribute names for compatibility
        assignments = getattr(self.solution, 'solution_assignments', getattr(self.solution, 'assignments', []))

        return {
            'timestamp': datetime.now().isoformat(),
            'status': status_names.get(self.solution.status, "UNKNOWN"),
            'status_code': self.solution.status,
            'objective_value': getattr(self.solution, 'objective_value', None),
            'solve_time_seconds': getattr(self.solution, 'solve_time', None),
            'total_assignments': len(assignments),
            'total_requests': len(self.data.request_ids),
            'total_resources': len(self.data.resource_ids),
            'enabled_constraints': ENABLED_CONSTRAINTS,
            'enabled_objectives': list(self.objective_analyzers.keys())
        }

    def _analyze_constraints(self):
        """
        Analyze all enabled constraints

        Returns:
            Dict mapping constraint_name -> analysis results
        """
        results = {}

        for constraint_name in ENABLED_CONSTRAINTS:
            if constraint_name in self.constraint_analyzers:
                analyzer = self.constraint_analyzers[constraint_name]

                # Get violation metadata from solution
                violation_metadata = getattr(self.solution, 'violation_metadata', [])

                results[constraint_name] = analyzer.analyze_violations(
                    self.solution,
                    self.data,
                    self.constraints,
                    violation_metadata
                )

        return results

    def _analyze_objectives(self):
        """
        Analyze all objectives (always active - weights control impact)

        Returns:
            Dict mapping objective_name -> performance analysis
        """
        results = {}

        # All objectives are always analyzed (weights control their impact)
        for objective_name, analyzer in self.objective_analyzers.items():
            try:
                results[objective_name] = analyzer.analyze_performance(
                    self.solution,
                    self.data,
                    self.constraints
                )
            except Exception as e:
                # Log error but continue with other objectives
                print(f"  Warning: {objective_name} analysis failed: {e}")
                results[objective_name] = {
                    "objective_id": objective_name,
                    "error": str(e),
                    "achievement_rate": 0,
                    "performance_category": "ERROR"
                }

        return results

    def _generate_summary(self, report):
        """
        Generate executive summary

        Args:
            report: Full analysis report

        Returns:
            Dict with key metrics and overall assessment
        """
        # Coverage metrics
        coverage_rate = 0
        if 'maximize_coverage' in report['objective_performance']:
            coverage_rate = report['objective_performance']['maximize_coverage']['achievement_rate']

        # Workload balance metrics
        workload_variance = 0
        workload_rate = 0
        if 'balance_workload' in report['objective_performance']:
            workload_metrics = report['objective_performance']['balance_workload']
            workload_rate = workload_metrics['achievement_rate']
            workload_variance = workload_metrics['metrics'].get('variance', 0)

        # Violation metrics
        total_violations = sum(
            result.get('total_violations', 0)
            for result in report['constraint_violations'].values()
        )

        total_violation_amount = sum(
            result.get('total_violation_amount', 0)
            for result in report['constraint_violations'].values()
        )

        # Constraint-specific metrics
        affected_resources = set()
        for result in report['constraint_violations'].values():
            if 'detailed_violations' in result:
                for detail in result['detailed_violations']:
                    affected_resources.add(detail['resource_id'])

        # Overall status assessment
        status = self._classify_overall_status(
            coverage_rate,
            workload_rate,
            total_violations,
            total_violation_amount
        )

        # Use coverage metrics from the CoverageAnalyzer (respects team filtering)
        coverage_metrics = {}
        if 'maximize_coverage' in report['objective_performance']:
            cm = report['objective_performance']['maximize_coverage']['metrics']
            coverage_metrics = {
                'rate': round(coverage_rate, 2),
                'category': self._classify_rate(coverage_rate),
                'requests_covered': cm['covered_requests'],
                'requests_total': cm['total_requests'],
                'requests_uncovered': cm['uncovered_requests'],
            }
            # Include overall stats when team-filtered
            if 'team_targeted_requests' in cm:
                coverage_metrics['team_targeted_requests'] = cm['team_targeted_requests']
                coverage_metrics['overall_total_requests'] = cm['overall_total_requests']
        else:
            coverage_metrics = {
                'rate': 0,
                'category': self._classify_rate(0),
                'requests_covered': report['metadata']['total_assignments'],
                'requests_total': report['metadata']['total_requests'],
                'requests_uncovered': report['metadata']['total_requests'] - report['metadata']['total_assignments'],
            }

        # 2026-04-21: surface Phase J (LC-06 CT/RT compliance) alerts into
        # analysis_summary so FE + summariser-agent see them via
        # /solver/status/{job_id}. Structured `ct_rt_compliance` + bounded
        # alerts list. Top-line strings also injected into key_insights.
        ct_rt_compliance = self._build_ct_rt_compliance_summary(report)

        insights = self._generate_key_insights(report)
        recommendations = self._generate_top_recommendations(report)
        if ct_rt_compliance and ct_rt_compliance['alerts_total'] > 0:
            insights.append(
                f"CT/RT compliance: {ct_rt_compliance['alerts_total']} alert(s) "
                f"(RT={ct_rt_compliance['by_kind'].get('RT',0)}, "
                f"CT={ct_rt_compliance['by_kind'].get('CT',0)}) — "
                "resources under target and not marked replannable"
            )
            if ct_rt_compliance.get('sample_message'):
                recommendations.append(ct_rt_compliance['sample_message'])

        return {
            'overall_status': status,
            'coverage': coverage_metrics,
            'workload_balance': {
                'rate': round(workload_rate, 2),
                'category': self._classify_rate(workload_rate),
                'variance_hours': round(workload_variance, 2)
            },
            'violations': {
                'total_count': total_violations,
                'total_amount_hours': round(total_violation_amount, 2),
                'affected_resources': len(affected_resources),
                'severity': self._classify_violation_severity(total_violations, total_violation_amount)
            },
            'ct_rt_compliance': ct_rt_compliance,
            'key_insights': insights,
            'top_recommendations': recommendations,
        }

    def _build_ct_rt_compliance_summary(self, report):
        """Summarize Phase J ct_rt_compliance_alerts for inclusion in
        analysis_summary. Returns a dict with counts + bounded alerts list,
        or None if the LC_08 analyzer didn't run.

        Bounded to 50 alerts in `alerts` to keep the status response light.
        Full list still lives in report['constraint_violations']['LC_08_monthly_rest_v2']['ct_rt_compliance_alerts'].
        """
        lc08 = report.get('constraint_violations', {}).get('LC_08_monthly_rest_v2')
        if not lc08:
            return None
        alerts = lc08.get('ct_rt_compliance_alerts') or []

        from collections import Counter
        kind_counts = Counter(a.get('kind', '?') for a in alerts)
        # Determine overall severity from the alert stream — default NONE if
        # empty, WARNING if any present, HIGH if many (>50) per resource-month.
        if not alerts:
            severity = 'NONE'
        elif any(a.get('severity') == 'HIGH' for a in alerts):
            severity = 'HIGH'
        else:
            severity = 'WARNING'

        # First alert with a user-facing message (for top_recommendations)
        sample_message = next(
            (a.get('message') for a in alerts if a.get('message') and a.get('severity') != 'INFO'),
            None
        )

        # Bound the embedded alerts list to 50 to keep status response light
        capped = alerts[:50]

        return {
            'alerts_total': len(alerts),
            'by_kind': dict(kind_counts),
            'severity': severity,
            'alerts_truncated': len(alerts) > len(capped),
            'alerts': capped,
            'sample_message': sample_message,
        }

    def _classify_overall_status(self, coverage_rate, workload_rate, total_viols, total_viol_amount):
        """Classify overall solution status"""
        if coverage_rate >= 95 and workload_rate >= 90 and total_viol_amount < 50:
            return "EXCELLENT"
        elif coverage_rate >= 80 and workload_rate >= 70 and total_viol_amount < 150:
            return "GOOD"
        elif coverage_rate >= 60 or workload_rate >= 50:
            return "ACCEPTABLE"
        else:
            return "NEEDS IMPROVEMENT"

    def _classify_rate(self, rate):
        """Classify achievement rate"""
        if rate >= 95:
            return "EXCELLENT"
        elif rate >= 80:
            return "GOOD"
        elif rate >= 60:
            return "FAIR"
        else:
            return "POOR"

    def _classify_violation_severity(self, count, amount):
        """Classify violation severity"""
        if count == 0 and amount == 0:
            return "NONE"
        elif count < 20 and amount < 30:
            return "LOW"
        elif count < 50 and amount < 100:
            return "MEDIUM"
        else:
            return "HIGH"

    def _generate_key_insights(self, report):
        """
        Generate consolidated key insights as simple strings.
        Aggregates related findings instead of listing each separately.

        Returns list of strings (FE-compatible format).
        """
        insights = []

        # Get key metrics
        uncovered = 0
        cat_gaps = 0
        qual_gaps = 0
        idle_resources = 0

        if 'maximize_coverage' in report['objective_performance']:
            uncovered = report['objective_performance']['maximize_coverage']['metrics'].get('uncovered_requests', 0)

        if 'balance_workload' in report['objective_performance']:
            idle_resources = report['objective_performance']['balance_workload']['metrics'].get('idle_resources', 0)

        if 'CP_02_qualification_matching' in report['constraint_violations']:
            cp02 = report['constraint_violations']['CP_02_qualification_matching']
            cat_gaps = cp02.get('category_gaps', {}).get('total_gaps', 0)
            qual_gaps = cp02.get('qualification_gaps', {}).get('total_gaps', 0)

        # 1. Consolidated coverage insight (combines multiple root causes)
        if uncovered > 0:
            capacity_gaps = uncovered - cat_gaps - qual_gaps
            parts = []
            if cat_gaps > 0:
                parts.append(f"{cat_gaps} by missing categories")
            if qual_gaps > 0:
                parts.append(f"{qual_gaps} by missing qualifications")
            if capacity_gaps > 0:
                parts.append(f"{capacity_gaps} by capacity/constraint limits")

            if parts:
                insights.append(f"{uncovered} requests uncovered: {', '.join(parts)}")
            else:
                insights.append(f"{uncovered} requests uncovered - check qualification gaps and capacity constraints")

        # 2. Consolidated idle resources insight (link to root cause)
        if idle_resources > 0:
            if cat_gaps > 0 or qual_gaps > 0:
                insights.append(f"{idle_resources} resources idle - qualification mismatch with uncovered requests (solving skill gaps will address this)")
            else:
                insights.append(f"{idle_resources} resources idle - potential capacity underutilization")

        # 3. Geographic imbalance (aggregate locations)
        if 'minimize_travel_cost' in report['objective_performance']:
            travel = report['objective_performance']['minimize_travel_cost']
            location_gaps = []
            for gap in travel.get('gaps', []):
                if gap.get('gap_type') == 'LOCATION_IMBALANCE':
                    # Extract location info from recommendations
                    for rec in gap.get('recommendations', []):
                        if 'Add resources to location' in str(rec):
                            location_gaps.append(rec)

            if location_gaps:
                # Parse locations from recommendations
                locations = []
                for rec in location_gaps[:3]:  # Top 3
                    # Extract location code and demand from recommendation text
                    if isinstance(rec, str) and 'demand:' in rec:
                        try:
                            loc = rec.split('location ')[1].split(' (')[0]
                            demand = rec.split('demand: ')[1].split(',')[0]
                            locations.append(f"{loc} ({demand})")
                        except:
                            pass
                if locations:
                    insights.append(f"Geographic imbalance: {', '.join(locations)} have demand but no local resources")

        # 4. Constraint violations (only if any)
        total_violations = sum(
            result.get('total_violations', 0)
            for result in report['constraint_violations'].values()
        )
        if total_violations > 0:
            total_amount = sum(
                result.get('total_violation_amount', 0)
                for result in report['constraint_violations'].values()
            )
            insights.append(f"{total_violations} constraint violations ({total_amount:.1f}h over limits)")

        return insights[:5]  # Limit to 5 most important

    def _generate_top_recommendations(self, report):
        """
        Generate aggregated, prioritized recommendations.
        Groups by root cause, removes duplicates, suppresses generic advice.

        Returns list of recommendation objects (FE-compatible format).
        """
        recommendations = []

        # =====================================================================
        # 1. SKILL GAPS - Aggregate all missing categories into one recommendation
        # =====================================================================
        if 'CP_02_qualification_matching' in report['constraint_violations']:
            cp02 = report['constraint_violations']['CP_02_qualification_matching']

            # Aggregate category gaps
            category_details = []
            total_category_blocked = 0
            if cp02.get('recommendations'):
                for rec in cp02['recommendations']:
                    if rec.get('type') == 'CATEGORY_EXPANSION':
                        # Extract category name and count
                        action = rec.get('action', '')
                        impact = rec.get('impact', '')
                        affected = rec.get('affected_requests', [])

                        # Parse category from action
                        if "category '" in action:
                            try:
                                cat_name = action.split("category '")[1].split("'")[0]
                                blocked_count = len(affected)
                                total_category_blocked += blocked_count
                                category_details.append({
                                    'category': cat_name,
                                    'blocked': blocked_count,
                                    'requests': affected
                                })
                            except:
                                pass

            if category_details:
                # Sort by impact (most blocked first)
                category_details.sort(key=lambda x: x['blocked'], reverse=True)
                recommendations.append({
                    'type': 'SKILL_GAPS',
                    'priority': 'HIGH',
                    'action': 'Add missing resource categories (hire or cross-train)',
                    'impact': f"Unlocks {total_category_blocked} requests",
                    'details': category_details[:5]  # Top 5 categories
                })

            # Aggregate training opportunities (quick wins)
            training_details = []
            for rec in cp02.get('recommendations', []):
                if rec.get('type') == 'TRAINING':
                    action = rec.get('action', '')
                    impact = rec.get('expected_impact', '')
                    # Parse resource and skill
                    if 'Train ' in action and ' on ' in action:
                        try:
                            parts = action.split('Train ')[1]
                            resource_id = parts.split(' on ')[0]
                            skill = parts.split(' on ')[1].strip("[]'")
                            # Parse request from impact
                            request_id = None
                            if 'coverage of ' in impact:
                                request_id = impact.split('coverage of ')[1]
                            training_details.append({
                                'resource': resource_id,
                                'train_on': skill,
                                'unlocks_request': request_id
                            })
                        except:
                            pass

            if training_details:
                recommendations.append({
                    'type': 'QUICK_WIN',
                    'priority': 'HIGH',
                    'action': f"Train {len(training_details)} resource(s) on missing qualifications",
                    'impact': f"Unlocks {len(training_details)} request(s) immediately",
                    'details': training_details[:3]  # Top 3
                })

        # =====================================================================
        # 2. LOCATION IMBALANCE - Aggregate all location gaps
        # =====================================================================
        if 'minimize_travel_cost' in report['objective_performance']:
            travel = report['objective_performance']['minimize_travel_cost']
            location_details = []

            for gap in travel.get('gaps', []):
                if gap.get('gap_type') == 'LOCATION_IMBALANCE':
                    for rec in gap.get('recommendations', []):
                        if isinstance(rec, str) and 'Add resources to location' in rec:
                            try:
                                loc = rec.split('location ')[1].split(' (')[0]
                                demand_str = rec.split('demand: ')[1].split(',')[0]
                                supply_str = rec.split('supply: ')[1].split(')')[0]
                                location_details.append({
                                    'location': loc,
                                    'demand': int(demand_str),
                                    'supply': int(supply_str)
                                })
                            except:
                                pass

            if location_details:
                total_demand = sum(l['demand'] for l in location_details)
                location_details.sort(key=lambda x: x['demand'], reverse=True)
                recommendations.append({
                    'type': 'LOCATION_IMBALANCE',
                    'priority': 'HIGH',
                    'action': 'Add resources to underserved locations',
                    'impact': f"Unlocks up to {total_demand} requests",
                    'details': location_details[:5]
                })

        # =====================================================================
        # 3. WORKLOAD BALANCE - Single consolidated recommendation
        # =====================================================================
        if 'balance_workload' in report['objective_performance']:
            wl = report['objective_performance']['balance_workload']
            idle_count = wl['metrics'].get('idle_resources', 0)
            overload_hours = 0

            for gap in wl.get('gaps', []):
                if gap.get('gap_type') == 'WORKLOAD_OVERLOAD':
                    # Extract hours from description
                    desc = gap.get('impact', '')
                    if 'excess workload:' in desc.lower():
                        try:
                            overload_hours = float(desc.split(':')[1].replace('h', '').strip())
                        except:
                            pass

            if overload_hours > 0 or idle_count > 0:
                # Only add if skill gaps recommendation exists, note that solving skills will help
                has_skill_gaps = any(r.get('type') == 'SKILL_GAPS' for r in recommendations)
                if has_skill_gaps and idle_count > 0:
                    recommendations.append({
                        'type': 'WORKLOAD_NOTE',
                        'priority': 'LOW',
                        'action': f'{idle_count} idle resources will become utilized once skill gaps (above) are resolved',
                        'impact': 'No separate action needed'
                    })
                elif overload_hours > 0:
                    recommendations.append({
                        'type': 'WORKLOAD_BALANCE',
                        'priority': 'MEDIUM',
                        'action': f'Redistribute {overload_hours:.0f}h from overloaded to underutilized resources',
                        'impact': 'Improves workload balance'
                    })

        # =====================================================================
        # 4. TEAM CONTINUITY - Single consolidated recommendation
        # =====================================================================
        if 'maximize_team_continuity' in report['objective_performance']:
            team = report['objective_performance']['maximize_team_continuity']
            fragmented_groups = []

            for gap in team.get('gaps', []):
                if gap.get('gap_type') in ['NO_CONTINUITY', 'HIGH_FRAGMENTATION']:
                    for rec in gap.get('recommendations', []):
                        if isinstance(rec, str) and 'Group ' in rec and 'different resources' in rec:
                            fragmented_groups.append(rec)

            if fragmented_groups:
                recommendations.append({
                    'type': 'CONTINUITY',
                    'priority': 'LOW',
                    'action': 'Increase team_continuity objective weight > 2.0',
                    'impact': f'Reduces fragmentation in {len(fragmented_groups)} group(s)'
                })

        # =====================================================================
        # Sort by priority and return
        # =====================================================================
        priority_order = {'HIGH': 0, 'MEDIUM': 1, 'LOW': 2}
        recommendations.sort(key=lambda x: priority_order.get(x.get('priority', 'LOW'), 2))

        return recommendations
