class SolutionAnalyzer:
    """
    Main orchestrator for post-solve analysis

    Coordinates all constraint and objective analyzers to provide:
    - Detailed violation analysis
    - Objective performance metrics
    - Gap analysis
    - Actionable recommendations
    """

    def __init__(self, solution, data, constraints):
        """
        Initialize analyzer with solution data

        Args:
            solution: Solver solution with assignments and violation_metadata
            data: PreprocessedData object with requests/resources
            constraints: ConstraintValues object with limits
        """
        self.solution = solution
        self.data = data
        self.constraints = constraints

        # Initialize constraint analyzers
        self.constraint_analyzers = {
            # Existing analyzers
            'HC_01_absence_blocking': HC_01_Analyzer(),
            'HC_01_contract_type': HC_01_ContractTypeAnalyzer(),
            'LC_01_max_weekly_hours': LC_01_Analyzer(),
            'LC_02_max_daily_hours_14h_span': LC_02_Analyzer(),
            'LC_03_max_absolute_daily_hours': LC_03_Analyzer(),
            'LC_04_max_continuous_work': LC_04_Analyzer(),
            'CP_02_qualification_matching': CP_02_Analyzer(),
            # New P0 analyzers (Phase 2B)
            'LC_04_min_rest_between_shifts': LC_04_MinRestAnalyzer(),
            'LC_05_weekend_frequency': LC_05_WeekendAnalyzer(),
            'LC_06_consecutive_nights': LC_06_ConsecutiveNightsAnalyzer(),
            'LC_07_monthly_nights': LC_07_MonthlyNightsAnalyzer(),
            'LC_08_monthly_rest': LC_08_MonthlyRestAnalyzer(),
            # LC_08_v2 is the active version in ENABLED_CONSTRAINTS; route it
            # through the same analyzer so Phase J's CT/RT compliance check runs.
            'LC_08_monthly_rest_v2': LC_08_MonthlyRestAnalyzer(),
            'HC_04_locked_planning': HC_04_LockedAnalyzer(),
            'HC_IR_ER_matching': HC_IR_ER_Analyzer(),
            'HC_05_function_doubling': HC_05_FunctionDoublingAnalyzer(),
            # Operational constraints (TIME-FRAME SENSITIVE)
            'OC_01_min_category_activity': OC_01_Analyzer(),
            # DISABLED: 'CP_02_external_percentage': CP_02_ExternalPercentageAnalyzer(),
        }

        # Initialize objective analyzers (all 9 objectives - always active)
        self.objective_analyzers = {
            'maximize_coverage': CoverageAnalyzer(),
            'balance_workload': WorkloadAnalyzer(),
            'minimize_legal_violations': LegalViolationsAnalyzer(),
            'minimize_policy_violations': PolicyViolationsAnalyzer(),
            'minimize_overtime_cost': OvertimeCostAnalyzer(),
            'minimize_total_cost': TotalCostAnalyzer(),
            'minimize_travel_cost': TravelCostAnalyzer(),
            'minimize_idle_time': IdleTimeAnalyzer(),
            'maximize_team_continuity': TeamContinuityAnalyzer(),
            'maintain_function_continuity': FunctionContinuityAnalyzer(),
            'maintain_shift_continuity': ShiftContinuityAnalyzer(),
            'main_competencies_priority': MainCompetenciesAnalyzer(),
