"""
LC-06: Rest Days Allocation (HARD CONSTRAINT)

Enforces minimum RT (Jour de repos) and CT (Jour de compensation) rest days
per calendar month per resource:
  - min 4 RT per full month
  - min 2 CT per full month
  - min 6 combined (RT + CT) per full month
Partial months are prorated (ceil of fraction) by Phase D (rest_targets).

Source: BAR CCT via solver_v2/planner_dev/ct_rt_hard_constraint-2026-04-13.md

Activation: this module is only invoked when `rt_replannable` or
`ct_replannable` is True. When neither is True the solver does not
decide rest days — the external assignments table's existing RT/CT blocks
remain authoritative and are enforced as absences via LC-08 v2 fallback.

Anchor rules (for the 24h rest interval associated with each (resource, day)):
  FIX #17 (2026-04-23) — flexible multi-anchor model.
  - Each (r, d) gets up to len(LC_06_ANCHOR_OFFSETS) candidate rest-day
    variables, one per anchor hour (e.g. 0, 6, 12, 13, 18). The solver
    picks at most one per (r, d). A small penalty in LC_06_ANCHOR_PENALTY
    biases toward midnight (0) but lets the solver pick a later anchor
    when midnight would overlap a demand.
  - Priority 1 — partition carryover: on day 0, if
    `incoming_state.resource_states[r].last_shift_end` is within the 24h
    immediately preceding midnight of day 0, the standard anchor set is
    REPLACED with a single carryover anchor (h_key=-1) at the exact
    last_shift_end datetime. Yields AZG-aligned rest like 13:00→13:00
    spanning the partition boundary.
  - Overlap with demands is checked PER ANCHOR. Each anchor window
    [anchor_start, anchor_start+24h] excludes any x[r, req] that
    overlaps it.

Related:
  - LC-04 enforces 12h rest between any two demand shifts (pairwise).
  - LC-05 enforces one free weekend per 5-week sliding window; its
    `free_weekend_vars` are coupled here so that a chosen free weekend
    counts toward the monthly rest quota.
  - LC-08 v2 remains enabled as a safety-net combined-rest check when
    LC-06 is not active for a given resource (see Phase K).

Return-type change (Fix #17): rt_vars / ct_vars keys are now 3-tuples
`(resource_id, day, anchor_hour_key)`. anchor_hour_key is an int from
config.LC_06_ANCHOR_OFFSETS (typically 0/6/12/13/18), or the sentinel
-1 for Priority-1 carryover. Callers that read these vars must iterate
the 3-tuple keys and look up anchor_start via `model.lc_06_anchor_map`.
"""
from __future__ import annotations

import logging
from datetime import date, datetime, time, timedelta, timezone
from typing import Any, Dict, List, Optional, Tuple

from ortools.sat.python import cp_model

logger = logging.getLogger(__name__)

# Sentinel anchor-hour key for Priority-1 carryover. Chosen outside the
# valid hour range [0, 23] so it never collides with a real anchor.
CARRYOVER_ANCHOR_KEY = -1


def add_rest_days_constraints(
    model: cp_model.CpModel,
    x_vars: Dict[Tuple[str, Any], Any],
    data,
    constraints,
    rest_targets: Dict[str, Dict[str, Any]],
    lc_05_free_weekend_vars: Optional[Dict[Tuple, Any]] = None,
    prior_free_weekends: Optional[Dict[str, Dict[str, List[Tuple[date, date]]]]] = None,
    rt_replannable: bool = True,
    ct_replannable: bool = True,
    incoming_state=None,
    all_resource_ids: Optional[List] = None,
    locked_free_weekends: Optional[Dict[Any, List[Any]]] = None,
) -> Tuple[Dict[Tuple[str, date, int], Any], Dict[Tuple[str, date, int], Any], list, list]:
    """Add LC-06 rest-day allocation constraints to the CP-SAT model.

    Args:
        model: the CP-SAT model under construction.
        x_vars: existing assignment variables {(resource_id, request_id): BoolVar}.
        data: PreprocessedData — supplies planning_start, planning_end,
              resource_ids, and the requests list (with shift_start_time /
              shift_finish_time strings).
        constraints: ConstraintValues (accepted for interface parity; LC-06
                     uses hardcoded targets from config.py — 4/2/6).
        rest_targets: output of Phase D's compute_rest_targets.
        lc_05_free_weekend_vars: dict keyed by (resource_id, (sat_dt, sun_dt))
                                  with values being LC-05 free-weekend BoolVars.
                                  Optional — absent means no LC-05 coupling.
        prior_free_weekends: dict {resource_id: {month_key: [(sat_date, sun_date), ...]}}
                              carried over from prior partitions.
        rt_replannable: if False, no `rt[r,d,h]` variables are created.
        ct_replannable: if False, no `ct[r,d,h]` variables are created.
        incoming_state: optional PartitionState for Priority-1 anchor carryover.
        all_resource_ids: optional full plan-range resource ID list (team-filtered
                          but NOT category-filtered). When provided, LC-06
                          enforces rest-day minimums on ALL these resources
                          (Fix #14, 2026-04-22). When omitted or None, falls back
                          to data.resource_ids — the partition's category-filtered
                          subset, which was the pre-Fix-#14 behavior and could
                          drop resources from LC-06 scope silently.

    Returns:
        (rt_vars, ct_vars, violations, metadata). rt_vars/ct_vars are
        3-tuple-keyed: {(resource_id, date, anchor_hour): BoolVar}. Empty dicts
        when the corresponding flag is False. violations is always [] (hard
        constraint). metadata is a list of dicts for analyzer visibility.
    """
    rt_vars: Dict[Tuple[str, date, int], Any] = {}
    ct_vars: Dict[Tuple[str, date, int], Any] = {}
    violations: list = []
    metadata: list = []

    if not (rt_replannable or ct_replannable):
        logger.info("[LC_06] Skipped (neither rt_replannable nor ct_replannable).")
        return rt_vars, ct_vars, violations, metadata

    if not rest_targets:
        logger.warning("[LC_06] rest_targets is empty — no constraints added.")
        return rt_vars, ct_vars, violations, metadata

    # Fix #17: load anchor config. Fallback to single-midnight behavior if
    # config missing (defensive; should always be present).
    try:
        from config import LC_06_ANCHOR_OFFSETS as _anchor_offsets
        from config import LC_06_ANCHOR_PENALTY as _anchor_penalty
    except ImportError:
        _anchor_offsets = [0]
        _anchor_penalty = {0: 0}
    standard_anchors: List[int] = [int(h) for h in _anchor_offsets]
    anchor_penalty: Dict[int, int] = {int(k): int(v) for k, v in _anchor_penalty.items()}

    # Fix #14: resolve the LC-06 resource scope. Prefer the caller-supplied
    # full list (team-filtered but not category-filtered); fall back to the
    # partition's filtered list for backward compatibility.
    lc06_resource_ids = all_resource_ids if all_resource_ids is not None else list(data.resource_ids)
    if all_resource_ids is not None and len(lc06_resource_ids) != len(data.resource_ids):
        logger.info(
            f"[LC_06] Scope: {len(lc06_resource_ids)} in-scope resources "
            f"(partition's category-filtered demand scope is {len(data.resource_ids)}; "
            f"LC-06 covers {len(lc06_resource_ids) - len(data.resource_ids)} additional "
            f"resource(s) that have no demand match here but still need monthly rest)"
        )

    # --- Derive planning-day list (date objects, inclusive) ---
    planning_start_dt = _to_utc(getattr(data, 'planning_start', None))
    planning_end_dt = _to_utc(getattr(data, 'planning_end', None))
    if planning_start_dt is None or planning_end_dt is None:
        logger.error("[LC_06] data.planning_start / planning_end not available — aborting LC-06.")
        return rt_vars, ct_vars, violations, metadata

    start_day = planning_start_dt.date()
    end_day = planning_end_dt.date()
    planning_days: List[date] = []
    cur = start_day
    while cur <= end_day:
        planning_days.append(cur)
        cur = cur + timedelta(days=1)
    planning_days_set = set(planning_days)

    logger.info(
        f"[LC_06] Adding rest-day allocation: rt_replannable={rt_replannable}, "
        f"ct_replannable={ct_replannable}, days={len(planning_days)}, "
        f"resources={len(lc06_resource_ids)}, anchors={standard_anchors}"
    )

    # --- Parse demand shift times once ---
    request_times: Dict[Any, Tuple[datetime, datetime]] = {}
    for req in data.requests:
        req_id = req.get('id')
        s = _parse_demand_datetime(req.get('shift_start_time'))
        e = _parse_demand_datetime(req.get('shift_finish_time'))
        if s and e and req_id is not None:
            request_times[req_id] = (s, e)

    # --- Pre-compute anchors per (resource, day) -------------------------
    # Fix #17 model:
    #   - day_anchor_hours[(r, d)] = list of h keys valid for that cell
    #   - anchor_starts[(r, d, h)] = the UTC datetime where the 24h rest
    #     interval begins for that (r, d, h) tuple
    #
    # Priority 1 (day 0 carryover): when last_shift_end falls in the 24h
    # preceding midnight of day 0, REPLACE the standard anchor set with a
    # single carryover anchor (h_key = CARRYOVER_ANCHOR_KEY) pinned to the
    # exact last_shift_end datetime. This yields AZG-aligned rest like
    # 13:30→13:30 spanning the partition boundary; subsequent days use the
    # standard anchor set.
    day_anchor_hours: Dict[Tuple[str, date], List[int]] = {}
    anchor_starts: Dict[Tuple[str, date, int], datetime] = {}
    priority1_applied = 0
    resource_states = getattr(incoming_state, 'resource_states', {}) if incoming_state else {}
    for r in lc06_resource_ids:
        for idx, d in enumerate(planning_days):
            midnight_d = datetime.combine(d, time(0, 0), tzinfo=timezone.utc)
            applied_p1 = False

            if idx == 0 and r in resource_states:
                rs = resource_states[r]
                last_end = getattr(rs, 'last_shift_end', None)
                if last_end is not None:
                    if last_end.tzinfo is None:
                        last_end = last_end.replace(tzinfo=timezone.utc)
                    if midnight_d - timedelta(hours=24) <= last_end <= midnight_d:
                        day_anchor_hours[(r, d)] = [CARRYOVER_ANCHOR_KEY]
                        anchor_starts[(r, d, CARRYOVER_ANCHOR_KEY)] = last_end
                        priority1_applied += 1
                        applied_p1 = True

            if not applied_p1:
                day_anchor_hours[(r, d)] = list(standard_anchors)
                for h in standard_anchors:
                    anchor_starts[(r, d, h)] = datetime.combine(
                        d, time(h, 0), tzinfo=timezone.utc
                    )
    if priority1_applied:
        logger.info(f"[LC_06] Priority-1 anchor applied to {priority1_applied} resource(s) on day 0")

    # --- Fix #17-J (2026-04-23): build lookup of pre-allocated rest dates ---
    # Days in this dict are GLOBALLY pre-allocated as LC-05 free weekends.
    # LC-06 skips variable creation + coupling on these days (they're already
    # rest by construction via x_vars=0 forcing and pre-credited in
    # compute_rest_targets). This is what breaks the cross-partition
    # infeasibility cascade empirically proven by Probe C.
    locked_dates_by_resource: Dict[Any, set] = {}
    if locked_free_weekends:
        for _rid, _windows in locked_free_weekends.items():
            # Normalize rid for lookup
            try: _rid_norm = int(_rid)
            except (ValueError, TypeError): _rid_norm = _rid
            _dates: set = set()
            for _w in (_windows or []):
                _sat = getattr(_w, 'sat', None) if not isinstance(_w, dict) else _w.get('sat')
                _sun = getattr(_w, 'sun', None) if not isinstance(_w, dict) else _w.get('sun')
                if isinstance(_sat, str):
                    try: _sat = date.fromisoformat(_sat)
                    except (ValueError, TypeError): _sat = None
                if isinstance(_sun, str):
                    try: _sun = date.fromisoformat(_sun)
                    except (ValueError, TypeError): _sun = None
                if _sat: _dates.add(_sat)
                if _sun: _dates.add(_sun)
            if _dates:
                locked_dates_by_resource[_rid_norm] = _dates
                # Also register under original key in case type differs
                locked_dates_by_resource[_rid] = _dates

    # --- Create decision variables ---
    # Skip (r, d) pairs where d is in locked_dates_by_resource[r].
    var_count = 0
    skipped_locked_days = 0
    for r in lc06_resource_ids:
        r_locked_dates = locked_dates_by_resource.get(r, set())
        for d in planning_days:
            if d in r_locked_dates:
                skipped_locked_days += 1
                continue
            for h in day_anchor_hours[(r, d)]:
                if rt_replannable:
                    rt_vars[(r, d, h)] = model.NewBoolVar(f'rt_{r}_{d.isoformat()}_h{h}')
                    var_count += 1
                if ct_replannable:
                    ct_vars[(r, d, h)] = model.NewBoolVar(f'ct_{r}_{d.isoformat()}_h{h}')
                    var_count += 1
    logger.info(
        f"[LC_06] Created {var_count} rest-day decision variables"
        + (f" (skipped {skipped_locked_days} pre-allocated weekend day-slots)"
           if skipped_locked_days else "")
    )

    # --- Constraint 1: At most one rest-day assignment per (r, d) ---
    # Replaces the legacy `rt[r,d] + ct[r,d] <= 1` mutex with a generalized
    # version summing over ALL anchor variants. Prevents:
    #   - two rest days on the same day (different anchors),
    #   - an RT and a CT on the same day,
    #   - one rest day of each type on different anchors.
    # Fix #17-J: skip locked days — no vars exist there.
    mutex_count = 0
    for r in lc06_resource_ids:
        r_locked_dates = locked_dates_by_resource.get(r, set())
        for d in planning_days:
            if d in r_locked_dates:
                continue
            hours_for_day = day_anchor_hours[(r, d)]
            terms = []
            if rt_replannable:
                terms.extend(rt_vars[(r, d, h)] for h in hours_for_day if (r, d, h) in rt_vars)
            if ct_replannable:
                terms.extend(ct_vars[(r, d, h)] for h in hours_for_day if (r, d, h) in ct_vars)
            if terms:
                model.Add(sum(terms) <= 1)
                mutex_count += 1
    logger.info(f"[LC_06] At-most-one-per-day constraints: {mutex_count}")

    # --- Constraint 2: No overlap with assigned demand (per anchor) ---
    # Pre-compute for each DISTINCT anchor window [anchor_start, +24h] the set
    # of demands overlapping it. Emit:
    #   x[r, req] + rt_vars[(r, d, h)] + ct_vars[(r, d, h)] <= 1
    # for every (r, d, h) and every overlapping demand.
    # Fix #17-J: skip locked days — no rt/ct vars exist there; x_vars on those
    # days are already forced to 0 in solver/model.py, so the overlap is trivially
    # satisfied.
    overlap_count = 0
    overlap_cache: Dict[Tuple[datetime, datetime], List[Any]] = {}
    for r in lc06_resource_ids:
        r_locked_dates = locked_dates_by_resource.get(r, set())
        for d in planning_days:
            if d in r_locked_dates:
                continue
            for h in day_anchor_hours[(r, d)]:
                anchor_start = anchor_starts[(r, d, h)]
                anchor_end = anchor_start + timedelta(hours=24)
                key = (anchor_start, anchor_end)
                if key not in overlap_cache:
                    overlap_cache[key] = [
                        req_id for req_id, (s, e) in request_times.items()
                        if _intervals_overlap(s, e, anchor_start, anchor_end)
                    ]
                overlapping = overlap_cache[key]
                if not overlapping:
                    continue
                for req_id in overlapping:
                    x_key = (r, req_id)
                    if x_key not in x_vars:
                        continue
                    terms = [x_vars[x_key]]
                    if rt_replannable and (r, d, h) in rt_vars:
                        terms.append(rt_vars[(r, d, h)])
                    if ct_replannable and (r, d, h) in ct_vars:
                        terms.append(ct_vars[(r, d, h)])
                    if len(terms) >= 2:
                        model.Add(sum(terms) <= 1)
                        overlap_count += 1
    logger.info(f"[LC_06] Overlap (demand↔rest, per-anchor) constraints: {overlap_count}")

    # --- Constraint 3: Per-segment targets ---
    # Pull upper-bound cap multiplier from config. Zero/None disables caps
    # (pre-2026-04-21 behavior — minimums only, solver may over-allocate).
    try:
        from config import REST_DAY_ALLOCATION_CAP_MULTIPLIER as _cap_mult
    except ImportError:
        _cap_mult = None
    cap_enabled = bool(_cap_mult) and float(_cap_mult) > 0.0

    # 2026-04-22 Fix #13: soft penalty on over-allocation. Complements the
    # hard cap — cap handles required>0 partitions, penalty handles
    # required=0 partitions (where a hard cap risks infeasibility). The
    # penalty terms are stashed on `model._lc_06_excess_terms` and pulled
    # into the objective by the caller in solver/model.py (same
    # side-channel pattern as `lc_06_anchor_map`).
    try:
        from config import REST_DAY_EXCESS_PENALTY_WEIGHT as _excess_weight_raw
    except ImportError:
        _excess_weight_raw = None
    excess_weight = int(_excess_weight_raw) if _excess_weight_raw and int(_excess_weight_raw) > 0 else 0
    excess_enabled = excess_weight > 0
    excess_terms: list = []   # list of (int_var * weight) terms for the Minimize objective

    # Helper: sum all rt (or ct) vars for a resource on the given seg_days,
    # summing over EVERY anchor present on each day.
    def _sum_rt(r, seg_days):
        terms = []
        for d in seg_days:
            for h in day_anchor_hours[(r, d)]:
                if (r, d, h) in rt_vars:
                    terms.append(rt_vars[(r, d, h)])
        return terms

    def _sum_ct(r, seg_days):
        terms = []
        for d in seg_days:
            for h in day_anchor_hours[(r, d)]:
                if (r, d, h) in ct_vars:
                    terms.append(ct_vars[(r, d, h)])
        return terms

    # Fix #17-E (2026-04-23): LC-06 targets are now SOFT with high-weight
    # shortfall penalties (previously hard constraints that caused partition
    # INFEASIBLE when no feasible rest-day assignment existed). The shortfall
    # is a non-negative IntVar equal to max(0, required - sum). Its weighted
    # cost flows into the objective via the _lc_06_excess_terms side-channel.
    try:
        from config import LC_06_SHORTFALL_WEIGHT as _shortfall_weight_raw
    except ImportError:
        _shortfall_weight_raw = 10
    shortfall_weight = int(_shortfall_weight_raw) if _shortfall_weight_raw and int(_shortfall_weight_raw) > 0 else 0
    shortfall_enabled = shortfall_weight > 0
    shortfall_terms: list = []  # (int_var * weight) terms merged into excess_terms at the end

    import math as _math
    target_rt_count = 0
    target_ct_count = 0
    target_combined_count = 0
    cap_rt_count = 0
    cap_ct_count = 0
    cap_combined_count = 0
    excess_var_count = 0
    shortfall_var_count = 0
    for r in lc06_resource_ids:
        r_targets = rest_targets.get(r)
        if not r_targets:
            continue
        for month_key, t in r_targets.items():
            seg_start = t.segment_start
            seg_end = t.segment_end
            seg_days = [d for d in planning_days if seg_start <= d <= seg_end]
            if not seg_days:
                continue

            rt_terms = _sum_rt(r, seg_days) if rt_replannable else []
            ct_terms = _sum_ct(r, seg_days) if ct_replannable else []

            # Soft RT target
            if rt_replannable and t.rt_required > 0 and rt_terms:
                if shortfall_enabled:
                    sv = model.NewIntVar(0, int(t.rt_required), f'rt_short_{r}_{month_key}')
                    # sv >= rt_required - sum(rt_terms)  ⇔  sum(rt_terms) + sv >= rt_required
                    model.Add(sum(rt_terms) + sv >= int(t.rt_required))
                    shortfall_terms.append(sv * shortfall_weight)
                    shortfall_var_count += 1
                else:
                    # Fallback: hard target (legacy behavior)
                    model.Add(sum(rt_terms) >= int(t.rt_required))
                target_rt_count += 1

            # Soft CT target
            if ct_replannable and t.ct_required > 0 and ct_terms:
                if shortfall_enabled:
                    sv = model.NewIntVar(0, int(t.ct_required), f'ct_short_{r}_{month_key}')
                    model.Add(sum(ct_terms) + sv >= int(t.ct_required))
                    shortfall_terms.append(sv * shortfall_weight)
                    shortfall_var_count += 1
                else:
                    model.Add(sum(ct_terms) >= int(t.ct_required))
                target_ct_count += 1

            # Soft combined target (redundant when both individuals hold, but kept
            # as safety net for the asymmetric-carryover edge cases documented in
            # preprocessing/rest_targets.py).
            if t.combined_required > 0:
                comb_terms = list(rt_terms) + list(ct_terms)
                if comb_terms:
                    if shortfall_enabled:
                        sv = model.NewIntVar(0, int(t.combined_required), f'comb_short_{r}_{month_key}')
                        model.Add(sum(comb_terms) + sv >= int(t.combined_required))
                        shortfall_terms.append(sv * shortfall_weight)
                        shortfall_var_count += 1
                    else:
                        model.Add(sum(comb_terms) >= int(t.combined_required))
                    target_combined_count += 1

            # Upper-bound caps — prevent the solver from "parking" idle
            # resources on rest days when demand coverage is weakly weighted.
            # Cap = ceil(multiplier * gross_target). Gross (not required)
            # is used so the cap is stable across partitions even when
            # prior carryover reduces the per-partition required.
            #
            # 2026-04-22 (Fix #12 v2): SKIP the cap entirely when
            # t.rt_required == 0 (carryover has already met the full-month
            # minimum). Attempts to cap at 0 or 1 in that case clashed
            # with LC-05 weekend coupling (which requires rt+ct >= 2 over
            # a weekend) and Priority-1 anchor forcing (which fixes
            # specific rt[r,d]=1), producing INFEASIBLE partitions with
            # "empty domain after intersecting with [0]" errors. Leaving
            # carryover-satisfied partitions uncapped keeps the solver
            # feasible; the bulk of the over-allocation still gets
            # trimmed by the cap on required>0 partitions.
            rt_cap = ct_cap = comb_cap = None
            if cap_enabled:
                if rt_replannable and t.rt_required > 0 and t.rt_gross > 0 and rt_terms:
                    rt_cap = int(_math.ceil(float(_cap_mult) * t.rt_gross))
                    model.Add(sum(rt_terms) <= rt_cap)
                    cap_rt_count += 1
                if ct_replannable and t.ct_required > 0 and t.ct_gross > 0 and ct_terms:
                    ct_cap = int(_math.ceil(float(_cap_mult) * t.ct_gross))
                    model.Add(sum(ct_terms) <= ct_cap)
                    cap_ct_count += 1
                if t.combined_required > 0 and t.combined_gross > 0:
                    comb_cap = int(_math.ceil(float(_cap_mult) * t.combined_gross))
                    comb_terms = list(rt_terms) + list(ct_terms)
                    if comb_terms:
                        model.Add(sum(comb_terms) <= comb_cap)
                        cap_combined_count += 1

            # Soft excess penalty — Fix #13.
            # excess = max(0, sum(rt_vars) - rt_required). IntVar upper
            # bound is len(seg_days) (can't have more excess than days).
            # Domain starts at 0 so we don't need a separate >= 0 constraint.
            seg_days_count = len(seg_days)
            if excess_enabled:
                if rt_replannable and seg_days_count > 0 and rt_terms:
                    erv = model.NewIntVar(0, seg_days_count, f'excess_rt_{r}_{month_key}')
                    model.Add(erv >= sum(rt_terms) - int(t.rt_required))
                    excess_terms.append(erv * excess_weight)
                    excess_var_count += 1
                if ct_replannable and seg_days_count > 0 and ct_terms:
                    ecv = model.NewIntVar(0, seg_days_count, f'excess_ct_{r}_{month_key}')
                    model.Add(ecv >= sum(ct_terms) - int(t.ct_required))
                    excess_terms.append(ecv * excess_weight)
                    excess_var_count += 1

            metadata.append({
                'constraint_id': 'LC_06',
                'constraint_type': 'hard',
                'resource_id': r,
                'month_key': month_key,
                'segment_start': str(seg_start),
                'segment_end': str(seg_end),
                'rt_required': t.rt_required,
                'ct_required': t.ct_required,
                'combined_required': t.combined_required,
                'rt_gross': t.rt_gross,
                'ct_gross': t.ct_gross,
                'combined_gross': t.combined_gross,
                'rt_cap': rt_cap,
                'ct_cap': ct_cap,
                'combined_cap': comb_cap,
                'prior_rt': t.prior_rt,
                'prior_ct': t.prior_ct,
                'is_full_month': t.is_full_month,
            })

    logger.info(
        f"[LC_06] Target constraints: rt={target_rt_count}, "
        f"ct={target_ct_count}, combined={target_combined_count}"
    )
    if cap_enabled:
        logger.info(
            f"[LC_06] Upper-bound caps (multiplier={_cap_mult}): "
            f"rt={cap_rt_count}, ct={cap_ct_count}, combined={cap_combined_count}"
        )
    else:
        logger.info("[LC_06] Upper-bound caps DISABLED (REST_DAY_ALLOCATION_CAP_MULTIPLIER <= 0 or unset)")

    # Fix #13: stash the excess-penalty terms on the model for the caller
    # to merge into its objective. Same side-channel pattern as
    # `lc_06_anchor_map` at the end of this function. Empty list is a
    # valid no-op when the penalty is disabled.
    if excess_enabled:
        logger.info(
            f"[LC_06] Excess penalty: {excess_var_count} vars created "
            f"(weight={excess_weight})"
        )
    else:
        logger.info("[LC_06] Excess penalty DISABLED (REST_DAY_EXCESS_PENALTY_WEIGHT <= 0 or unset)")

    # Fix #17: anchor preference penalty — nudge the solver to pick
    # lower-cost anchors (0 > 6/12/18 > 13). This is intentionally a SMALL
    # soft term; it only matters when multiple anchors are feasible. The
    # carryover sentinel is exempt (free).
    anchor_pref_terms: list = []
    anchor_pref_count = 0
    for (r, d, h), var in rt_vars.items():
        cost = 0 if h == CARRYOVER_ANCHOR_KEY else anchor_penalty.get(h, 0)
        if cost:
            anchor_pref_terms.append(var * cost)
            anchor_pref_count += 1
    for (r, d, h), var in ct_vars.items():
        cost = 0 if h == CARRYOVER_ANCHOR_KEY else anchor_penalty.get(h, 0)
        if cost:
            anchor_pref_terms.append(var * cost)
            anchor_pref_count += 1
    if anchor_pref_count:
        logger.info(f"[LC_06] Anchor-preference penalty: {anchor_pref_count} terms")
    if shortfall_enabled:
        logger.info(
            f"[LC_06] Shortfall penalty (Fix #17-E): {shortfall_var_count} vars "
            f"created (weight={shortfall_weight}) — rest-day targets are now SOFT"
        )
    else:
        logger.info("[LC_06] Shortfall penalty DISABLED (LC_06_SHORTFALL_WEIGHT <= 0)")
    # Combine excess + anchor-preference + shortfall terms into the side-channel
    # list that solver/model.py reads and appends to objective_vars.
    setattr(
        model,
        '_lc_06_excess_terms',
        list(excess_terms) + list(anchor_pref_terms) + list(shortfall_terms),
    )

    # --- Constraint 4: LC-05 weekend coupling (current partition) ---
    # For each fw[r, (sat, sun)] = free-weekend var:
    #   fw <= sum over anchors h of (rt[r, sat, h] + ct[r, sat, h])
    #   fw <= sum over anchors h of (rt[r, sun, h] + ct[r, sun, h])
    fw_coupling_count = 0
    if lc_05_free_weekend_vars:
        for fw_key, fw_var in lc_05_free_weekend_vars.items():
            # Key is expected to be (resource_id, (sat_dt_or_date, sun_dt_or_date))
            try:
                r, weekend = fw_key
                sat_raw, sun_raw = weekend
            except (TypeError, ValueError):
                logger.warning(f"[LC_06] Unexpected fw_key shape: {fw_key!r}; skipping")
                continue
            sat_d = sat_raw.date() if isinstance(sat_raw, datetime) else sat_raw
            sun_d = sun_raw.date() if isinstance(sun_raw, datetime) else sun_raw
            # Fix #17-J: skip pre-allocated days — they're already rest by
            # construction via x_vars=0 forcing; no need to couple fw_var.
            r_locked_dates = locked_dates_by_resource.get(r, set())
            for weekend_d in (sat_d, sun_d):
                if weekend_d not in planning_days_set:
                    continue
                if weekend_d in r_locked_dates:
                    continue
                hours_for_day = day_anchor_hours.get((r, weekend_d), [])
                terms = []
                if rt_replannable:
                    terms.extend(
                        rt_vars[(r, weekend_d, h)]
                        for h in hours_for_day
                        if (r, weekend_d, h) in rt_vars
                    )
                if ct_replannable:
                    terms.extend(
                        ct_vars[(r, weekend_d, h)]
                        for h in hours_for_day
                        if (r, weekend_d, h) in ct_vars
                    )
                if terms:
                    model.Add(fw_var <= sum(terms))
                    fw_coupling_count += 1
    logger.info(f"[LC_06] LC-05 weekend coupling (current): {fw_coupling_count} constraints")

    # --- Constraint 5: LC-05 cross-partition coupling ---
    # For each prior free weekend whose Sat/Sun falls inside the current
    # planning range, force rt+ct >= 1 on that day (summed over anchors).
    prior_coupling_count = 0
    if prior_free_weekends:
        for r, by_month in prior_free_weekends.items():
            if not by_month:
                continue
            # Fix #17-J: skip pre-allocated days — redundant forcing
            r_locked_dates = locked_dates_by_resource.get(r, set())
            for month_key, weekend_pairs in by_month.items():
                for pair in weekend_pairs:
                    try:
                        sat_d_raw, sun_d_raw = pair
                    except (TypeError, ValueError):
                        continue
                    sat_d = sat_d_raw.date() if isinstance(sat_d_raw, datetime) else sat_d_raw
                    sun_d = sun_d_raw.date() if isinstance(sun_d_raw, datetime) else sun_d_raw
                    for wd in (sat_d, sun_d):
                        if wd not in planning_days_set:
                            continue
                        if wd in r_locked_dates:
                            continue
                        hours_for_day = day_anchor_hours.get((r, wd), [])
                        terms = []
                        if rt_replannable:
                            terms.extend(
                                rt_vars[(r, wd, h)]
                                for h in hours_for_day
                                if (r, wd, h) in rt_vars
                            )
                        if ct_replannable:
                            terms.extend(
                                ct_vars[(r, wd, h)]
                                for h in hours_for_day
                                if (r, wd, h) in ct_vars
                            )
                        if terms:
                            model.Add(sum(terms) >= 1)
                            prior_coupling_count += 1
    else:
        logger.info(
            "[LC_06] No prior_free_weekends supplied — cross-partition weekend "
            "coupling skipped (first partition or cold start)."
        )
    logger.info(f"[LC_06] LC-05 weekend coupling (cross-partition): {prior_coupling_count} constraints")

    # --- Constraint 6: cross-partition DEMAND×REST overlap prevention ---
    # Fix #17: for every rest-day window the PRIOR partition allocated, block
    # any CURRENT-partition demand whose shift overlaps that window. The rest
    # variable itself lives in the prior partition's model and is no longer
    # reachable, so we force the demand var to 0 via a unit constraint.
    #
    # Mirrors the within-partition per-anchor overlap (Constraint 2) but for
    # the rest/demand pair whose rest side was decided upstream.
    prior_rest_block_count = 0
    if resource_states:
        for r, rs in resource_states.items():
            prior_rest_windows = getattr(rs, 'rest_day_windows_by_month', None) or {}
            if not prior_rest_windows:
                continue
            for month_key, windows in prior_rest_windows.items():
                for w in windows:
                    try:
                        rs_start, rs_end = w
                    except (TypeError, ValueError):
                        continue
                    rs_start = _to_utc(rs_start)
                    rs_end = _to_utc(rs_end)
                    if rs_start is None or rs_end is None:
                        continue
                    # Skip windows that can't overlap the current planning range.
                    if rs_end <= planning_start_dt or rs_start >= planning_end_dt + timedelta(days=1):
                        continue
                    for req_id, (s, e) in request_times.items():
                        if not _intervals_overlap(s, e, rs_start, rs_end):
                            continue
                        x_key = (r, req_id)
                        if x_key not in x_vars:
                            continue
                        model.Add(x_vars[x_key] == 0)
                        prior_rest_block_count += 1
    logger.info(
        f"[LC_06] Cross-partition DEMAND blocked by prior REST window: "
        f"{prior_rest_block_count} constraints"
    )

    # --- Constraint 7: cross-partition REST×DEMAND overlap prevention ---
    # Fix #17: for every demand window the PRIOR partition ASSIGNED, forbid
    # any CURRENT-partition rest-day anchor whose 24h window would overlap
    # that demand. Without this, partition B could anchor a rest day at
    # midnight day-0 while partition A's demand 21:00→06:00 of day-0 runs
    # in the same resource's calendar.
    prior_demand_block_count = 0
    if resource_states:
        for r, rs in resource_states.items():
            prior_demand_windows = getattr(rs, 'assigned_demand_windows_by_month', None) or {}
            if not prior_demand_windows:
                continue
            for month_key, windows in prior_demand_windows.items():
                for w in windows:
                    try:
                        dem_start, dem_end = w
                    except (TypeError, ValueError):
                        continue
                    dem_start = _to_utc(dem_start)
                    dem_end = _to_utc(dem_end)
                    if dem_start is None or dem_end is None:
                        continue
                    for d in planning_days:
                        for h in day_anchor_hours.get((r, d), []):
                            anchor_start = anchor_starts[(r, d, h)]
                            anchor_end = anchor_start + timedelta(hours=24)
                            if not _intervals_overlap(dem_start, dem_end, anchor_start, anchor_end):
                                continue
                            if rt_replannable and (r, d, h) in rt_vars:
                                model.Add(rt_vars[(r, d, h)] == 0)
                                prior_demand_block_count += 1
                            if ct_replannable and (r, d, h) in ct_vars:
                                model.Add(ct_vars[(r, d, h)] == 0)
                                prior_demand_block_count += 1
    logger.info(
        f"[LC_06] Cross-partition REST anchors blocked by prior DEMAND window: "
        f"{prior_demand_block_count} constraints"
    )

    # --- Constraint 8: cross-partition REST×REST mutex leak plug ---
    # Fix #17-A (issue #3): without this, partition B can allocate an RT on
    # the same (resource, day) where partition A already allocated a CT (or
    # another RT). The within-partition at-most-one-per-day mutex only sees
    # variables in its own model. We use the prior rest_day_windows_by_month
    # as a 24h-window lookup and forbid any current-partition (r, d, h)
    # anchor whose window overlaps — mirrors Constraint 7 but with the
    # REST source instead of DEMAND source.
    #
    # Observed in first Fix #17 probe (PLAN-20260423111641, res=290,
    # 2026-06-02): CT and RT both midnight→midnight, different partitions.
    prior_rest_block_rest_count = 0
    if resource_states:
        for r, rs in resource_states.items():
            prior_rest_windows = getattr(rs, 'rest_day_windows_by_month', None) or {}
            if not prior_rest_windows:
                continue
            for month_key, windows in prior_rest_windows.items():
                for w in windows:
                    try:
                        rs_start, rs_end = w
                    except (TypeError, ValueError):
                        continue
                    rs_start = _to_utc(rs_start)
                    rs_end = _to_utc(rs_end)
                    if rs_start is None or rs_end is None:
                        continue
                    for d in planning_days:
                        for h in day_anchor_hours.get((r, d), []):
                            anchor_start = anchor_starts[(r, d, h)]
                            anchor_end = anchor_start + timedelta(hours=24)
                            if not _intervals_overlap(rs_start, rs_end, anchor_start, anchor_end):
                                continue
                            if rt_replannable and (r, d, h) in rt_vars:
                                model.Add(rt_vars[(r, d, h)] == 0)
                                prior_rest_block_rest_count += 1
                            if ct_replannable and (r, d, h) in ct_vars:
                                model.Add(ct_vars[(r, d, h)] == 0)
                                prior_rest_block_rest_count += 1
    logger.info(
        f"[LC_06] Cross-partition REST anchors blocked by prior REST window: "
        f"{prior_rest_block_rest_count} constraints"
    )

    # --- Constraint 9: within-partition pairwise REST × REST overlap ---
    # Fix #17-D (2026-04-23): the at-most-one-per-day mutex (Constraint 1)
    # only covers the SAME day. With flexible anchors, the solver can pick
    # h=18 on day D and h=6 on day D+1 — two legal within-day choices that
    # produce 24h windows overlapping by 12h on D+1. Observed in
    # PLAN-20260423120047: 25 such overlaps (17 RT×RT, 5 CT×RT, 3 CT×CT).
    #
    # Symmetric to Constraint 8 (cross-partition REST×REST) but for pairs
    # within the current partition. We iterate anchors sorted by start
    # time and use a sliding window: once an anchor's start is past a
    # reference anchor's end, no further anchor overlaps that reference.
    # For anchor sets {0, 6, 12, 13, 18} and consecutive days, only about
    # half the pairs overlap — still ~O(resources × days × 10) constraints
    # in practice, manageable.
    within_pair_count = 0
    for r in lc06_resource_ids:
        # Collect all anchors for this resource with their windows
        items: List[Tuple[date, int, datetime, datetime]] = []
        for d in planning_days:
            for h in day_anchor_hours.get((r, d), []):
                a_start = anchor_starts[(r, d, h)]
                items.append((d, h, a_start, a_start + timedelta(hours=24)))
        items.sort(key=lambda t: t[2])

        for i in range(len(items)):
            d1, h1, as1, ae1 = items[i]
            for j in range(i + 1, len(items)):
                d2, h2, as2, ae2 = items[j]
                # Sorted ascending by as2 — if B starts at/after A's end,
                # no overlap and neither will any later j.
                if as2 >= ae1:
                    break
                # Same-day pairs are already handled by at-most-one-per-day.
                if d1 == d2:
                    continue
                terms = []
                if rt_replannable:
                    if (r, d1, h1) in rt_vars:
                        terms.append(rt_vars[(r, d1, h1)])
                    if (r, d2, h2) in rt_vars:
                        terms.append(rt_vars[(r, d2, h2)])
                if ct_replannable:
                    if (r, d1, h1) in ct_vars:
                        terms.append(ct_vars[(r, d1, h1)])
                    if (r, d2, h2) in ct_vars:
                        terms.append(ct_vars[(r, d2, h2)])
                if len(terms) >= 2:
                    model.Add(sum(terms) <= 1)
                    within_pair_count += 1
    logger.info(
        f"[LC_06] Within-partition pairwise REST×REST overlap: "
        f"{within_pair_count} constraints"
    )

    # Attach anchor metadata for _extract_solution (Phase H).
    # Keyed by (r, d, h) since output must know the exact anchor_start per
    # selected var.
    _attach_anchor_map(model, anchor_starts)

    return rt_vars, ct_vars, violations, metadata


# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------

def _to_utc(dt):
    """Coerce to timezone-aware UTC datetime, or return None."""
    if dt is None:
        return None
    if isinstance(dt, datetime):
        if dt.tzinfo is None:
            return dt.replace(tzinfo=timezone.utc)
        return dt
    return None


def _parse_demand_datetime(dt_string):
    """Parse demand datetime string to timezone-aware UTC datetime."""
    if not dt_string:
        return None
    try:
        if isinstance(dt_string, datetime):
            return _to_utc(dt_string)
        s = dt_string
        if s.endswith('Z'):
            s = s.replace('Z', '+00:00')
        dt = datetime.fromisoformat(s)
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=timezone.utc)
        return dt
    except (ValueError, AttributeError):
        return None


def _intervals_overlap(a_start: datetime, a_end: datetime,
                        b_start: datetime, b_end: datetime) -> bool:
    """True iff half-open intervals [a_start, a_end) and [b_start, b_end) overlap."""
    return a_start < b_end and b_start < a_end


def _attach_anchor_map(model, anchors: Dict[Tuple[str, date, int], datetime]) -> None:
    """Stash the anchor map on the model object for Phase H to consume.

    Fix #17: keys are now 3-tuples (resource_id, day, anchor_hour).

    We store it as a plain attribute (not a CP-SAT construct) so the extraction
    step can compute output timestamps. Using `setattr` avoids coupling to any
    particular solver wrapper shape.
    """
    try:
        setattr(model, 'lc_06_anchor_map', anchors)
    except Exception:
        # If the model is a plain CpModel that doesn't accept attrs, fall back
        # to a module-level last-call cache (rare path; tests only).
        global _LAST_ANCHOR_MAP
        _LAST_ANCHOR_MAP = anchors


_LAST_ANCHOR_MAP: Dict[Tuple[str, date, int], datetime] = {}
