"""
Analyze INFEASIBLE partitions from the last demanding probe.

Strategy per INFEASIBLE partition:
  1. Extract partition date range + resource scope from docker logs.
  2. Fetch demands in that range from cff_api.
  3. For each demand: list qualified resources (category + qualifications match).
  4. For each qualified resource: check absences/blocks overlapping the demand window.
  5. Classify:
     A. COVERAGE VACUUM — no qualified resources free to cover demands
     B. CARRYOVER COLLISION — qualified resources exist but LC-06 anchors zeroed
     C. DENSITY — resources free but too packed for LC-06 monthly minimums

Usage:  python3 /tmp/analyze_infeasible_partitions.py <job_id>
"""
import json, sys, re, subprocess, urllib.request, urllib.parse
from collections import defaultdict
from datetime import datetime, timezone

API_BASE = "http://localhost:8003/qa/ai/api/v1"
CONTAINER = "cff-solver-qa"
JOB_ID = sys.argv[1] if len(sys.argv) > 1 else None


def http_get(path, params=None):
    url = API_BASE + path
    if params:
        url += "?" + urllib.parse.urlencode(params)
    with urllib.request.urlopen(url, timeout=60) as r:
        return json.load(r)


def paginate(path, base_params):
    rows = []
    page = 1
    while True:
        p = dict(base_params, page=page, per_page=200)
        d = http_get(path, p)
        data = d.get("data") or []
        rows.extend(data)
        total = d.get("total")
        if not data or (total and len(rows) >= total):
            break
        page += 1
        if page > 200:
            break
    return rows


def extract_partitions_from_logs(job_id):
    """Parse docker logs to map each partition to: index, date range, INFEASIBLE status."""
    out = subprocess.check_output(
        ["docker", "logs", CONTAINER], stderr=subprocess.STDOUT, text=True, errors="ignore"
    )
    lines = out.splitlines()
    # Find the job_id marker if given, else use most recent run
    partitions = []
    current = {}
    for line in lines:
        m = re.search(r"Partition (\d+):\s+(\d{4}-\d{2}-\d{2})\s+to\s+(\d{4}-\d{2}-\d{2}),\s+(\d+)\s+demands", line)
        if m:
            idx, ds, de, n_demands = m.groups()
            current = {
                "index": int(idx),
                "start": ds,
                "end": de,
                "n_demands_declared": int(n_demands),
                "infeasible": False,
                "n_vars": None,
                "n_pairwise": None,
                "cross_rest_blocked": None,
                "cross_demand_blocked": None,
                "cross_rest_blocks_rest": None,
                "shortfall_vars": None,
            }
            partitions.append(current)
            continue
        if not partitions:
            continue
        p = partitions[-1]
        if "INFEASIBLE" in line and "status:" in line.lower() and p.get("n_vars") is not None:
            p["infeasible"] = True
        elif re.search(r"Created\s+(\d+)\s+rest-day decision variables", line):
            p["n_vars"] = int(re.search(r"Created\s+(\d+)", line).group(1))
        elif "Within-partition pairwise" in line:
            p["n_pairwise"] = int(re.search(r":\s+(\d+)\s+constraints", line).group(1))
        elif "Cross-partition DEMAND blocked by prior REST" in line:
            p["cross_rest_blocked"] = int(re.search(r":\s+(\d+)\s+constraints", line).group(1))
        elif "Cross-partition REST anchors blocked by prior DEMAND" in line:
            p["cross_demand_blocked"] = int(re.search(r":\s+(\d+)\s+constraints", line).group(1))
        elif "Cross-partition REST anchors blocked by prior REST" in line:
            p["cross_rest_blocks_rest"] = int(re.search(r":\s+(\d+)\s+constraints", line).group(1))
        elif "Shortfall penalty" in line:
            m2 = re.search(r":\s+(\d+)\s+vars", line)
            if m2:
                p["shortfall_vars"] = int(m2.group(1))
    return partitions


def normalize_cats(val):
    if not val:
        return set()
    if isinstance(val, str):
        return {c.strip().lower() for c in val.split(",") if c.strip()}
    if isinstance(val, list):
        return {str(c).strip().lower() for c in val if c}
    return set()


def parse_dt(s):
    if not s:
        return None
    try:
        dt = datetime.fromisoformat(s.replace("Z", "+00:00").replace(" ", "T"))
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=timezone.utc)
        return dt
    except Exception:
        return None


def intervals_overlap(a_s, a_e, b_s, b_e):
    return a_s < b_e and b_s < a_e


def analyze_partition(p, all_resources, all_absences, teams_in_scope):
    """Diagnose why partition is infeasible."""
    date_s = p["start"]
    date_e = p["end"]
    start_dt = parse_dt(date_s + "T00:00:00+00:00")
    end_dt = parse_dt(date_e + "T23:59:59+00:00")

    # Fetch demands for the partition range
    demands = paginate("/demands/", {"start_date": date_s, "end_date": date_e})
    # Only count demands actually in this window (API may return a superset)
    filtered_demands = []
    for d in demands:
        ds = parse_dt(d.get("shift_start_time"))
        if ds and start_dt <= ds <= end_dt:
            filtered_demands.append(d)

    n_total_demands = len(filtered_demands)
    n_with_qualified = 0
    n_with_free_qualified = 0
    coverage_details = []

    for d in filtered_demands:
        req_cat = (d.get("resource_category") or "").strip().lower()
        req_quals = normalize_cats(d.get("required_qualifications"))
        ds = parse_dt(d.get("shift_start_time"))
        de = parse_dt(d.get("shift_finish_time"))
        if not (ds and de):
            continue

        qualified = []
        free_qualified = []
        for r in all_resources:
            r_cats = normalize_cats(r.get("resource_categories"))
            r_quals = normalize_cats(r.get("qualifications"))
            # Tier 1 — category
            if req_cat and req_cat not in r_cats:
                continue
            # Tier 2 — qualifications
            if req_quals and not req_quals.issubset(r_quals):
                continue
            qualified.append(r)
            # Check blocking absences in partition range
            rid = r["resource_id"]
            r_abs = all_absences.get(rid, [])
            blocked = any(intervals_overlap(ds, de, ab_s, ab_e) for (ab_s, ab_e) in r_abs)
            if not blocked:
                free_qualified.append(r)
        if qualified:
            n_with_qualified += 1
        if free_qualified:
            n_with_free_qualified += 1
        if len(coverage_details) < 5 and not free_qualified:
            coverage_details.append({
                "demand_id": d.get("id"),
                "time": f"{ds} -> {de}",
                "category": d.get("resource_category"),
                "n_qualified": len(qualified),
                "sample_qualified_ids": [r["resource_id"] for r in qualified[:3]],
            })

    # Classify
    if n_with_free_qualified < n_total_demands * 0.3:
        verdict = "A. COVERAGE VACUUM — most demands have no free qualified resource"
    elif (p.get("cross_rest_blocks_rest", 0) or 0) + (p.get("cross_demand_blocked", 0) or 0) > 50:
        verdict = "B. CARRYOVER COLLISION — qualified resources exist, anchors zeroed by prior partitions"
    else:
        verdict = "C. DENSITY — resources free, but LC-06 + pairwise packing impossible"

    return {
        "partition": p,
        "n_demands_in_range": n_total_demands,
        "n_demands_with_qualified": n_with_qualified,
        "n_demands_with_free_qualified": n_with_free_qualified,
        "pct_coverable": round(100 * n_with_free_qualified / max(1, n_total_demands), 1),
        "verdict": verdict,
        "uncoverable_samples": coverage_details,
    }


def main():
    print(f"Analyzing INFEASIBLE partitions of most recent run (job={JOB_ID or 'auto'})\n")

    # Discover partitions from logs
    partitions = extract_partitions_from_logs(JOB_ID)
    infeasible = [p for p in partitions if p["infeasible"]]
    print(f"Found {len(partitions)} partitions; {len(infeasible)} INFEASIBLE.\n")

    if not infeasible:
        print("No INFEASIBLE partitions found in logs. Exiting.")
        return

    # Fetch all resources (team-filtered by the probe — use the trigger payload teams)
    teams = [2, 4, 5, 7, 8, 14]
    all_resources = []
    for t in teams:
        rs = paginate("/resources/", {"team_id": t})
        all_resources.extend(rs)
    print(f"Resources fetched: {len(all_resources)}\n")

    # Fetch absences (resource-blocks excluding RT/CT since those are replannable)
    rb = paginate("/resource-blocks/", {
        "start_date": "2026-05-01",
        "end_date": "2026-06-30",
        "category": "all",
        "exclude_calendar_types": "RT Jour de repos,CT Jour de compensation",
    })
    absences = defaultdict(list)
    for b in rb:
        rid = b.get("resource_id")
        bs = parse_dt(b.get("start_datetime") or b.get("shift_start_time"))
        be = parse_dt(b.get("end_datetime") or b.get("shift_finish_time"))
        if rid and bs and be:
            absences[rid].append((bs, be))
    print(f"Absences/blocks indexed: {sum(len(v) for v in absences.values())} across {len(absences)} resources\n")

    # Analyze each infeasible partition
    for p in infeasible:
        print("=" * 70)
        print(f"Partition {p['index']}  {p['start']} → {p['end']}  "
              f"(declared demands={p['n_demands_declared']})")
        print(f"  vars={p['n_vars']}  pairwise={p['n_pairwise']}  "
              f"cross_blocks: DEMxREST={p['cross_rest_blocked']}, "
              f"RESTxDEM={p['cross_demand_blocked']}, RESTxREST={p['cross_rest_blocks_rest']}")

        res = analyze_partition(p, all_resources, absences, teams)
        print(f"  Demands in range: {res['n_demands_in_range']}")
        print(f"  With ≥1 qualified resource:          {res['n_demands_with_qualified']}")
        print(f"  With ≥1 FREE qualified resource:     {res['n_demands_with_free_qualified']} "
              f"({res['pct_coverable']}% of demands)")
        print(f"  VERDICT: {res['verdict']}")
        if res["uncoverable_samples"]:
            print(f"  Sample uncoverable demands:")
            for s in res["uncoverable_samples"]:
                print(f"    demand={s['demand_id']}  cat={s['category']!r}  "
                      f"n_qualified={s['n_qualified']}  sample_q_ids={s['sample_qualified_ids']}")
        print()


if __name__ == "__main__":
    main()
