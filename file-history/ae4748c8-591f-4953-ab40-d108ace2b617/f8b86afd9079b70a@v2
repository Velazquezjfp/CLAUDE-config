"""
Check CT/RT anchor flexibility + overlap integrity across the last N plans.

What we verify:
  1. Anchor distribution — how many CT/RT rows start at midnight (00:00)
     vs. some other hour. The solver should be FLEXIBLE: able to choose
     12:00 or 13:00 anchors when that helps a resource fit a night shift
     later the same day.
  2. Per-resource overlap integrity — no two assignments (CT/RT/DEMAND)
     for the same resource should overlap in time. Overlap = pipeline bug.

Usage:  python3 /tmp/check_ct_rt_anchors.py [N]   (N = plans to check, default 3)
"""
from __future__ import annotations
import json, sys, urllib.request, urllib.parse
from collections import Counter, defaultdict
from datetime import datetime

API_BASE = "http://localhost:8003/qa/ai/api/v1"
N_PLANS = int(sys.argv[1]) if len(sys.argv) > 1 else 3


def http_get(path, params=None):
    url = API_BASE + path
    if params:
        url += "?" + urllib.parse.urlencode(params)
    with urllib.request.urlopen(url, timeout=60) as r:
        return json.load(r)


def parse_dt(s):
    if not s:
        return None
    try:
        return datetime.fromisoformat(s.replace("Z", "+00:00"))
    except Exception:
        return None


def fetch_all_assignments(plan_id):
    rows = []
    page = 1
    while True:
        d = http_get("/planner-output/assignments/",
                     {"plan_id": plan_id, "per_page": 200, "page": page})
        data = d.get("data") or []
        rows.extend(data)
        total = d.get("total")
        if not data or (total and len(rows) >= total):
            break
        page += 1
        if page > 200:
            break
    return rows


def analyze_plan(plan_id, job_id):
    print(f"\n{'='*70}")
    print(f"Plan {plan_id}  (job {job_id})")
    print(f"{'='*70}")

    rows = fetch_all_assignments(plan_id)
    by_type = Counter(a.get("assignment_type") for a in rows)
    print(f"Total rows: {len(rows)}  | by type: {dict(by_type)}")

    ct_rows = [a for a in rows if a.get("assignment_type") == "CT"]
    rt_rows = [a for a in rows if a.get("assignment_type") == "RT"]
    demand_rows = [a for a in rows if a.get("assignment_type") == "DEMAND"]

    # 1. Anchor distribution
    print("\n-- 1. CT/RT anchor distribution (calendar_start hour) --")
    for label, lst in (("RT", rt_rows), ("CT", ct_rows)):
        if not lst:
            print(f"  {label}: (no rows)")
            continue
        hours = Counter()
        for a in lst:
            st = parse_dt(a.get("calendar_start"))
            et = parse_dt(a.get("calendar_end"))
            if st is None or et is None:
                hours["(unparseable)"] += 1
                continue
            hours[(st.hour, et.hour)] += 1
        print(f"  {label}: {len(lst)} rows")
        for (k, n) in sorted(hours.items(), key=lambda x: -x[1]):
            if isinstance(k, tuple):
                h_start, h_end = k
                pct = 100 * n / len(lst)
                flag = "  <-- midnight->midnight" if (h_start == 0 and h_end == 0) else ""
                print(f"    start={h_start:02d}:00  end={h_end:02d}:00  count={n:>5}  ({pct:5.1f}%){flag}")
            else:
                print(f"    {k}: {n}")
        midnight_only = sum(n for k, n in hours.items() if isinstance(k, tuple) and k == (0, 0))
        other = len(lst) - midnight_only
        print(f"    => {midnight_only}/{len(lst)} midnight-to-midnight ({100*midnight_only/len(lst):.1f}%); {other} non-midnight")

    # 2. Per-resource overlap check
    print("\n-- 2. Per-resource overlap check --")
    per_res = defaultdict(list)
    for a in rows:
        rid = a.get("resource_id")
        st = parse_dt(a.get("calendar_start"))
        et = parse_dt(a.get("calendar_end"))
        if rid is None or st is None or et is None:
            continue
        per_res[rid].append((st, et, a.get("assignment_type"), a.get("id")))

    overlaps = []
    for rid, items in per_res.items():
        items.sort()
        for i in range(len(items) - 1):
            s1, e1, t1, id1 = items[i]
            s2, e2, t2, id2 = items[i + 1]
            if s2 < e1:
                overlaps.append({
                    "resource_id": rid,
                    "a1": {"id": id1, "type": t1, "start": s1.isoformat(), "end": e1.isoformat()},
                    "a2": {"id": id2, "type": t2, "start": s2.isoformat(), "end": e2.isoformat()},
                })
    print(f"  Resources with any assignment: {len(per_res)}")
    print(f"  Total overlap cases: {len(overlaps)}")

    pair_counts = Counter()
    for o in overlaps:
        pair = tuple(sorted([o["a1"]["type"], o["a2"]["type"]]))
        pair_counts[pair] += 1
    for pair, n in sorted(pair_counts.items(), key=lambda x: -x[1]):
        print(f"    {pair[0]} x {pair[1]}: {n}")
    if overlaps:
        print("\n  First 5 overlap samples:")
        for o in overlaps[:5]:
            print(f"    res={o['resource_id']}  [{o['a1']['type']:6}] {o['a1']['start']} -> {o['a1']['end']}  id={o['a1']['id']}")
            print(f"                 [{o['a2']['type']:6}] {o['a2']['start']} -> {o['a2']['end']}  id={o['a2']['id']}")

    # 3. Duration sanity
    print("\n-- 3. CT/RT duration sanity (expected: 24h) --")
    for label, lst in (("RT", rt_rows), ("CT", ct_rows)):
        if not lst:
            continue
        dur_counts = Counter()
        for a in lst:
            try:
                dh = float(a.get("duration_hours") or 0)
            except (TypeError, ValueError):
                dh = 0.0
            dur_counts[dh] += 1
        top = dur_counts.most_common(5)
        print(f"  {label}: {dict(top)}")

    return {
        "plan_id": plan_id,
        "job_id": job_id,
        "total_rows": len(rows),
        "by_type": dict(by_type),
        "rt_count": len(rt_rows),
        "ct_count": len(ct_rows),
        "demand_count": len(demand_rows),
        "overlap_count": len(overlaps),
        "overlap_pairs": dict(pair_counts),
    }


def main():
    jobs = http_get("/solver-jobs", {"per_page": 50})
    rows = jobs.get("data") or []

    completed = [r for r in rows
                 if (r.get("plan_id") and r.get("status") in ("COMPLETED", "COMPLETE"))]
    print(f"Total solver_jobs rows in backend: {len(rows)}")
    print(f"  of which have plan_id + status COMPLETED: {len(completed)}")
    print(f"  checking the {N_PLANS} most recent COMPLETED plans:\n")

    for j in completed[:N_PLANS]:
        print(f"-> {j['plan_id']} (job {j['job_id']}, fetch_rt={j.get('fetch_rt')}, fetch_ct={j.get('fetch_ct')})")
    print()

    summaries = []
    for j in completed[:N_PLANS]:
        summaries.append(analyze_plan(j["plan_id"], j["job_id"]))

    print("\n" + "=" * 70)
    print("AGGREGATE SUMMARY")
    print("=" * 70)
    for s in summaries:
        print(f"{s['plan_id']}: rows={s['total_rows']}, DEMAND={s['demand_count']}, RT={s['rt_count']}, CT={s['ct_count']}, overlaps={s['overlap_count']}")

    with open("/tmp/check_ct_rt_anchors_output.json", "w") as f:
        json.dump(summaries, f, indent=2, default=str)
    print("\nDetailed output saved to /tmp/check_ct_rt_anchors_output.json")


if __name__ == "__main__":
    main()
