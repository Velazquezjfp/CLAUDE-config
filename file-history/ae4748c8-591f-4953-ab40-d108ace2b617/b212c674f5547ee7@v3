#!/bin/bash

# Local Deploy - Backend API
# No git pull, no sudo. Rebuilds container images and applies idempotent
# schema migrations to existing volumes.
#
# Usage:
#   ./local_deploy.sh -dev | -qa | -uat | -dev -qa -uat
#     → DEFAULT (preserve-data) — keeps the postgres volume + data dir,
#       rebuilds images, brings containers up, applies idempotent
#       migrations in ./database/*add*.sql and self-healing seeds.
#
#   ./local_deploy.sh -qa --wipe
#     → destructive mode — `docker compose down -v` + wipes data dir,
#       then rebuilds and runs fresh init (triggers docker-entrypoint-initdb.d).
#       ONLY use when you explicitly want to reset the DB.
#
# Notes:
#   - Migrations applied on preserve mode all use IF NOT EXISTS / ON CONFLICT,
#     so safe to re-run. See ./database/schema_*_add_*.sql files.
#   - In --wipe mode, the docker-entrypoint-initdb.d pipeline runs the same
#     SQLs automatically (they're COPY'd into the postgres image), plus the
#     base schemas + seed data.
#   - Postgres data dirs are owned by UID 70 (postgres in container).
#     We use a temporary alpine container to delete them as root in --wipe.

HEALTH_WAIT=90       # Max seconds to wait for health check
HEALTH_INTERVAL=5    # Seconds between retries
ENVS_DEPLOYED=()
MODE="preserve"      # default: keep volume + data. --wipe to force reset.

# --- 1. Argument Parsing ---
if [ $# -eq 0 ]; then
    cat <<EOF
Error: No environment specified.

Usage:
  ./local_deploy.sh -dev | -qa | -uat   [ one or more, any combination ]
  Add --wipe to do a destructive reset (drops volumes).

Examples:
  ./local_deploy.sh -qa              Rebuild images + apply migrations to QA (data preserved)
  ./local_deploy.sh -qa -uat         Same for QA and UAT
  ./local_deploy.sh -dev --wipe      Rebuild + wipe DEV data (dangerous)
EOF
    exit 1
fi

ENV_ARGS=()
for arg in "$@"; do
    case $arg in
        --wipe|-wipe)   MODE="wipe" ;;
        -dev|-qa|-uat)  ENV_ARGS+=("$arg") ;;
        *)
            echo "Unknown argument: $arg"
            exit 1
            ;;
    esac
done

if [ ${#ENV_ARGS[@]} -eq 0 ]; then
    echo "Error: must specify at least one of -dev, -qa, -uat"
    exit 1
fi

echo "------------------------------------------------"
echo "Local deploy targets: ${ENV_ARGS[*]}"
if [ "$MODE" = "wipe" ]; then
    echo "MODE: WIPE — will remove postgres volumes + data dirs."
else
    echo "MODE: PRESERVE — keeps existing volumes, applies idempotent migrations."
fi
echo "------------------------------------------------"
read -p "Proceed? (y/n): " CONFIRM
if [[ ! $CONFIRM =~ ^[Yy]$ ]]; then
    echo "Cancelled."
    exit 0
fi

# --- 2. Helpers ---
clean_pgdata() {
    local dir=$1
    if [ -d "$dir" ]; then
        echo "  Cleaning $dir (docker rm as root)..."
        local parent_abs
        parent_abs="$(cd "$(dirname "$dir")" && pwd)"
        local base
        base="$(basename "$dir")"
        # Mount the PARENT so the alpine root can delete the dir itself,
        # not only its contents. The old `rm -rf "$dir"` on the host fails
        # because $dir is owned by UID 70 (postgres) with mode 700.
        docker run --rm -v "$parent_abs:/parent" alpine rm -rf "/parent/$base"
    fi
}

check_health() {
    local url=$1
    local name=$2
    local elapsed=0

    echo "  Waiting for $name ($url) ..."
    while [ $elapsed -lt $HEALTH_WAIT ]; do
        if curl -sf "$url" > /dev/null 2>&1; then
            echo "  $name is healthy."
            return 0
        fi
        sleep $HEALTH_INTERVAL
        elapsed=$((elapsed + HEALTH_INTERVAL))
    done
    echo "  WARNING: $name did not become healthy within ${HEALTH_WAIT}s."
    return 1
}

# Wait for a postgres container to accept connections, then apply idempotent
# migrations. Safe to re-run — every migration uses IF NOT EXISTS / ON CONFLICT.
#
# Args:
#   $1 = postgres container name (e.g., cff_postgres_qa)
#   $2 = display label (e.g., "QA")
apply_migrations() {
    local pg_container=$1
    local env_label=$2
    local elapsed=0

    echo "  Waiting for $pg_container to accept SQL ..."
    while [ $elapsed -lt $HEALTH_WAIT ]; do
        if docker exec "$pg_container" pg_isready -U postgres > /dev/null 2>&1 \
           || docker exec "$pg_container" sh -c 'pg_isready -U "$POSTGRES_USER"' > /dev/null 2>&1; then
            echo "  $pg_container ready."
            break
        fi
        sleep $HEALTH_INTERVAL
        elapsed=$((elapsed + HEALTH_INTERVAL))
    done
    if [ $elapsed -ge $HEALTH_WAIT ]; then
        echo "  ERROR: $pg_container did not become ready in ${HEALTH_WAIT}s; skipping migrations."
        return 1
    fi

    echo "  Applying idempotent migrations to $pg_container..."

    # All of these files use IF NOT EXISTS / ON CONFLICT DO NOTHING,
    # so re-running is a no-op when the change is already present.
    # Add new migration files here as the schema evolves.
    local MIGRATIONS=(
        "./database/schema_replannable_demand_types.sql"                   # Fix #7 — self-healing catalog (RT + CT INSERT)
        "./database/schema_solver_jobs_add_fetch_flags.sql"                # Fix #16 — fetch_rt / fetch_ct on solver_jobs
        "./database/schema_planner_assignments_add_category_priority.sql"  # Fix #16 — category_priority on planner_assignments
    )

    local applied=0 failed=0
    for sql in "${MIGRATIONS[@]}"; do
        if [ ! -f "$sql" ]; then
            echo "    SKIP (missing file): $sql"
            continue
        fi
        local name=$(basename "$sql")
        # Run via the container's own env (POSTGRES_USER, POSTGRES_DB).
        # Using sh -c so the container-side shell expands the env vars.
        local out
        if out=$(docker exec -i "$pg_container" \
                    sh -c 'psql -v ON_ERROR_STOP=1 -U "$POSTGRES_USER" -d "$POSTGRES_DB"' \
                    < "$sql" 2>&1); then
            echo "    ✓ $name"
            applied=$((applied+1))
        else
            echo "    ✗ $name — FAILED:"
            echo "$out" | sed 's/^/        /'
            failed=$((failed+1))
        fi
    done

    echo "  Migrations for ${env_label}: ${applied} applied, ${failed} failed."
    return 0
}

# --- 3. Deployment Functions ---

deploy_dev() {
    echo ""
    echo "=== DEV Backend ==="
    if [ "$MODE" = "wipe" ]; then
        docker compose -f docker-compose.yml down -v
        clean_pgdata ./data/postgres
        docker compose -f docker-compose.yml build --no-cache
    else
        docker compose -f docker-compose.yml down
        docker compose -f docker-compose.yml build
    fi
    docker compose -f docker-compose.yml --env-file .env up -d
    ENVS_DEPLOYED+=("dev")
    echo "DEV containers started."
}

deploy_qa() {
    echo ""
    echo "=== QA Backend ==="
    if [ "$MODE" = "wipe" ]; then
        docker compose -f docker-compose.qa.yml down -v
        clean_pgdata ./data/postgres_qa
        docker compose -f docker-compose.qa.yml build --no-cache
    else
        docker compose -f docker-compose.qa.yml down
        docker compose -f docker-compose.qa.yml build
    fi
    docker compose -f docker-compose.qa.yml --env-file .env.qa up -d
    ENVS_DEPLOYED+=("qa")
    echo "QA containers started."
}

deploy_uat() {
    echo ""
    echo "=== UAT Backend ==="
    if [ "$MODE" = "wipe" ]; then
        docker compose -f docker-compose.uat.yml down -v
        clean_pgdata ./data/postgres_uat
        docker compose -f docker-compose.uat.yml build --no-cache
    else
        docker compose -f docker-compose.uat.yml down
        docker compose -f docker-compose.uat.yml build
    fi
    docker compose -f docker-compose.uat.yml --env-file .env.uat up -d
    ENVS_DEPLOYED+=("uat")
    echo "UAT containers started."
}

# --- 4. Execution Loop ---
for arg in "${ENV_ARGS[@]}"; do
    case $arg in
        -dev) deploy_dev ;;
        -qa)  deploy_qa  ;;
        -uat) deploy_uat ;;
    esac
done

# --- 5. Apply migrations (preserve mode only — in wipe mode the init
#         pipeline runs them during postgres's first-start hook).
if [ "$MODE" = "preserve" ]; then
    echo ""
    echo "================================================"
    echo "Applying idempotent migrations to preserved data..."
    echo "================================================"
    for env in "${ENVS_DEPLOYED[@]}"; do
        case $env in
            dev) apply_migrations cff_postgres     "DEV" ;;
            qa)  apply_migrations cff_postgres_qa  "QA"  ;;
            uat) apply_migrations cff_postgres_uat "UAT" ;;
        esac
    done
fi

# --- 6. Health Checks ---
echo ""
echo "================================================"
echo "Running health checks..."
echo "================================================"

HEALTH_OK=true
for env in "${ENVS_DEPLOYED[@]}"; do
    case $env in
        dev) check_health "http://localhost:8002/dev/ai/health" "DEV Backend (8002)" || HEALTH_OK=false ;;
        qa)  check_health "http://localhost:8003/qa/ai/health"  "QA Backend (8003)"  || HEALTH_OK=false ;;
        uat) check_health "http://localhost:8007/uat/ai/health" "UAT Backend (8007)" || HEALTH_OK=false ;;
    esac
done

echo ""
if [ "$HEALTH_OK" = true ]; then
    echo "All deployments healthy."
else
    echo "Some services failed health check. Check logs with: docker compose -f <compose-file> logs"
fi
