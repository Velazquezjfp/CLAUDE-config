# =============================================================================
# MULTI-ENVIRONMENT API CONFIGURATION
# =============================================================================

class Environment(str, Enum):
    DEV = "dev"
    QA = "qa"
    UAT = "uat"

# Read backend connection from environment variables (for Docker)
# Falls back to localhost for local development
BACKEND_HOST = os.environ.get("BACKEND_HOST", "localhost")
BACKEND_PORT_DEV = int(os.environ.get("BACKEND_PORT", "8002"))
BACKEND_PORT_QA = int(os.environ.get("BACKEND_PORT_QA", "8003"))
BACKEND_PORT_UAT = int(os.environ.get("BACKEND_PORT_UAT", "8007"))

# Environment-specific configurations
ENV_CONFIG = {
    Environment.DEV: {
        "host": BACKEND_HOST,
        "port": BACKEND_PORT_DEV,
        "context_path": "/dev/ai",
    },
    Environment.QA: {
        "host": BACKEND_HOST,
        "port": BACKEND_PORT_QA,
        "context_path": "/qa/ai",
    },
    Environment.UAT: {
        "host": BACKEND_HOST,
        "port": BACKEND_PORT_UAT,
        "context_path": "/uat/ai",
    },
}

def get_api_base_url(env: Environment) -> str:
    """Construct API base URL for the specified environment."""
    cfg = ENV_CONFIG[env]
    return f"http://{cfg['host']}:{cfg['port']}{cfg['context_path']}/api/v1"

# Determine current solver environment from SOLVER_ENV (set in docker-compose)
SOLVER_ENV = os.environ.get("SOLVER_ENV", "dev").lower()
CURRENT_ENV = Environment(SOLVER_ENV)

# Default API URL for current environment
API_BASE_URL = get_api_base_url(CURRENT_ENV)

# Webhook Configuration — uses current environment's backend
SOLVER_WEBHOOK_ENABLED = os.environ.get("SOLVER_WEBHOOK_ENABLED", "true").lower() in ("true", "1", "yes")
_webhook_cfg = ENV_CONFIG[CURRENT_ENV]
SOLVER_WEBHOOK_URL = os.environ.get(
    "SOLVER_WEBHOOK_URL",
    f"http://{_webhook_cfg['host']}:{_webhook_cfg['port']}{_webhook_cfg['context_path']}/api/v1/solver-jobs/webhook"
)

