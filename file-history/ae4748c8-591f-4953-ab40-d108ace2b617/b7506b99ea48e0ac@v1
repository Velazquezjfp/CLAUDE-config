"""
LC_05: Work-Free Weekend Frequency (HARD CONSTRAINT)
At least 1 complete work-free weekend (Saturday AND Sunday) per 5 calendar weeks.

============================================================================
TIME-FRAME SENSITIVE CONSTRAINT (CALENDAR WEEKS)
============================================================================
This constraint uses CALENDAR WEEKS (Monday-Sunday) for weekend counting.

Partitioning Considerations:
- Rolling 5-week windows are based on calendar weeks
- Planning starting mid-week: First partial week may have incomplete weekend
- Planning ending mid-week: Last partial week may have incomplete weekend

For quarterly/monthly partitioning:
- Ensure week boundaries align with partition boundaries when possible
- Consider tracking "pending weekends" at partition edges
- Weekend at partition boundary: Include in whichever partition contains both days
============================================================================

Based on: ../../mock_data_v2/CONSTRAINTS_DOCUMENTATION_v2.md (lines 138-167)
Source: BAR CCT (final_constraints.md)

Layer 1: Legal constraint (processed after absence blocking)

Definition:
- A "free weekend" = BOTH Saturday AND Sunday with NO work assignments
- Requirement: At least 1 free weekend per rolling 5-week period
- Vacation weekends count toward this requirement

Implementation:
For each resource and each rolling 5-week window:
  1. Identify all weekends (Saturday-Sunday pairs) in the window
  2. For each weekend, check if BOTH Saturday AND Sunday are work-free
  3. Require at least 1 weekend where both days are free
"""
from ortools.sat.python import cp_model
from datetime import datetime, timedelta, timezone
import sys


def _parse_dt(dt_string: str) -> datetime:
    """Parse ISO datetime string, ensure timezone-aware (UTC)."""
    dt = datetime.fromisoformat(dt_string)
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    return dt
