"""
OBJ-09: BSA-ID Category Consistency Analyzer
Analyzes how well resources maintain the same category on the same construction site.
"""
import re
from collections import defaultdict
from .base_analyzer import ObjectiveAnalyzer


def _normalize_string(s) -> str:
    """Normalize a string for comparison."""
    if s is None:
        return ""
    return re.sub(r'\s+', ' ', str(s).strip()).lower()


class BsaCategoryConsistencyAnalyzer(ObjectiveAnalyzer):
    """Analyzer for OBJ-09 (BSA-ID Category Consistency)"""

    def __init__(self):
        super().__init__(
            objective_id='bsa_category_consistency',
            objective_name='BSA-ID Category Consistency'
        )

    def analyze_performance(self, solution, data, constraints):
        """
        Analyze BSA-ID category consistency performance.

        Measures how often resources switch categories on the same BSA-ID.
        """
        assignments = getattr(solution, 'solution_assignments',
                             getattr(solution, 'assignments', []))

        if not assignments:
            return self._empty_result("No assignments to analyze")

        # Group assignments by (resource_id, bsa_id)
        resource_bsa_cats = defaultdict(lambda: defaultdict(set))
        for assignment in assignments:
            res_id = assignment.get('resource_id')
            bsa_id = assignment.get('bsa_id')
            cat = assignment.get('resource_category', '')

            if not bsa_id or not cat:
                continue

            resource_bsa_cats[res_id][str(bsa_id)].add(_normalize_string(cat))

        # Count consistent vs inconsistent
        total_resource_bsa_pairs = 0
        consistent_pairs = 0
        inconsistent_pairs = 0
        switch_details = []

        for res_id, bsa_map in resource_bsa_cats.items():
            for bsa_id, categories in bsa_map.items():
                total_resource_bsa_pairs += 1
                if len(categories) <= 1:
                    consistent_pairs += 1
                else:
                    inconsistent_pairs += 1
                    if len(switch_details) < 20:
                        switch_details.append({
                            'resource_id': res_id,
                            'bsa_id': bsa_id,
                            'categories_used': list(categories),
                            'switch_count': len(categories) - 1
                        })

        if total_resource_bsa_pairs > 0:
            achievement_rate = (consistent_pairs / total_resource_bsa_pairs) * 100
        else:
            achievement_rate = 100.0

        gaps = self.get_gap_details(solution, data)

        # Count unique BSA-IDs with any inconsistency
        bsa_ids_with_switches = set()
        for detail in switch_details:
            bsa_ids_with_switches.add(detail['bsa_id'])

        return {
            "objective_id": "bsa_category_consistency",
            "objective_name": "BSA-ID Category Consistency",
            "target_description": "Keep same resource in same category on same construction site",
            "achieved_value": consistent_pairs,
            "max_possible_value": total_resource_bsa_pairs,
            "achievement_rate": round(achievement_rate, 2),
            "performance_category": self.classify_performance(achievement_rate),
            "gaps": gaps,
            "metrics": {
                "total_assignments": len(assignments),
                "total_resource_bsa_pairs": total_resource_bsa_pairs,
                "consistent_pairs": consistent_pairs,
                "inconsistent_pairs": inconsistent_pairs,
                "bsa_ids_with_switches": len(bsa_ids_with_switches),
                "consistency_rate": round(achievement_rate, 2),
                "switch_examples": switch_details[:10]
            }
        }

    def get_gap_details(self, solution, data):
        """Get detailed information about BSA-ID category consistency gaps."""
        assignments = getattr(solution, 'solution_assignments',
                             getattr(solution, 'assignments', []))

        if not assignments:
            return []

        # Group by (resource_id, bsa_id) -> set of categories
        resource_bsa_cats = defaultdict(lambda: defaultdict(set))
        for assignment in assignments:
            res_id = assignment.get('resource_id')
            bsa_id = assignment.get('bsa_id')
            cat = assignment.get('resource_category', '')
            if not bsa_id or not cat:
                continue
            resource_bsa_cats[res_id][str(bsa_id)].add(_normalize_string(cat))

        gaps = []

        # Resources with BSA-ID category switches
        resources_with_switches = []
        for res_id, bsa_map in resource_bsa_cats.items():
            switches = 0
            for bsa_id, categories in bsa_map.items():
                if len(categories) > 1:
                    switches += 1
            if switches > 0:
                resources_with_switches.append((res_id, switches))

        if resources_with_switches:
            resources_with_switches.sort(key=lambda x: -x[1])
            gaps.append({
                "gap_type": "BSA_CATEGORY_SWITCHES",
                "description": f"{len(resources_with_switches)} resources switch categories within BSA-IDs",
                "impact": "Inconsistent role assignment on construction sites",
                "affected_resources": [
                    {"resource_id": res_id, "bsa_ids_with_switches": count}
                    for res_id, count in resources_with_switches[:5]
                ],
                "recommendations": [
                    "Increase bsa_category_consistency weight",
                    "Review BSA-ID demands — may need to standardize category requirements per site"
                ]
            })

        return gaps

    def _empty_result(self, message: str) -> dict:
        """Return empty result."""
        return {
            "objective_id": "bsa_category_consistency",
            "objective_name": "BSA-ID Category Consistency",
            "target_description": "Keep same resource in same category on same construction site",
            "achieved_value": 0,
            "max_possible_value": 0,
            "achievement_rate": 100.0,
            "performance_category": "EXCELLENT",
            "gaps": [],
            "metrics": {
                "total_assignments": 0,
                "message": message
            }
        }
