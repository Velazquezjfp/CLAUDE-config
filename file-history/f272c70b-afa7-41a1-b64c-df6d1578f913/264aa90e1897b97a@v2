-- ============================================================================
-- 2. OBJECTIVE PRIORITIES (Drag-and-Drop UI)
-- Initialize all objectives in 'low' priority bucket with position-based weights
-- ============================================================================

-- Link to existing objective_weights records
-- Weights are calculated automatically based on position within bucket
INSERT INTO objective_priorities (objective_id, priority_bucket, position)
SELECT
    weight_id,
    'low' as priority_bucket,
    ROW_NUMBER() OVER (ORDER BY weight_id) as position
FROM objective_weights
WHERE active = TRUE;

-- Update critical objectives to 'high' priority
UPDATE objective_priorities
SET priority_bucket = 'high', position = 1
WHERE objective_id = (SELECT weight_id FROM objective_weights WHERE objective_name = 'minimize_legal_violations');

UPDATE objective_priorities
SET priority_bucket = 'high', position = 2
WHERE objective_id = (SELECT weight_id FROM objective_weights WHERE objective_name = 'maximize_coverage');

UPDATE objective_priorities
SET priority_bucket = 'high', position = 3
WHERE objective_id = (SELECT weight_id FROM objective_weights WHERE objective_name = 'minimize_policy_violations');

-- Update important objectives to 'medium' priority
UPDATE objective_priorities
SET priority_bucket = 'medium', position = 1
WHERE objective_id = (SELECT weight_id FROM objective_weights WHERE objective_name = 'maximize_team_continuity');

UPDATE objective_priorities
SET priority_bucket = 'medium', position = 2
WHERE objective_id = (SELECT weight_id FROM objective_weights WHERE objective_name = 'balance_workload');

UPDATE objective_priorities
SET priority_bucket = 'medium', position = 3
WHERE objective_id = (SELECT weight_id FROM objective_weights WHERE objective_name = 'minimize_overtime_cost');

-- New quality objectives in 'medium' priority
