"""
Objective Weights Fetching and Organization
All objective weights are fetched dynamically from the backend database.

Objectives are ALWAYS ACTIVE - weights control their impact.
A weight of 0 effectively disables an objective.
"""
import sys
sys.path.append('..')
from api.client import get_client


class ObjectiveWeights:
    """Container for all objective weights fetched from backend"""

    def __init__(self, user_id: str = None):
        self.client = get_client(user_id=user_id)
        self.user_id = user_id  # User context for scoped weights

        # Will be populated by fetch method
        self.weights = {}  # objective_name -> weight_coefficient
        self.metadata = {}  # objective_name -> full objective data
        self.sources = {}  # objective_name -> "backend" or "fallback"

        # Default weights (BAR CCT / company defaults) for fallback
        # NOTE: maintain_function_continuity, maintain_shift_continuity, group_continuity
        # are NOT in the DB yet. Conservative defaults from config.py OBJECTIVE_FALLBACK_DEFAULTS.
        # These are low-priority — overridden by coverage/workload at medium or above.
        self.DEFAULTS = {
            'maximize_coverage': 3.0,
            'balance_workload': 1.5,
            'minimize_policy_violations': 5.0,
            'minimize_idle_time': 1.0,
            'maximize_team_continuity': 2.0,
            'maintain_function_continuity': 1.0,   # Conservative: min of [1.0-5.0]
            'maintain_shift_continuity': 1.5,      # Conservative: min of [1.5-5.0]
            'group_continuity': 0.5,               # Conservative: min of [0.5-3.0]
        }

    def fetch_all_weights(self):
        """
        Fetch all objective weights from backend.
        Falls back to defaults if backend unavailable.
        """
        print("\n[OBJECTIVE FETCH] Fetching objective weights from backend...")
        print("-" * 60)

        try:
            objectives = self.client.get_objective_weights(user_id=self.user_id)

            for obj in objectives:
                name = obj['objective_name']
                weight = obj['weight_coefficient']

                self.weights[name] = weight
                self.metadata[name] = obj
                self.sources[name] = "backend"

                category = obj.get('objective_category', 'unknown')
                active = obj.get('active', True)
                print(f"  [{category.upper()}] {name}: {weight} (from backend, active={active})")

            backend_count = len(objectives)
            print("-" * 60)
            print(f"[OBJECTIVE FETCH] Complete: {backend_count} objectives from backend")

        except Exception as e:
            print(f"  [WARNING] Failed to fetch from backend: {e}")
            print(f"  [WARNING] Using default weights...")
            self._use_defaults()

    def _use_defaults(self):
        """Use default weights when backend unavailable"""
        for name, weight in self.DEFAULTS.items():
            self.weights[name] = weight
            self.sources[name] = "fallback"
            print(f"  [FALLBACK] {name}: {weight}")

        print("-" * 60)
        print(f"[OBJECTIVE FETCH] Complete: {len(self.DEFAULTS)} objectives using fallback defaults")

    def get_weight(self, objective_name: str) -> float:
        """
        Get weight for specific objective.

        Args:
            objective_name: Name of the objective

        Returns:
            Weight coefficient (float)
        """
        if objective_name not in self.weights:
            # Try to fetch if not cached
            if not self.weights:
                self.fetch_all_weights()

            # If still not found, use default
            if objective_name not in self.weights:
                default = self.DEFAULTS.get(objective_name, 1.0)
                print(f"  [WARNING] Objective '{objective_name}' not in backend, using default: {default}")
                self.weights[objective_name] = default
                self.sources[objective_name] = "fallback"

        return self.weights[objective_name]

    def get_all_weights(self) -> dict:
        """
        Get all objective weights as dict.

        Returns:
            Dict mapping objective_name -> weight_coefficient
        """
        if not self.weights:
            self.fetch_all_weights()
        return self.weights.copy()

    def is_from_backend(self, objective_name: str) -> bool:
        """Check if objective weight came from backend or fallback"""
        return self.sources.get(objective_name) == "backend"

    def print_summary(self):
        """Print summary of all objective weights"""
        print("\n" + "=" * 60)
        print("OBJECTIVE WEIGHTS SUMMARY")
        print("=" * 60)

        # Group by category
        categories = {}
        for name, weight in self.weights.items():
            meta = self.metadata.get(name, {})
            category = meta.get('objective_category', 'unknown')
            if category not in categories:
                categories[category] = []
            categories[category].append((name, weight, self.sources.get(name, 'unknown')))

        for category in sorted(categories.keys()):
            print(f"\n{category.upper()}:")
            print("-" * 60)
            for name, weight, source in sorted(categories[category], key=lambda x: -x[1]):
                source_indicator = "" if source == "backend" else " [FALLBACK]"
                print(f"  {name:35s}: {weight:6.1f}{source_indicator}")

        print("=" * 60 + "\n")


def fetch_objective_weights(user_id: str = None) -> ObjectiveWeights:
    """
    Convenience function to fetch all objective weights.

    Args:
        user_id: User context ID for scoped weights (defaults to 'global' on server)

    Returns:
        ObjectiveWeights object with all weights populated
    """
    objectives = ObjectiveWeights(user_id=user_id)
    objectives.fetch_all_weights()
    return objectives
