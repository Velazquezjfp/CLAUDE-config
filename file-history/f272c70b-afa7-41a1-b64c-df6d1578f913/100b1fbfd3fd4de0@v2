"""
OBJ-08: Category Priority Analyzer
Analyzes how well resources are assigned to their primary categories.
"""
import re
from .base_analyzer import ObjectiveAnalyzer


def _normalize_string(s) -> str:
    """Normalize a string for comparison."""
    if s is None:
        return ""
    return re.sub(r'\s+', ' ', str(s).strip()).lower()


class CategoryPriorityAnalyzer(ObjectiveAnalyzer):
    """Analyzer for OBJ-08 (Category Priority)"""

    def __init__(self):
        super().__init__(
            objective_id='category_priority',
            objective_name='Category Priority'
        )

    def analyze_performance(self, solution, data, constraints):
        """
        Analyze category priority performance.

        Measures how well resources are assigned to their primary categories
        vs secondary/tertiary ones.
        """
        assignments = getattr(solution, 'solution_assignments',
                             getattr(solution, 'assignments', []))

        if not assignments:
            return self._empty_result("No assignments to analyze")

        # Build resource category index lookup
        resource_cat_index = {}
        for resource in data.resources:
            res_id = resource.get('resource_id', resource.get('id'))
            categories = resource.get('resource_categories', [])
            if not categories or not isinstance(categories, list):
                continue
            cat_index = {}
            for idx, cat in enumerate(categories):
                norm_cat = _normalize_string(cat)
                if norm_cat and norm_cat not in cat_index:
                    cat_index[norm_cat] = idx
            if cat_index:
                resource_cat_index[res_id] = cat_index

        # Analyze assignments
        primary_count = 0
        secondary_count = 0
        tertiary_plus_count = 0
        unknown_count = 0
        index_distribution = {}
        non_primary_details = []

        for assignment in assignments:
            res_id = assignment.get('resource_id')
            demand_cat = _normalize_string(assignment.get('resource_category', ''))

            if not demand_cat:
                unknown_count += 1
                continue

            cat_index = resource_cat_index.get(res_id)
            if not cat_index:
                unknown_count += 1
                continue

            idx = cat_index.get(demand_cat)
            if idx is None:
                unknown_count += 1
                continue

            index_distribution[idx] = index_distribution.get(idx, 0) + 1

            if idx == 0:
                primary_count += 1
            elif idx == 1:
                secondary_count += 1
            else:
                tertiary_plus_count += 1

            if idx > 0 and len(non_primary_details) < 20:
                non_primary_details.append({
                    'resource_id': res_id,
                    'demand_id': assignment.get('demand_id', assignment.get('request_id')),
                    'category': assignment.get('resource_category', ''),
                    'category_index': idx
                })

        total_categorized = primary_count + secondary_count + tertiary_plus_count
        if total_categorized > 0:
            achievement_rate = (primary_count / total_categorized) * 100
        else:
            achievement_rate = 100.0

        gaps = self.get_gap_details(solution, data)

        return {
            "objective_id": "category_priority",
            "objective_name": "Category Priority",
            "target_description": "Assign resources to their primary (highest-priority) category",
            "achieved_value": primary_count,
            "max_possible_value": total_categorized,
            "achievement_rate": round(achievement_rate, 2),
            "performance_category": self.classify_performance(achievement_rate),
            "gaps": gaps,
            "metrics": {
                "total_assignments": len(assignments),
                "primary_category_assignments": primary_count,
                "secondary_category_assignments": secondary_count,
                "tertiary_plus_assignments": tertiary_plus_count,
                "unknown_category_assignments": unknown_count,
                "primary_rate": round(achievement_rate, 2),
                "index_distribution": {str(k): v for k, v in sorted(index_distribution.items())},
                "non_primary_examples": non_primary_details[:10]
            }
        }

    def get_gap_details(self, solution, data):
        """Get detailed information about category priority gaps."""
        assignments = getattr(solution, 'solution_assignments',
                             getattr(solution, 'assignments', []))

        if not assignments:
            return []

        # Build resource category index lookup
        resource_cat_index = {}
        for resource in data.resources:
            res_id = resource.get('resource_id', resource.get('id'))
            categories = resource.get('resource_categories', [])
            if not categories or not isinstance(categories, list):
                continue
            cat_index = {}
            for idx, cat in enumerate(categories):
                norm_cat = _normalize_string(cat)
                if norm_cat and norm_cat not in cat_index:
                    cat_index[norm_cat] = idx
            if cat_index:
                resource_cat_index[res_id] = cat_index

        # Find resources consistently assigned to non-primary categories
        non_primary_by_resource = {}
        for assignment in assignments:
            res_id = assignment.get('resource_id')
            demand_cat = _normalize_string(assignment.get('resource_category', ''))
            cat_index = resource_cat_index.get(res_id, {})
            idx = cat_index.get(demand_cat)

            if idx is not None and idx > 0:
                if res_id not in non_primary_by_resource:
                    non_primary_by_resource[res_id] = []
                non_primary_by_resource[res_id].append({
                    'demand_id': assignment.get('demand_id', assignment.get('request_id')),
                    'category': assignment.get('resource_category', ''),
                    'index': idx
                })

        gaps = []

        # Resources frequently in non-primary categories
        frequent_non_primary = [
            (res_id, details)
            for res_id, details in non_primary_by_resource.items()
            if len(details) >= 3
        ]

        if frequent_non_primary:
            gaps.append({
                "gap_type": "FREQUENT_NON_PRIMARY",
                "description": f"{len(frequent_non_primary)} resources frequently assigned to non-primary categories",
                "impact": "Resources not working in their strongest category",
                "affected_resources": [
                    {
                        "resource_id": res_id,
                        "non_primary_assignments": len(details),
                        "categories_used": list(set(d['category'] for d in details))
                    }
                    for res_id, details in sorted(frequent_non_primary, key=lambda x: -len(x[1]))[:5]
                ],
                "recommendations": [
                    "Increase category_priority weight to favor primary categories",
                    "Review demand distribution — may need more resources with specific primary categories"
                ]
            })

        return gaps

    def _empty_result(self, message: str) -> dict:
        """Return empty result."""
        return {
            "objective_id": "category_priority",
            "objective_name": "Category Priority",
            "target_description": "Assign resources to their primary (highest-priority) category",
            "achieved_value": 0,
            "max_possible_value": 0,
            "achievement_rate": 100.0,
            "performance_category": "EXCELLENT",
            "gaps": [],
            "metrics": {
                "total_assignments": 0,
                "message": message
            }
        }
