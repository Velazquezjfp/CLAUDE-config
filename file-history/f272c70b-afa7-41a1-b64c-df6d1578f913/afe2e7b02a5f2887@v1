"""
Partition State for Constraint Carryover

Tracks constraint state at partition boundaries to ensure rolling constraints
(LC-01, LC-05, LC-06, LC-07) and annual constraints (OC-01) are satisfied
across partitions.

TASK-062: Implement Partitioning Strategy

State Categories:
1. Rolling Window States (LC-01, LC-04, LC-05, LC-06, LC-07):
   - Track last N days of activity for rolling constraint windows
   - Clean up old data outside relevant windows at each partition boundary

2. Annual Target States (OC-01):
   - Track year-to-date (YTD) activity toward annual targets
   - Protecteur shifts, Chef sécurité shifts, CVM hours
   - Used for prorating targets in subsequent partitions
"""
from dataclasses import dataclass, field
from datetime import datetime, date, timedelta, timezone
from typing import Dict, List, Any, Optional
import json


def _ensure_aware(dt: datetime) -> datetime:
    """Ensure datetime is timezone-aware (UTC). Handles naive datetimes from DB."""
    if dt is not None and dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    return dt


# =============================================================================
# OC-01 CATEGORY ACTIVITY TRACKING
# =============================================================================

@dataclass
class CategoryActivityState:
    """
    Tracks annual category activity for OC-01 constraint.

    This enables accurate prorating when planning in partitions.
    """
    # Shift-based categories (count)
    shifts_protecteur: int = 0
    shifts_chef_securite: int = 0

    # Hour-based categories
    hours_cvm: float = 0.0

    # Generic category tracking for future extensibility
    shifts_by_category: Dict[str, int] = field(default_factory=dict)
    hours_by_category: Dict[str, float] = field(default_factory=dict)

    def add_shift(self, category: str):
        """Record a shift assignment in a category."""
        norm_cat = category.lower().strip() if category else ''

        if norm_cat == 'protecteur':
            self.shifts_protecteur += 1
        elif norm_cat in ('chef sécurité', 'chef securite'):
            self.shifts_chef_securite += 1

        # Also track in generic dict
        self.shifts_by_category[norm_cat] = self.shifts_by_category.get(norm_cat, 0) + 1

    def add_hours(self, category: str, hours: float):
        """Record hours worked in a category."""
        norm_cat = category.lower().strip() if category else ''

        if norm_cat == 'cvm':
            self.hours_cvm += hours

        # Also track in generic dict
        self.hours_by_category[norm_cat] = self.hours_by_category.get(norm_cat, 0.0) + hours

    def get_activity(self, category: str, activity_type: str = 'shifts') -> float:
        """Get activity for a category (shifts or hours)."""
        norm_cat = category.lower().strip() if category else ''

        if activity_type == 'shifts':
            if norm_cat == 'protecteur':
                return self.shifts_protecteur
            elif norm_cat in ('chef sécurité', 'chef securite'):
                return self.shifts_chef_securite
            return self.shifts_by_category.get(norm_cat, 0)
        else:  # hours
            if norm_cat == 'cvm':
                return self.hours_cvm
            return self.hours_by_category.get(norm_cat, 0.0)

    def to_dict(self) -> Dict[str, Any]:
        """Serialize to dict."""
        return {
            'shifts_protecteur': self.shifts_protecteur,
            'shifts_chef_securite': self.shifts_chef_securite,
            'hours_cvm': self.hours_cvm,
            'shifts_by_category': dict(self.shifts_by_category),
            'hours_by_category': dict(self.hours_by_category),
        }

    @classmethod
    def from_dict(cls, data: Dict[str, Any]) -> 'CategoryActivityState':
        """Deserialize from dict."""
        state = cls()
        state.shifts_protecteur = data.get('shifts_protecteur', 0)
        state.shifts_chef_securite = data.get('shifts_chef_securite', 0)
        state.hours_cvm = data.get('hours_cvm', 0.0)
        state.shifts_by_category = data.get('shifts_by_category', {})
        state.hours_by_category = data.get('hours_by_category', {})
        return state


# =============================================================================
# ANNUAL CONTEXT FOR YTD TRACKING
# =============================================================================

@dataclass
class AnnualContext:
    """
    Tracks annual planning context for year-based constraints like OC-01.

    This enables correct prorating of annual targets across partitions.
    """
    # The calendar year being planned
    planning_year: int = 0

    # Year start/end dates (for calculating annual fraction)
    year_start: Optional[date] = None
    year_end: Optional[date] = None

    # Days already processed this year (for prorating)
    days_processed: int = 0

    # Total days in planning horizon for this year
    total_days_planned: int = 0

    def get_annual_fraction_so_far(self) -> float:
        """Get fraction of year processed so far."""
        if self.total_days_planned <= 0:
            return 0.0
        return min(1.0, self.days_processed / 365.0)

    def get_remaining_fraction(self) -> float:
        """Get fraction of year remaining."""
        return max(0.0, 1.0 - self.get_annual_fraction_so_far())

    def to_dict(self) -> Dict[str, Any]:
        """Serialize to dict."""
        return {
            'planning_year': self.planning_year,
            'year_start': str(self.year_start) if self.year_start else None,
            'year_end': str(self.year_end) if self.year_end else None,
            'days_processed': self.days_processed,
            'total_days_planned': self.total_days_planned,
        }

    @classmethod
    def from_dict(cls, data: Dict[str, Any]) -> 'AnnualContext':
        """Deserialize from dict."""
        ctx = cls()
        ctx.planning_year = data.get('planning_year', 0)
        if data.get('year_start'):
            ctx.year_start = date.fromisoformat(data['year_start'])
        if data.get('year_end'):
            ctx.year_end = date.fromisoformat(data['year_end'])
        ctx.days_processed = data.get('days_processed', 0)
        ctx.total_days_planned = data.get('total_days_planned', 0)
        return ctx


