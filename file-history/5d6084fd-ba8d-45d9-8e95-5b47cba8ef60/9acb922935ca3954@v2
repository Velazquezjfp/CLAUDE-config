:root {
  --bg: #f7f7fb;
  --panel: #ffffff;
  --border: #e3e3ec;
  --text: #222;
  --muted: #6b7280;
  --accent: #4f46e5;
}

* { box-sizing: border-box; }

body {
  margin: 0;
  font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  background: var(--bg);
  color: var(--text);
}

header {
  padding: 24px 32px;
  background: var(--panel);
  border-bottom: 1px solid var(--border);
}

header h1 { margin: 0 0 4px; font-size: 1.5rem; }
.subtitle { margin: 0; color: var(--muted); font-size: 0.9rem; }

main {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: 24px;
  padding: 24px 32px;
}

#planner {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 16px;
  overflow-x: auto;
}

table {
  width: 100%;
  border-collapse: collapse;
}

th, td {
  text-align: left;
  padding: 10px 12px;
  border-bottom: 1px solid var(--border);
  vertical-align: middle;
}

th {
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: var(--muted);
}

td.day-label {
  font-weight: 600;
  width: 80px;
}

select {
  width: 100%;
  padding: 6px 8px;
  border: 1px solid var(--border);
  border-radius: 6px;
  background: #fff;
  font-size: 0.9rem;
}

select:focus {
  outline: 2px solid var(--accent);
  outline-offset: 0;
  border-color: var(--accent);
}

#summary {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 16px;
  height: fit-content;
}

#summary h2 {
  margin: 0 0 12px;
  font-size: 1rem;
}

#summary p {
  margin: 6px 0;
  font-size: 0.9rem;
  color: var(--muted);
}

#summary span {
  color: var(--text);
  font-weight: 600;
}

@media (max-width: 720px) {
  main { grid-template-columns: 1fr; padding: 16px; }
  header { padding: 16px; }
}
