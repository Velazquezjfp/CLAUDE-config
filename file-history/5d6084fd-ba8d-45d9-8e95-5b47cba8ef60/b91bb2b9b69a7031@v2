const DAYS = [
  ["mon", "Monday"],
  ["tue", "Tuesday"],
  ["wed", "Wednesday"],
  ["thu", "Thursday"],
  ["fri", "Friday"],
  ["sat", "Saturday"],
  ["sun", "Sunday"],
];
const SLOTS = ["breakfast", "lunch", "dinner"];

let meals = [];
let plan = {};

async function fetchJSON(url, options) {
  const res = await fetch(url, options);
  if (!res.ok) throw new Error(`Request failed: ${res.status}`);
  return res.json();
}

function renderTable() {
  const tbody = document.getElementById("plan-body");
  tbody.innerHTML = "";

  for (const [key, label] of DAYS) {
    const tr = document.createElement("tr");
    const dayCell = document.createElement("td");
    dayCell.className = "day-label";
    dayCell.textContent = label;
    tr.appendChild(dayCell);

    for (const slot of SLOTS) {
      const td = document.createElement("td");
      const select = document.createElement("select");
      select.dataset.day = key;
      select.dataset.slot = slot;

      const empty = document.createElement("option");
      empty.value = "";
      empty.textContent = "— none —";
      select.appendChild(empty);

      for (const meal of meals) {
        const opt = document.createElement("option");
        opt.value = meal.id;
        opt.textContent = `${meal.name} (${meal.kcal} kcal)`;
        select.appendChild(opt);
      }

      select.value = plan[key]?.[slot] ?? "";
      select.addEventListener("change", onSelectChange);
      td.appendChild(select);
      tr.appendChild(td);
    }

    tbody.appendChild(tr);
  }
}

function renderSummary() {
  let count = 0;
  let kcal = 0;
  const mealsById = Object.fromEntries(meals.map((m) => [m.id, m]));

  for (const day of Object.values(plan)) {
    for (const mealId of Object.values(day)) {
      if (mealId && mealsById[mealId]) {
        count += 1;
        kcal += mealsById[mealId].kcal;
      }
    }
  }

  document.getElementById("count").textContent = count;
  document.getElementById("kcal").textContent = kcal;
}

async function onSelectChange(event) {
  const { day, slot } = event.target.dataset;
  const mealId = event.target.value || null;

  plan = await fetchJSON("/api/plan", {
    method: "PUT",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ day, slot, meal_id: mealId }),
  });

  renderSummary();
}

async function init() {
  [meals, plan] = await Promise.all([
    fetchJSON("/api/meals"),
    fetchJSON("/api/plan"),
  ]);
  renderTable();
  renderSummary();
}

init().catch((err) => {
  console.error(err);
  document.body.insertAdjacentHTML(
    "beforeend",
    `<p style="color:red;padding:16px">Failed to load data: ${err.message}</p>`
  );
});
