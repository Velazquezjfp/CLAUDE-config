<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Meal Planner</title>
    <link rel="stylesheet" href="/static/styles.css" />
  </head>
  <body>
    <header>
      <h1>Weekly Meal Planner</h1>
      <p class="subtitle">Plan your week, one meal at a time.</p>
    </header>

    <main>
      <section id="planner">
        <table id="plan-table">
          <thead>
            <tr>
              <th></th>
              <th>Breakfast</th>
              <th>Lunch</th>
              <th>Dinner</th>
            </tr>
          </thead>
          <tbody id="plan-body"></tbody>
        </table>
      </section>

      <aside id="summary">
        <h2>Summary</h2>
        <p>Total meals planned: <span id="count">0</span></p>
        <p>Estimated kcal: <span id="kcal">0</span></p>
      </aside>
    </main>

    <script src="/static/app.js"></script>
  </body>
</html>
