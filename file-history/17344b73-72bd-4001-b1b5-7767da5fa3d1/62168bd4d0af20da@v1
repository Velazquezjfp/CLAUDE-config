"""
CFF Workforce Planning Solver - MVP Entry Point
Fetches data from live database and solves with OR-tools CP-SAT
"""
import sys
from api.client import get_client
from preprocessing.constraints import fetch_constraint_values
from preprocessing.objectives import fetch_objective_weights
from preprocessing.data_processor import preprocess_data
from solver.model import create_and_solve_model
from config import (
    TEST_MODE,
    TEST_NUM_REQUESTS,
    TEST_NUM_RESOURCES,
    PLANNING_MODE,
    ENABLED_CONSTRAINTS,
    Environment
)
from ortools.sat.python import cp_model


def main():
    """Main entry point for the solver"""

    print("\n" + "="*70)
    print(" CFF WORKFORCE PLANNING SOLVER - MVP")
    print("="*70)
    print(f"Mode: {'TEST (small dataset)' if TEST_MODE else 'FULL DATABASE'}")
    print(f"Planning Mode: {PLANNING_MODE}")
    print(f"Enabled Constraints: {', '.join(ENABLED_CONSTRAINTS)}")
    print("="*70 + "\n")

    # ========== Step 1: Fetch Data from Live Database ==========
    print("[STEP 1] Fetching data from live database...")
    print("-" * 70)

    client = get_client()

    # Replannable calendar types (can be set via environment variable)
    # Types in this list are EXCLUDED from blocking - resources become available
    import os
    replannable_types_env = os.environ.get('REPLANNABLE_DEMAND_TYPES', '')
    replannable_types = [t.strip() for t in replannable_types_env.split(',') if t.strip()] if replannable_types_env else []
    if replannable_types:
        print(f"Replannable types (excluded from blocking): {replannable_types}")

    if TEST_MODE:
        # Test mode: fetch small dataset
        print(f"TEST MODE: Fetching {TEST_NUM_REQUESTS} requests and {TEST_NUM_RESOURCES} resources")
        dataset = client.fetch_test_dataset(
            num_requests=TEST_NUM_REQUESTS,
            num_resources=TEST_NUM_RESOURCES
        )
        requests_data = dataset['requests']
        resources_data = dataset['resources']
        # Use new resource-blocks API for blocking periods (excluding replannable types)
        absences_data = client.get_resource_blocks(
            category="all",
            exclude_calendar_types=replannable_types if replannable_types else None
        )
    else:
        # Full mode: fetch all data
        print("FULL MODE: Fetching all requests and resources")
        requests_data = client.get_requests()
        resources_data = client.get_resources()
        # Use new resource-blocks API for blocking periods (excluding replannable types)
        absences_data = client.get_resource_blocks(
            category="all",
            exclude_calendar_types=replannable_types if replannable_types else None
        )

    print(f"Fetched {len(requests_data['data'])} requests")
    print(f"Fetched {len(resources_data['data'])} resources")
    print(f"Fetched {len(absences_data['data'])} absences (resource blocks)")

    # ========== Step 2: Fetch Constraint Values ==========
    print("\n[STEP 2] Fetching constraint values from database...")
    print("-" * 70)

    # User ID from environment (for standalone mode)
    solver_user_id = os.environ.get('SOLVER_USER_ID', None)
    if solver_user_id:
        print(f"User context: {solver_user_id}")

    constraint_values = fetch_constraint_values(planning_mode=PLANNING_MODE, user_id=solver_user_id)
    constraint_values.print_summary()

    # ========== Step 2B: Fetch Objective Weights ==========
    print("\n[STEP 2B] Fetching objective weights from database...")
    print("-" * 70)

    objective_weights = fetch_objective_weights(user_id=solver_user_id)
    objective_weights.print_summary()

    # ========== Step 3: Preprocess Data ==========
    print("\n[STEP 3] Preprocessing data...")
    print("-" * 70)

    preprocessed_data = preprocess_data(
        requests_data,
        resources_data,
        absences_data
    )
    preprocessed_data.print_summary()

    # ========== Step 4: Build and Solve Model ==========
    print("\n[STEP 4] Building and solving CP-SAT model...")
    print("-" * 70)

    model = create_and_solve_model(preprocessed_data, constraint_values, objective_weights)

    # ========== Step 5: Run Analysis ==========
    if model.status in [cp_model.OPTIMAL, cp_model.FEASIBLE]:
        print("\n" + "="*70)
        print(" POST-SOLVE ANALYSIS")
        print("="*70)

        from analysis.solution_analyzer import SolutionAnalyzer
        import json

        try:
            analyzer = SolutionAnalyzer(
                solution=model,
                data=preprocessed_data,
                constraints=constraint_values
            )

            analysis_report = analyzer.analyze()

            # Save analysis report
            with open('solver_v2/output/analysis_report.json', 'w') as f:
                json.dump(analysis_report, f, indent=2, default=str)

            print("\n✓ Analysis complete: solver_v2/output/analysis_report.json")

            # Print summary
            print("\n" + "-"*70)
            print("ANALYSIS SUMMARY:")
            print("-"*70)
            summary = analysis_report['summary']
            print(f"Overall Status: {summary['overall_status']}")
            print(f"\nCoverage: {summary['coverage']['rate']}% ({summary['coverage']['category']})")
            print(f"  - Covered: {summary['coverage']['requests_covered']}/{summary['coverage']['requests_total']} requests")
            print(f"  - Uncovered: {summary['coverage']['requests_uncovered']} requests")

            if 'workload_balance' in summary:
                print(f"\nWorkload Balance: {summary['workload_balance']['rate']}% ({summary['workload_balance']['category']})")
                print(f"  - Variance: {summary['workload_balance']['variance_hours']}h")

            print(f"\nViolations: {summary['violations']['severity']}")
            print(f"  - Total Count: {summary['violations']['total_count']}")
            print(f"  - Total Amount: {summary['violations']['total_amount_hours']:.1f}h over limits")
            print(f"  - Affected Resources: {summary['violations']['affected_resources']}")

            if summary.get('key_insights'):
                print("\nKey Insights:")
                for insight in summary['key_insights'][:3]:
                    print(f"  • {insight}")

            if summary.get('top_recommendations'):
                print("\nTop Recommendations:")
                for rec in summary['top_recommendations'][:3]:
                    priority = rec.get('priority', 'MEDIUM')
                    action = rec.get('action', '')
                    print(f"  • [{priority}] {action}")

        except Exception as e:
            print(f"\n⚠️  Analysis failed: {e}")
            import traceback
            traceback.print_exc()

    # ========== Step 6: Summary ==========
    print("\n" + "="*70)
    print(" EXECUTION SUMMARY")
    print("="*70)

    if model.status is not None:
        status_name = {
            4: "OPTIMAL",
            2: "FEASIBLE",
            3: "INFEASIBLE",
            0: "UNKNOWN"
        }.get(model.status, "UNKNOWN")

        print(f"Solver Status: {status_name}")
        if model.solution_assignments:
            print(f"Assignments Found: {len(model.solution_assignments)}")
            print(f"Solve Time: {model.solver.WallTime():.2f} seconds")

            # Calculate some statistics
            total_hours = sum(a['duration_hours'] for a in model.solution_assignments)
            print(f"Total Work Hours: {total_hours:.2f}h")

            # Group by resource
            resource_workload = {}
            for assignment in model.solution_assignments:
                res_id = assignment['resource_id']
                if res_id not in resource_workload:
                    resource_workload[res_id] = 0
                resource_workload[res_id] += assignment['duration_hours']

            print("\nResource Workload:")
            for res_id, hours in resource_workload.items():
                print(f"  {res_id}: {hours:.2f}h")
        else:
            print("No solution found - problem is infeasible!")
    else:
        print("Model was not solved")

    # ========== Step 7: POST Results to Database ==========
    if model.status in [cp_model.OPTIMAL, cp_model.FEASIBLE]:
        print("\n[STEP 7] Posting results to planner_output table...")
        print("-" * 70)
        
        from datetime import datetime
        
        # Get environment and user from client
        env = client.env
        user_id = client.user_id
        test_mode = TEST_MODE
        
        # Generate plan_id
        timestamp = datetime.now().strftime("%Y%m%d-%H%M%S")
        plan_id = f"PLAN-{timestamp}"
        
        # Map status code to string
        status_map = {4: "OPTIMAL", 2: "FEASIBLE", 3: "INFEASIBLE", 0: "UNKNOWN"}
        status_str = status_map.get(model.status, "UNKNOWN")
        
        # Count violations from analysis if available
        num_violations = 0
        if 'analysis_report' in locals() and analysis_report:
            num_violations = analysis_report.get('summary', {}).get('violations', {}).get('total_count', 0)
        
        try:
            result = client.post_planner_output(
                plan_id=plan_id,
                status=status_str,
                assignments=model.solution_assignments or [],
                num_requests=len(requests_data['data']),
                num_resources=len(resources_data['data']),
                num_violations=num_violations,
                solve_time_seconds=model.solver.WallTime(),
                metadata={
                    "planning_mode": PLANNING_MODE,
                    "test_mode": test_mode,
                    "enabled_constraints": ENABLED_CONSTRAINTS,
                }
            )
            print(f"✓ Results posted successfully. Plan ID: {plan_id}")
        except Exception as e:
            print(f"⚠️ Failed to post results: {e}")
            # Don't fail the whole run if POST fails


    print("="*70 + "\n")

    return model


if __name__ == "__main__":
    try:
        model = main()
        sys.exit(0 if model.status in [2, 4] else 1)  # 0 = success
    except Exception as e:
        print(f"\n[ERROR] {str(e)}")
        import traceback
        traceback.print_exc()
        sys.exit(1)
