---
title: BAMF ACTE Companion - Kubernetes Deployment Architektur
---
flowchart TB
    %% Externer Einstiegspunkt
    Browser["Browser"]

    %% Kubernetes Cluster
    subgraph K8s["Kubernetes Cluster"]
        direction TB

        %% Ingress Layer
        subgraph Ingress["Ingress Layer"]
            NginxIngress["NGINX Ingress Controller<br/>acte.bamf.internal<br/>TLS Terminierung"]
        end

        %% Frontend
        subgraph FrontendPod["Frontend Pod (x2 Replicas)"]
            Frontend["React 18 + NGINX<br/>Port: 80<br/>Statische SPA-Dateien"]
        end

        %% Backend
        subgraph BackendPod["Backend Pod (x2 Replicas)"]
            Backend["FastAPI + Uvicorn<br/>Port: 8000<br/>Python 3.12<br/>10 REST Router + WebSocket"]
        end

        %% Persistent Storage
        subgraph Storage["Persistenter Speicher"]
            DocPVC["Dokumenten-PVC<br/>10Gi RWX<br/>PDF / Bilder / E-Mails"]
            CasePVC["Case-Daten-PVC<br/>5Gi RWX<br/>JSON Konfiguration"]
        end

        %% Configuration
        subgraph Config["Konfiguration"]
            ConfigMap["ConfigMap<br/>acte-config"]
            Secret["Secret<br/>acte-secrets<br/>GEMINI_API_KEY"]
        end
    end

    %% External Services
    subgraph External["Externe Dienste"]
        Anon["Anonymisierungsdienst<br/>Port: 5000<br/>PII-Erkennung"]
        IDIRS["IDIRS OpenSearch<br/>Port: 8010<br/>Hybride Suche + RAG"]
        Gemini["Google Gemini API<br/>HTTPS Port 443<br/>gemini-2.5-flash"]
    end

    %% Verbindungen - Browser zu Ingress
    Browser -->|"HTTPS"| NginxIngress

    %% Verbindungen - Ingress zu Services
    NginxIngress -->|"Statische Dateien /"| Frontend
    NginxIngress -->|"/api/* und /ws/*"| Backend

    %% Verbindungen - Backend zu Storage
    Backend <-->|"Lesen/Schreiben"| DocPVC
    Backend <-->|"Lesen/Schreiben"| CasePVC

    %% Verbindungen - Backend zu Config
    Backend -.->|"Liest"| ConfigMap
    Backend -.->|"Liest"| Secret

    %% Verbindungen - Backend zu Externen Diensten
    Backend -->|"HTTP :5000"| Anon
    Backend -->|"HTTP :8010"| IDIRS
    Backend -->|"HTTPS :443"| Gemini

    %% Styling
    classDef frontend fill:#4A90E2,stroke:#2E5C8A,stroke-width:2px,color:#fff
    classDef backend fill:#9B59B6,stroke:#6C3483,stroke-width:2px,color:#fff
    classDef storage fill:#27AE60,stroke:#1E8449,stroke-width:2px,color:#fff
    classDef external fill:#E74C3C,stroke:#C0392B,stroke-width:2px,color:#fff
    classDef ingress fill:#95A5A6,stroke:#7F8C8D,stroke-width:2px,color:#fff
    classDef config fill:#F39C12,stroke:#D68910,stroke-width:2px,color:#fff
    classDef browser fill:#34495E,stroke:#2C3E50,stroke-width:2px,color:#fff

    class Frontend frontend
    class Backend backend
    class DocPVC,CasePVC storage
    class Anon,IDIRS,Gemini external
    class NginxIngress ingress
    class ConfigMap,Secret config
    class Browser browser
