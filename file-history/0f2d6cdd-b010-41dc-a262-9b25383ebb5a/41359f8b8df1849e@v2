# CFF Workforce Planning Solver - Development Environment
# Usage: docker-compose -f docker-compose.dev.yml up

name: cff-solver-dev

version: '3.8'

services:
  solver-api:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: cff-solver-dev
    ports:
      - "8004:8004"
    environment:
      - SOLVER_ENV=dev
      # Connect to backend container by name (on same network)
      - BACKEND_HOST=cff_api
      - BACKEND_PORT=8000  # Internal container port, not mapped port
      - PYTHONUNBUFFERED=1
      # Optional: Force WSS if nginx doesn't set X-Forwarded-Proto header
      # - FORCE_HTTPS_WEBSOCKET=true
    volumes:
      # Mount output directory for results
      - ./output:/app/output
      # Mount source code for development (remove for production)
      - .:/app
    networks:
      - cff_network  # Use the backend's existing network
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 12G
        reservations:
          memory: 6G
    healthcheck:
      test: ["CMD", "python", "-c", "import httpx; httpx.get('http://localhost:8004/health')"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s

networks:
  cff_network:
    external: true  # Connect to existing network from database_application_v2
